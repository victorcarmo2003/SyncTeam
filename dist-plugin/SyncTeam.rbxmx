<roblox version="4">
  <Item class="Script" referent="0">
    <Properties>
      <string name="Name">SyncTeam</string>
      <token name="RunContext">0</token>
      <string name="Source"><![CDATA[-- SyncTeam — Plugin de produção (M2 + M3.1 + M3.2 + M4 + M4.5)
--
-- Ponte local mínima para 1 desenvolvedor: cliente WebSocket único da
-- extensão VS Code (a extensão hospeda o servidor; o plugin é sempre
-- cliente — decisão registrada em docs/DECISIONS.md), observação genérica
-- de Source nos containers fixos (SourceWatcher/Config) e handlers do
-- protocolo v2 (writeSource/readSource/listScripts endereçados por
-- UUID+ObjectValue via ScriptRegistry, não mais por path — ver
-- docs/MILESTONES.md seção M2) com handshake versionado. A partir do M3.1,
-- também inicia/para TeamCreateElection (Sessions + heartbeat + eleição de
-- líder sob TestService.SyncTeam) junto com SourceWatcher. A partir do
-- M3.2, também inicia/para TeamCreateLease (leases autoritativas por
-- script) e `handleWriteSource` em modo atualização passa a checar a lease
-- antes de escrever (ver TeamCreateLease.luau). A partir do M4, também
-- inicia/para TeamCreatePresence (passthrough de cursor/seleção/arquivo ativo
-- vindo da extensão para Sessions/<clientId>/Presence) e despacha a mensagem
-- espontânea `presenceUpdate` para `TeamCreatePresence.updateOwnPresence`
-- (ver TeamCreatePresence.luau). A partir do M4.5, a antiga toolbar de 3
-- botões (Conectar/Parar/Alternar porta) foi substituída por 1 botão só que
-- alterna um DockWidgetPluginGui (painel de status construído com Vide, ver
-- plugin/src/ui/PluginUI.luau) — este arquivo continua sendo o ÚNICO dono da
-- lógica de conexão/sessão; PluginUI só invoca callbacks (onConnect/
-- onDisconnect/onPortChange/onAutoReconnectToggle) e reflete estado
-- (setConnectionStatus/setPort), nunca reimplementa nada de
-- start()/stop()/troca de porta. 2026-07-20: a tela de configurações do
-- painel ganhou um toggle real para Config.AUTOSTART_SETTING_KEY
-- (onAutoReconnectToggle abaixo, perto de PluginUI.init) — a setting já
-- existia desde 2026-07-16, só sem UI dedicada.
--
-- Fora de escopo aqui (ver docs/MILESTONES.md): UX de lease no VS Code
-- (M3.3, delegado a ui-dev); renderização de cursores/seleções na extensão
-- (M4, delegado a ui-dev — este arquivo só faz o passthrough de dados
-- opacos); schema versionado (SchemaVersion, nunca existiu no SyncTeam);
-- propriedades de instâncias não-script (decisão fixa do projeto, v1 só
-- scripts).
--
-- Porta do padrão de spikes/m0_5-local-pipeline/plugin/SyncTeamLab.lua
-- (checkSourceChanged polling+sinal) e spikes/m0-source-replication/
-- SyncTeamM0.lua (token de geração para start/stop seguro).
--
-- 2026-07-07: auto-descoberta de porta em runConnection (ver comentário na
-- própria função) — estopgap para o cenário de teste com 2 Studios na mesma
-- máquina/mesma pasta de Plugins, que hoje colidem na mesma porta sem isso.
-- O campo de porta do painel (M4.5, PluginUI.luau/onPortChange abaixo)
-- continua funcionando como fallback manual: uma porta setada
-- explicitamente é sempre a única tentada, nunca cicla pelas candidatas (ver
-- Config.resolveCandidatePorts).

local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")
local StudioService = game:GetService("StudioService")

local Config = require(script.Config)
local Logger = require(script.Logger)
local SourceWatcher = require(script.SourceWatcher)
local TeamCreateElection = require(script.TeamCreateElection)
local TeamCreateLease = require(script.TeamCreateLease)
local TeamCreatePresence = require(script.TeamCreatePresence)
local PluginUI = require(script.ui.PluginUI)

local enabled = false
local currentToken = 0
local client = nil -- WebStreamClient conectado no momento (nil se desconectado)

-- Guarda de modo Run/Play (F8 Run / F5 Play), 2026-07-16 — pesquisa em
-- .claude/research/2026-07-16-runservice-isstudio-isrunning-plugin-detect-test.md.
-- `RunService:IsStudio()` sozinho NÃO distingue edição normal do Team Create de
-- um teste rodando dentro do próprio Studio (fica `true` nos dois casos) — a
-- condição correta de "devo sincronizar" é `IsStudio() and not IsRunning()`.
-- Checagem só no boot não basta: o dev pode apertar F8/F5 DEPOIS do plugin já
-- estar conectado, então isso precisa de polling contínuo detectando a
-- TRANSIÇÃO edição->teste (chama stop()) e teste->edição (chama start() de
-- novo, só se este guard foi quem parou). Reaproveita
-- Config.POLL_INTERVAL_SECONDS (mesmo intervalo já usado para o polling de
-- Source) em vez de um timer novo dedicado — loop próprio, module-level,
-- independente de `enabled`/`currentToken` (precisa rodar mesmo desconectado,
-- para detectar o retorno à edição e poder chamar start() de novo).
--
-- 2026-07-20 (BUG 1, ver docs/DECISIONS.md): a condição
-- `RunService:IsStudio() and RunService:IsRunning()` estava DUPLICADA (aqui e
-- no fim do arquivo, antes do autostart) e o botão CONNECT do painel
-- (onConnect, PluginUI.init abaixo) não tinha NENHUM guard — extraída para
-- esta função única, usada em TODOS os pontos de entrada de start()
-- (checkRunModeTransition, autostart, onConnect, e dentro do próprio start()
-- como defesa em profundidade).
local function isInRunOrPlayMode()
	return RunService:IsStudio() and RunService:IsRunning()
end

-- Limitação conhecida, não resolvida (documentada na pesquisa e em
-- docs/DECISIONS.md 2026-07-16): quando o teste é PAUSADO, a doc oficial
-- afirma que `IsRunning()` (e `IsEdit()`) ficam ambos `false` — ou seja, este
-- guard pode falso-negativo e achar que voltou para edição normal enquanto o
-- teste só está pausado, retomando o sync indevidamente. Não há solução limpa
-- documentada para isso; tratado como limitação aceita, não um hack.
local wasInRunOrPlayMode = isInRunOrPlayMode()
local runGuardStoppedSync = false -- true quando ESTE guard (não o usuário) chamou stop() por causa do Run/Play

-- Sinal EXPLÍCITO de rejeição de porta (2026-07-15): a extensão VS Code rejeita
-- um 2º cliente na mesma porta mandando uma mensagem de aplicação
-- {kind="connectionRejected", reason="port_in_use"} ANTES de fechar o WS. Como
-- WebStreamClient.Closed não expõe close code nem motivo
-- (.claude/research/2026-07-15-webstreamclient-close-code.md), essa mensagem é o
-- único jeito CONFIÁVEL de o plugin saber que o motivo real da queda é "porta
-- ocupada por outro Studio" — a heurística de tempo em runConnection só INFERE
-- isso. handleMessage seta `connectionRejected`; runConnection lê a flag para
-- tratar como rejeição confirmada sem esperar a janela de tempo. É module-level
-- porque handleMessage (dispatch genérico) não enxerga os locals de
-- runConnection — por isso runConnection reseta a flag a cada tentativa.
-- `activePort` = porta da tentativa em curso, usada só para o texto do toast em
-- handleMessage. `lastRejectedPortToasted` deduplica o toast: o Toast é
-- single-instance e re-show reinicia o timer (ver ui/Toast.luau), então sem
-- dedup reconectar numa porta explícita ocupada a cada RECONNECT_SECONDS
-- deixaria um toast permanente/indispensável — mesma disciplina anti-spam de
-- outageToasted/hasStabilizedOnce abaixo.
local connectionRejected = false
local activePort = nil
local lastRejectedPortToasted = nil

-- Guarda de reentrância da troca de porta pelo painel (2026-07-16, bug real
-- com log). FocusLost do campo de porta (ui/StatusPanel.luau, PortRow) pode
-- disparar MAIS DE UMA VEZ para o mesmo Enter/perda de foco (quirk conhecido de
-- TextBox no Roblox). O único guard contra repetição que existia é
-- `newPort ~= state.port()` DENTRO do PortRow, mas ele NÃO é seguro contra
-- reentrância: `state.port()` (portSource) só é atualizado de forma ASSÍNCRONA
-- por PluginUI.setPort, chamado lá dentro de runConnection (já no novo start()).
-- Existe portanto uma janela em que um 2º FocusLost lê o state.port() AINDA
-- ANTIGO contra o portBox.Text já NOVO, passa pelo guard e dispara um 2º
-- onPortChange. Esse 2º onPortChange roda stop()+start() de novo e o stop() mata
-- a sessão/conexão que o 1º start() acabou de criar (sintoma observado no log:
-- conecta em ws://127.0.0.1:1405 e ~40ms depois um stop() completo do MESMO
-- clientId recém-criado). Duas camadas de proteção, complementares:
--   (a) portChangeInFlight: enquanto o stop()+start() de uma troca ainda está
--       rodando (start() pode yieldar internamente), uma 2ª chamada é ignorada
--       — protege o caso de reentrância por yield.
--   (b) dedupe por VALOR+TEMPO: uma 2ª chamada com o MESMO newPort dentro de
--       PORT_CHANGE_DEDUPE_SECONDS é ignorada mesmo depois que a flag baixou —
--       cobre a janela entre start() retornar (flag=false) e o runConnection de
--       fato atualizar state.port(), que é EXATAMENTE quando o guard do PortRow
--       falha.
local PORT_CHANGE_DEDUPE_SECONDS = 1
local portChangeInFlight = false
local lastPortChangeValue = nil
local lastPortChangeAt = 0

local log = Logger.log
local notify = Logger.notify

-- sendMessage é a própria função que o Logger usa para encaminhar logs pela
-- conexão WS (injetada em Logger.init(sendMessage) dentro de start()) — os
-- dois logs internos abaixo usam `print` PURO, nunca `log`/`Logger.log`.
-- Motivo (evitar recursão, ver Logger.luau): se usassem `log`, uma falha de
-- envio disparia Logger.log -> sendMessage -> (falha de novo) -> log da
-- falha via Logger.log -> sendMessage de novo, sem saída natural do ciclo.
-- Formato do print mantido idêntico ao de antes desta tarefa.
local function sendMessage(message)
	if client == nil then
		-- kind == "log" é o próprio Logger.log tentando se auto-encaminhar
		-- pela conexão WS (ver Logger.luau) — o conteúdo já apareceu no
		-- Output via print() dentro de Logger.log; avisar "descartado" aqui
		-- é só ruído duplicado, não uma falha real. Mensagens de protocolo de
		-- verdade (scriptAdded, presenceUpdate, etc.) continuam avisando,
		-- porque isso é informação útil para depurar por que algo não
		-- chegou na extensão.
		if message.kind ~= "log" then
			print(("[SyncTeam %s]"):format(os.date("%H:%M:%S")), "descartado (sem conexão):", tostring(message.kind))
		end
		return
	end
	local ok, err = pcall(function()
		client:Send(HttpService:JSONEncode(message))
	end)
	if not ok then
		print(("[SyncTeam %s]"):format(os.date("%H:%M:%S")), "falha ao enviar:", tostring(err))
	end
end

-- --------------------------------------------------------------- handlers

-- Protocolo v2 (docs/MILESTONES.md, M2): writeSource tem dois modos,
-- distinguidos pela presença do campo `uuid` na mensagem recebida.
--
-- M3.2 (docs/MILESTONES.md): modo ATUALIZAÇÃO agora passa por checagem de
-- lease ANTES de qualquer escrita — registra/refresca o próprio intent
-- (TeamCreateLease.ensureIntent) e só prossegue se TeamCreateLease.canWrite
-- permitir (dono == eu, ou nenhuma lease arbitrada ainda: decisão explícita
-- de permitir otimisticamente, ver TeamCreateLease.luau e MILESTONES.md).
-- Modo CRIAÇÃO (sem uuid) NÃO passa por essa checagem nesta fatia (spec
-- M3.2, item 3 — fora de escopo).
local function handleWriteSource(message)
	if message.uuid ~= nil then
		-- Modo ATUALIZAÇÃO: {uuid, source, requestId} — script já conhecido.
		local instance = SourceWatcher.resolveByUuid(message.uuid)
		if instance == nil then
			sendMessage({
				kind = "writeAck",
				requestId = message.requestId,
				ok = false,
				error = "uuid desconhecido ou script inválido: " .. tostring(message.uuid),
			})
			log(("writeSource (update) uuid=%s -> ERRO: desconhecido"):format(tostring(message.uuid)))
			return
		end

		-- Pastas vendorizadas (Packages/ServerPackages/DevPackages, ver
		-- Config.luau/docs/DECISIONS.md 2026-07-16): edição normal (modo
		-- ATUALIZAÇÃO, script já existente) é bloqueada/ignorada — nunca
		-- arbitra lease nem escreve Source para esses scripts, para não
		-- empurrar ao Team Create compartilhado uma versão vendorizada
		-- divergente entre devs. Modo CRIAÇÃO (path abaixo, sem uuid) não é
		-- afetado por esta checagem — é assim que um pacote novo chega ao
		-- Studio pela 1ª vez.
		if Config.isInsideExcludedPackageFolder(instance) then
			local blockedMessage = "edição bloqueada: script dentro de pasta de pacote vendorizado (Packages/ServerPackages/DevPackages) — não sincronizado ao vivo"
			sendMessage({
				kind = "writeAck",
				requestId = message.requestId,
				ok = false,
				uuid = message.uuid,
				error = blockedMessage,
			})
			log(("writeSource (update) uuid=%s -> BLOQUEADO (pasta vendorizada): %s"):format(
				tostring(message.uuid),
				instance:GetFullName()
			))
			return
		end

		TeamCreateLease.ensureIntent(message.uuid, instance)
		local canWrite, ownerClientId = TeamCreateLease.canWrite(message.uuid)
		if not canWrite then
			local ownerDisplay = TeamCreateLease.describeClient(ownerClientId)
			local leaseDeniedMessage = ("lease negada — script sendo editado por %s"):format(ownerDisplay)
			sendMessage({
				kind = "writeAck",
				requestId = message.requestId,
				ok = false,
				uuid = message.uuid,
				error = leaseDeniedMessage,
			})
			-- M4.5: toast-worthy (Logger.notify, não Logger.log) — recusa de
			-- escrita é um evento que o usuário precisa perceber sem precisar
			-- olhar o Output (spec da tarefa: writeAck ok=false/lease negada é
			-- um dos gatilhos sugeridos). Log incondicional continua
			-- acontecendo (Logger.notify sempre loga, ver Logger.luau) — só a
			-- exibição do toast depende da preferência "Mostrar notificações".
			notify(("%s (uuid=%s)"):format(leaseDeniedMessage, tostring(message.uuid)))
			return
		end

		local ok, detail = SourceWatcher.writeSource(instance, message.source or "")
		sendMessage({
			kind = "writeAck",
			requestId = message.requestId,
			ok = ok,
			uuid = if ok then message.uuid else nil,
			api = if ok then detail else nil,
			error = if ok then nil else detail,
		})
		-- 2026-07-20 (BUG 2, ruído de uso contínuo — docs/DECISIONS.md):
		-- rotineiro/alta frequência (dispara a cada escrita vinda do VS Code,
		-- não só no boot) -> Logger.debug. Continua encaminhado por WS
		-- (observabilidade de teste automatizado intacta); só não aparece mais
		-- no Output do Studio a cada edição. Erros de uuid desconhecido/bloqueio
		-- de pasta vendorizada (acima, ainda `log`) continuam visíveis — são
		-- raros/acionáveis, não rotina.
		Logger.debug(("writeSource (update) uuid=%s -> %s"):format(
			tostring(message.uuid),
			if ok then detail else "ERRO: " .. tostring(detail)
		))
		return
	end

	-- Modo CRIAÇÃO: {path, source, className, requestId} — sem uuid, o
	-- plugin resolve/cria a Instance a partir de `game` e aloca um uuid novo.
	local instance, err = SourceWatcher.resolvePath(message.path, message.className or "Script")
	if instance == nil or not instance:IsA("LuaSourceContainer") then
		sendMessage({
			kind = "writeAck",
			requestId = message.requestId,
			ok = false,
			error = err or ("alvo não é um script: " .. tostring(message.path)),
		})
		return
	end
	-- writeSource já chama watchScript() de forma síncrona antes de escrever,
	-- o que já resolve/aloca o uuid no ScriptRegistry — getUuid abaixo lê o
	-- resultado dessa alocação. Se a Instance for genuinamente nova, o
	-- DescendantAdded (deferred) do container correspondente vai emitir
	-- também um scriptAdded espontâneo com o mesmo uuid — a extensão recebe
	-- os dois (writeAck + scriptAdded); é esperado, não é bug (spec M2).
	local ok, detail = SourceWatcher.writeSource(instance, message.source or "")
	local uuid = SourceWatcher.getUuid(instance)
	sendMessage({
		kind = "writeAck",
		requestId = message.requestId,
		ok = ok,
		uuid = if ok then uuid else nil,
		api = if ok then detail else nil,
		error = if ok then nil else detail,
	})
	-- 2026-07-20 (BUG 2, mesmo critério do writeSource (update) acima):
	-- rotineiro/alta frequência -> Logger.debug.
	Logger.debug(("writeSource (create) '%s' -> uuid=%s %s"):format(
		tostring(message.path),
		tostring(uuid),
		if ok then detail else "ERRO: " .. tostring(detail)
	))
end

-- Contrato aditivo (extensão -> plugin, docs/DECISIONS.md): o dev deleta um
-- module localmente no VS Code -> a extensão detecta e manda
-- {kind="deleteScript", requestId, uuid}. Mesmo estilo/estrutura de
-- handleWriteSource modo ATUALIZAÇÃO acima (lógica quase paralela: resolve
-- por uuid, bloqueia pasta vendorizada, checa lease) — reusa o kind
-- "writeAck" na resposta (mesmo formato que writeSource já usa).
--
-- Checagem de lease aplicada aqui pela MESMA razão que updates já a exigem:
-- evita destruir um script que outro dev está com lease ativa de edição no
-- exato momento (consistência e segurança; a alternativa — permitir delete
-- sem lease — abriria uma forma de um dev apagar o trabalho em andamento de
-- outro sem qualquer arbitragem).
--
-- NÃO limpa ScriptRegistry nem emite scriptRemoved aqui: o ciclo de polling
-- que já existe (checkRegistryDrift em SourceWatcher.luau, docs/MILESTONES.md
-- M2) já detecta a Instance destruída (ScriptRegistry.isInstanceDestroyed —
-- Parent == nil + confirmação por pcall, NUNCA ObjectValue.Value == nil, ver
-- .claude/rules/luau.md) dentro de Config.POLL_INTERVAL_SECONDS (0.5s) e
-- emite scriptRemoved espontâneo sozinho, pelo MESMO caminho que já existe
-- para delete feito diretamente no Studio — inclusive o que propaga a
-- remoção para o OUTRO dev (Team Create replica o Destroy(), o Studio dele
-- detecta via o mesmo polling e o plugin dele manda scriptRemoved para a
-- extensão dele).
local function handleDeleteScript(message)
	local instance = SourceWatcher.resolveByUuid(message.uuid)
	if instance == nil then
		sendMessage({
			kind = "writeAck",
			requestId = message.requestId,
			ok = false,
			error = "uuid desconhecido ou script inválido: " .. tostring(message.uuid),
		})
		log(("deleteScript uuid=%s -> ERRO: desconhecido"):format(tostring(message.uuid)))
		return
	end

	-- Pastas vendorizadas (Packages/ServerPackages/DevPackages, ver
	-- Config.luau/docs/DECISIONS.md 2026-07-16): mesma checagem que
	-- handleWriteSource (modo atualização) já faz — delete via live sync
	-- também é bloqueado, para não destruir/perturbar uma árvore vendorizada
	-- que pode divergir entre devs.
	if Config.isInsideExcludedPackageFolder(instance) then
		local blockedMessage = "delete bloqueado: script dentro de pasta de pacote vendorizado (Packages/ServerPackages/DevPackages) — não sincronizado ao vivo"
		sendMessage({
			kind = "writeAck",
			requestId = message.requestId,
			ok = false,
			uuid = message.uuid,
			error = blockedMessage,
		})
		log(("deleteScript uuid=%s -> BLOQUEADO (pasta vendorizada): %s"):format(
			tostring(message.uuid),
			instance:GetFullName()
		))
		return
	end

	TeamCreateLease.ensureIntent(message.uuid, instance)
	local canWrite, ownerClientId = TeamCreateLease.canWrite(message.uuid)
	if not canWrite then
		local ownerDisplay = TeamCreateLease.describeClient(ownerClientId)
		local leaseDeniedMessage = ("lease negada — script sendo editado por %s"):format(ownerDisplay)
		sendMessage({
			kind = "writeAck",
			requestId = message.requestId,
			ok = false,
			uuid = message.uuid,
			error = leaseDeniedMessage,
		})
		-- Mesmo padrão M4.5 de lease negada em handleWriteSource: toast-worthy
		-- (Logger.notify), não só log — o dev precisa perceber sem olhar o
		-- Output.
		notify(("%s (uuid=%s)"):format(leaseDeniedMessage, tostring(message.uuid)))
		return
	end

	-- Toda API de plataforma em pcall (.claude/rules/luau.md).
	local ok, err = pcall(function()
		instance:Destroy()
	end)
	sendMessage({
		kind = "writeAck",
		requestId = message.requestId,
		ok = ok,
		uuid = if ok then message.uuid else nil,
		error = if ok then nil else tostring(err),
	})
	-- Diferente de writeSource update/create (rotineiro/alta frequência,
	-- rebaixado a Logger.debug em 2026-07-20): delete é raro e consequente
	-- (evento destrutivo) — mesmo critério já estabelecido
	-- ("rotineiro/alta frequência = debug; raro/acionável = log") aponta para
	-- manter Logger.log tanto no sucesso quanto no erro.
	log(("deleteScript uuid=%s -> %s"):format(
		tostring(message.uuid),
		if ok then "destruído" else "ERRO: " .. tostring(err)
	))
end

local function handleReadSource(message)
	local instance = SourceWatcher.resolveByUuid(message.uuid)
	if instance == nil then
		sendMessage({
			kind = "sourceContent",
			requestId = message.requestId,
			ok = false,
			error = "uuid desconhecido ou script inválido: " .. tostring(message.uuid),
		})
		return
	end
	sendMessage({
		kind = "sourceContent",
		requestId = message.requestId,
		ok = true,
		source = instance.Source,
	})
end

local function handleListScripts(message)
	sendMessage({
		kind = "scriptList",
		requestId = message.requestId,
		scripts = SourceWatcher.listScripts(),
	})
end

local function handleMessage(raw)
	local ok, message = pcall(function()
		return HttpService:JSONDecode(raw)
	end)
	if not ok or type(message) ~= "table" or type(message.kind) ~= "string" then
		log("mensagem inválida:", tostring(raw))
		return
	end

	if message.kind == "writeSource" then
		handleWriteSource(message)
	elseif message.kind == "deleteScript" then
		-- Mensagem ADITIVA (extensão -> plugin, docs/DECISIONS.md) — mesmo
		-- padrão de "ping": não bumpa Config.PROTOCOL_VERSION.
		handleDeleteScript(message)
	elseif message.kind == "readSource" then
		handleReadSource(message)
	elseif message.kind == "listScripts" then
		handleListScripts(message)
	elseif message.kind == "presenceUpdate" then
		-- M4: espontânea, sem requestId, sem ack (spec docs/MILESTONES.md) —
		-- só grava a própria Presence; TeamCreatePresence.updateOwnPresence já
		-- degrada sem erro se a sessão local ainda não estiver pronta.
		TeamCreatePresence.updateOwnPresence(message)
	elseif message.kind == "ping" then
		-- Heartbeat da extensão (vscode-extension HeartbeatMonitor.ts): a
		-- extensão manda {kind:"ping"} a cada 5s enquanto conectada e responde-se
		-- pong imediatamente. Mensagem ADITIVA — não bumpa PROTOCOL_VERSION. Sem
		-- requestId, sem estado: é só liveness. O plugin NÃO origina ping próprio;
		-- só RECEBER este ping já conta como atividade (o handler de
		-- MessageReceived em runConnection atualiza lastMessageAt para QUALQUER
		-- mensagem, inclusive esta — a ausência dele é o que detecta a queda).
		sendMessage({ kind = "pong" })
	elseif message.kind == "connectionRejected" then
		-- A extensão rejeitou explicitamente esta conexão (2º cliente na mesma
		-- porta) e fechará o WS logo em seguida. Sinal DEFINITIVO de "porta
		-- ocupada por outro Studio" — runConnection lê a flag e trata como
		-- rejeição confirmada na hora (sem depender da heurística de tempo
		-- Config.PROBABLE_REJECTION_WINDOW_SECONDS, que passa a ser só o fallback
		-- para quando este sinal NÃO chega, ex.: extensão antiga sem este fix).
		-- Toast (Logger.notify, não Logger.log) só na 1ª vez por porta ocupada;
		-- rejeições repetidas na mesma porta só logam (ver dedupe no topo do
		-- arquivo). `reason` hoje é sempre "port_in_use" (único definido) — a
		-- flag/aviso assumem esse motivo.
		connectionRejected = true
		if lastRejectedPortToasted ~= activePort then
			lastRejectedPortToasted = activePort
			notify(("porta %d já está em uso por outro Studio"):format(activePort or 0))
		else
			log(("porta %d já está em uso por outro Studio (rejeição repetida; toast já exibido)"):format(activePort or 0))
		end
	else
		log("kind desconhecido/ignorado:", tostring(message.kind))
	end
end

-- ------------------------------------------------------------- conexão ws

local function sendHello()
	local okUserId, userId = pcall(function()
		return StudioService:GetUserId()
	end)
	sendMessage({
		kind = "hello",
		protocolVersion = Config.PROTOCOL_VERSION,
		role = "studio",
		placeName = game.Name,
		userId = if okUserId then userId else nil,
		pluginVersion = Config.PLUGIN_VERSION,
		-- M3.3: clientId da eleição (TeamCreateElection.luau), para a extensão
		-- comparar contra o dono de uma lease. nil se a eleição ainda não
		-- rodou (start() chamado antes de TeamCreateElection.start() concluir
		-- o primeiro tick? não é o caso aqui — TeamCreateElection.start() já
		-- gera o clientId de forma síncrona antes de retornar; nil só seria
		-- possível se sendHello rodasse antes de start(), o que não acontece
		-- neste fluxo) — enviado como nil mesmo, sem erro, nesse caso.
		clientId = TeamCreateElection.getClientId(),
	})
end

-- Uma única conexão (o produto usa 1 conexão; spikes é que usavam até 2 —
-- ver .claude/rules/luau.md). Loop de reconexão guardado pelo token de
-- geração: stop()/start() repetidos não deixam loops antigos sobrepostos
-- (pegadinha real do M0, ver .claude/agent-memory/luau-dev.md).
--
-- Auto-descoberta de porta (2026-07-07, pedido do orquestrador): `ports` é
-- ou uma lista de 1 item (porta já explicitamente setada — manual via botão
-- "Alternar porta" ou persistida por uma descoberta automática anterior) ou
-- `Config.CANDIDATE_PORTS` inteiro (sem nenhuma setting ainda). O harness
-- (SyncServer.ts) rejeita uma 2ª conexão simultânea com
-- `socket.close(1013, "SyncTeam: já existe um plugin conectado")` — mas NÃO
-- há confirmação salva em .claude/research/ sobre o que
-- CreateWebStreamClient expõe desse close code/motivo através dos
-- parâmetros do evento Error, então o critério de "rejeição provável" abaixo
-- deliberadamente NÃO tenta interpretar `code`/`errorMessage` (só loga eles,
-- como antes) — usa só observação local: a conexão caiu SEM NUNCA ter
-- recebido nenhuma mensagem do harness E dentro de uma janela curta
-- (Config.PROBABLE_REJECTION_WINDOW_SECONDS) desde que foi aberta. Uma queda
-- que ficou de pé mais que essa janela, ou que já recebeu qualquer mensagem,
-- é tratada como queda normal (reconecta na MESMA porta, como antes desta
-- mudança).
local function runConnection(myToken, ports, explicitAtStart, pluginObject)
	local index = 1
	local attemptsInLap = 0
	-- Já explícita = nunca persistir (item 4 da tarefa: nunca sobrescrever
	-- uma porta que o usuário já escolheu, seja manual seja de uma sessão
	-- anterior). Só descobertas automáticas desta sessão chegam a persistir.
	local persistedAutoPort = explicitAtStart

	-- Estado visual do botão CONNECT/DISCONNECT (item 1 da tarefa): a cada
	-- volta deste loop o estado vai para "connecting" (laranja) e só passa a
	-- "connected" (vermelho) quando a conexão estabiliza (abaixo). O estado
	-- "disconnected" (azul) é setado SÓ por stop(), nunca aqui — assim um loop
	-- de ConnectFail fica laranja estável em vez de piscar azul/vermelho, que
	-- era o que o usuário via como confuso.
	--
	-- M4.5 (toast de "reconexão falhando"): `hasStabilizedOnce` vira true na
	-- primeira vez que esta runConnection (mesmo myToken, ou seja, mesmo
	-- ciclo start()/stop()) recebe de verdade qualquer mensagem do harness —
	-- só a partir daí uma queda é tratada como "algo que estava funcionando
	-- parou", digno de toast. Sem isso, o cenário normal "extensão VS Code
	-- ainda não foi aberta" (loop de reconexão tentando a cada
	-- RECONNECT_SECONDS sem nunca ter recebido nada) dispararia toast
	-- repetido desde o primeiro segundo — exatamente o "evento rotineiro"
	-- que a spec pede pra NÃO notificar. Isto é MAIS forte que o critério
	-- visual acima (que também aceita "ficou de pé além da janela") de
	-- propósito: um ConnectFail nunca recebe mensagem NEM fica de pé, então
	-- não vira nem laranja-confirmado nem toast — é o cenário "nunca conectou
	-- de verdade", corretamente silencioso. `outageToasted` garante só 1 toast
	-- por "episódio" de queda (reseta pra false assim que uma nova conexão
	-- estabiliza de novo, permitindo um novo toast se cair de novo depois).
	local hasStabilizedOnce = false
	local outageToasted = false

	while enabled and currentToken == myToken do
		local port = ports[index]
		activePort = port
		-- Reset por tentativa: `connectionRejected` é module-level (setado por
		-- handleMessage), então precisa nascer false a cada nova conexão para
		-- não vazar uma rejeição de uma tentativa anterior para a lógica de
		-- decisão abaixo.
		connectionRejected = false
		PluginUI.setPort(port)
		-- Cada volta do loop = uma tentativa de conexão → estado "connecting"
		-- (botão laranja). Dedupe no setter evita reexecutar effects quando já
		-- está "connecting" (o caso comum no loop de reconexão). Só vira
		-- "connected" (vermelho) quando a conexão estabiliza de fato, abaixo.
		PluginUI.setConnectionStatus("connecting")
		local url = ("ws://127.0.0.1:%d"):format(port)
		local ok, newClient = pcall(function()
			return HttpService:CreateWebStreamClient(Enum.WebStreamClientType.WebSocket, { Url = url })
		end)
		if not ok then
			log(("falha ao criar cliente WS (%s); nova tentativa em %ds"):format(
				tostring(newClient),
				Config.RECONNECT_SECONDS
			))
			task.wait(Config.RECONNECT_SECONDS)
			continue
		end

		local closed = false
		local receivedAnyMessage = false
		local connectedAt = os.clock()
		-- Timestamp local da ÚLTIMA mensagem recebida de QUALQUER tipo (estende o
		-- rastreamento que `receivedAnyMessage` já fazia como booleano — agora
		-- também guardamos QUANDO, para detectar silêncio prolongado). Inicia em
		-- connectedAt: se nada chegar desde a abertura, o silêncio conta a partir
		-- daqui. Atualizado no handler de MessageReceived abaixo, para ping
		-- (heartbeat da extensão a cada 5s) e para toda outra mensagem por igual.
		local lastMessageAt = connectedAt
		local connections = {}
		table.insert(connections, newClient.MessageReceived:Connect(function(raw)
			receivedAnyMessage = true
			lastMessageAt = os.clock()
			handleMessage(raw)
		end))
		table.insert(connections, newClient.Closed:Connect(function()
			closed = true
		end))
		table.insert(connections, newClient.Error:Connect(function(code, errorMessage)
			-- 2026-07-16: Logger.debug (ver Logger.luau) — um ConnectFail isolado
			-- é ruído rotineiro do loop de reconexão (a linha visível de verdade
			-- é "desconectado; reconectando em Xs" logo abaixo, categoria
			-- "reconectando"); continua encaminhado por WS para diagnóstico.
			Logger.debug(("erro WS %s %s"):format(tostring(code), tostring(errorMessage)))
			closed = true
		end))

		client = newClient
		sendHello()
		-- NÃO vira "connected" (vermelho) aqui: criar o WebStreamClient e
		-- mandar o hello é otimista (a conexão pode falhar logo em seguida com
		-- ConnectFail). O botão só passa a vermelho quando a conexão
		-- ESTABILIZA de fato (abaixo) — até lá fica laranja ("connecting").
		-- 2026-07-16: rebaixado para Logger.debug — esta tentativa ainda não é
		-- a categoria visível "conectado" (spec da tarefa: só 3 categorias de
		-- status, uma linha por MUDANÇA real); a linha Logger.log de verdade
		-- fica no ponto de estabilização abaixo (`shownConnected`).
		Logger.debug(("conectado em %s"):format(url))

		-- Vira "connected" (vermelho) só na 1ª vez que esta tentativa
		-- estabiliza — não repete o setter a cada 0.5s.
		local shownConnected = false

		while enabled and currentToken == myToken and not closed do
			task.wait(0.5)

			-- Garantia independente de Closed/Error: se ficamos silenciosos por
			-- mais de DEAD_CONNECTION_TIMEOUT_SECONDS (nenhuma mensagem de nenhum
			-- tipo — nem o ping periódico da extensão a cada 5s, nem qualquer
			-- outra), a extensão provavelmente caiu sem fechar o WS (ex.: "Reload
			-- Window" do VS Code) — cenário em que Closed/Error do WebStreamClient
			-- podem NÃO disparar (o bug que esta detecção existe para cobrir).
			-- Só setamos `closed = true`: EXATAMENTE o que os handlers de
			-- Closed/Error já fazem (o restante da iteração corrente termina
			-- inócuo e a condição do `while` encerra o loop na próxima checagem —
			-- mesmíssimo timing de quando um Closed dispara durante o task.wait),
			-- então caímos no MESMO teardown + ciclo de reconexão logo abaixo (que
			-- por sua vez repõe o painel em "connecting" sozinho — não duplicamos
			-- setConnectionStatus aqui).
			if os.clock() - lastMessageAt >= Config.DEAD_CONNECTION_TIMEOUT_SECONDS then
				log(("sem mensagens da extensão há %ds (provável queda sem close do WS); forçando reconexão"):format(
					Config.DEAD_CONNECTION_TIMEOUT_SECONDS
				))
				closed = true
			end

			-- "Estabilizou" (item 4): recebeu qualquer mensagem do harness
			-- depois do hello (a extensão dispara um listScripts inicial em
			-- runInitialSync assim que valida o hello — ver vscode-extension/
			-- src/sync/SyncTeamService.ts), OU já ficou conectada além da
			-- janela curta de rejeição provável sem cair.
			-- `not connectionRejected` suprime "estabilizou": uma conexão
			-- rejeitada RECEBE sim uma mensagem (o próprio connectionRejected),
			-- então sem esta guarda ela contaria como estável e o plugin (a)
			-- piscaria o botão em "connected" e (b) PERSISTIRIA a porta ocupada
			-- como porta descoberta (SetSetting abaixo) — os dois errados. Ver
			-- handleMessage/connectionRejected.
			local stabilized = not connectionRejected
				and (receivedAnyMessage
					or (os.clock() - connectedAt) >= Config.PROBABLE_REJECTION_WINDOW_SECONDS)

			-- Estado visual (item 1 da tarefa): só vira "connected" (vermelho)
			-- ao estabilizar. Um ConnectFail nunca estabiliza (cai em
			-- <PROBABLE_REJECTION_WINDOW_SECONDS sem receber nada), então o
			-- botão fica laranja o loop inteiro em vez de piscar azul/vermelho.
			-- Nota: usa o critério FRACO (recebeu msg OU ficou de pé além da
			-- janela), igual à persistência de porta — mais permissivo que o
			-- critério de toast (hasStabilizedOnce, só recebeu msg). Ver
			-- .claude/agent-memory/ui-dev.md para o porquê da diferença.
			if stabilized and not shownConnected then
				shownConnected = true
				-- Conexão real estabeleceu: zera o dedupe de toast de rejeição,
				-- para que uma futura ocupação DESTA mesma porta (outro Studio a
				-- toma depois) volte a notificar.
				lastRejectedPortToasted = nil
				PluginUI.setConnectionStatus("connected")
				-- 2026-07-16 (consolidação de log de boot, item 3 da tarefa): ÚNICA
				-- linha visível (Logger.log) da categoria "conectado" — substitui a
				-- antiga rajada de ~7 linhas de subsistema (agora Logger.debug, ver
				-- acima e nos módulos SourceWatcher/TeamCreateElection/
				-- TeamCreateLease/TeamCreatePresence). Contagem de scripts vem de
				-- SourceWatcher.getWatchedCount() (novo, mesmo dado que a antiga
				-- linha "observação iniciada" já expunha, só lido sob demanda aqui
				-- em vez de guardado). Não inclui líder/term aqui de propósito: a
				-- eleição é assíncrona e pode não ter convergido ainda no instante
				-- em que a conexão WS estabiliza — "sou o líder agora (term N)"
				-- continua sendo logado separadamente por TeamCreateElection quando
				-- de fato acontecer.
				log(("conectado em %s (%d scripts observados)"):format(url, SourceWatcher.getWatchedCount()))
			end

			-- Persistir assim que estabilizar (não espera a conexão cair) para
			-- reloads futuros já reconectarem direto nesta porta.
			if not persistedAutoPort and stabilized then
				local okSet, errSet = pcall(function()
					pluginObject:SetSetting(Config.PORT_SETTING_KEY, port)
				end)
				if okSet then
					log(("porta %d confirmada e salva"):format(port))
				else
					log(("falha ao salvar porta descoberta automaticamente (%d): %s"):format(port, tostring(errSet)))
				end
				persistedAutoPort = true
			end
			-- M4.5: ver comentário no topo de runConnection — só o recebimento
			-- REAL de uma mensagem do harness conta como "estabilizou" para
			-- fins de toast (mais forte que o critério visual/porta acima, que
			-- também aceita só "ficou de pé um tempo").
			-- `and not connectionRejected`: um connectionRejected É uma mensagem
			-- recebida, mas NÃO é "a conexão funcionou" — não deve armar o toast
			-- genérico de "conexão perdida" (já existe o toast específico de
			-- porta ocupada em handleMessage).
			if not hasStabilizedOnce and receivedAnyMessage and not connectionRejected then
				hasStabilizedOnce = true
				outageToasted = false
			end
		end

		local aliveSeconds = os.clock() - connectedAt
		client = nil
		for _, connection in connections do
			connection:Disconnect()
		end
		pcall(function()
			newClient:Close()
		end)

		if not (enabled and currentToken == myToken) then
			-- stop() já colocou o estado em "disconnected" (botão azul) — não
			-- sobrescreve com "connecting" aqui.
			return
		end

		-- Ainda habilitado: vamos tentar de novo → volta a "connecting"
		-- (laranja). Cobre a espera até a próxima tentativa (RECONNECT_SECONDS
		-- ou CANDIDATE_RETRY_DELAY_SECONDS) sem deixar o botão preso em
		-- "connected" (vermelho) depois de uma queda.
		PluginUI.setConnectionStatus("connecting")

		-- Rejeição CONFIRMADA pelo sinal explícito (connectionRejected) OU
		-- inferida pela heurística de tempo (fallback quando o sinal não chega:
		-- extensão antiga — "caiu cedo sem nunca receber mensagem"). O sinal
		-- explícito dispensa tanto a janela de tempo quanto o "não recebeu
		-- mensagem" (o próprio connectionRejected É uma mensagem). Só cicla
		-- candidatas se houver >1 porta; porta explícita (#ports==1) sempre
		-- reconecta na mesma — o toast de handleMessage já avisou o motivo e o
		-- usuário decide trocar de porta no painel (item 2 da tarefa).
		local rejected = connectionRejected
			or ((not receivedAnyMessage) and aliveSeconds < Config.PROBABLE_REJECTION_WINDOW_SECONDS)
		local probablyRejected = rejected and #ports > 1

		-- M4.5: toast só quando uma conexão que JÁ FUNCIONOU cai de um jeito
		-- que não é a rotina de "ciclar candidatas de porta" — evita o ruído
		-- de notificar o cenário normal "extensão ainda não foi aberta" (ver
		-- comentário no topo da função).
		if not probablyRejected and hasStabilizedOnce and not outageToasted then
			outageToasted = true
			notify("conexão com a extensão VS Code perdida; tentando reconectar...")
		end

		if probablyRejected then
			attemptsInLap += 1
			local nextIndex = (index % #ports) + 1
			if attemptsInLap >= #ports then
				-- Esgotou todas as candidatas nesta volta sem sucesso: volta
				-- pro início da lista, mas com o RECONNECT_SECONDS normal (evita
				-- busy-loop se nenhum harness estiver de pé em porta nenhuma).
				log(("porta %d parece ocupada; todas as %d candidatas falharam, aguardando %ds antes de recomeçar"):format(
					port,
					#ports,
					Config.RECONNECT_SECONDS
				))
				attemptsInLap = 0
				index = nextIndex
				task.wait(Config.RECONNECT_SECONDS)
			else
				log(("porta %d parece ocupada, tentando %d..."):format(port, ports[nextIndex]))
				index = nextIndex
				task.wait(Config.CANDIDATE_RETRY_DELAY_SECONDS)
			end
		else
			attemptsInLap = 0
			log(("desconectado; reconectando em %ds"):format(Config.RECONNECT_SECONDS))
			task.wait(Config.RECONNECT_SECONDS)
		end
	end
end

-- ------------------------------------------------------------ start/stop

local function stop()
	if not enabled then
		return
	end
	enabled = false
	currentToken += 1
	SourceWatcher.stop()
	-- TeamCreateLease.stop()/TeamCreatePresence.stop() antes de
	-- TeamCreateElection.stop(): ambos só limpam estado em memória (a própria
	-- Presence e as pastas de intent morrem em cascata quando
	-- TeamCreateElection.stop() destrói a própria sessão a seguir) — ordem
	-- não é estritamente necessária, mas segue a mesma disciplina "parar o
	-- que depende antes do que é dependido" já usada neste arquivo.
	TeamCreateLease.stop()
	TeamCreatePresence.stop()
	-- TeamCreateElection.stop() remove a própria entrada de Sessions/ de forma
	-- SÍNCRONA (M3.1) — mesmo cuidado do fix de WebStreamClient abaixo:
	-- plugin.Unloading pode não dar chance de uma coroutine assíncrona notar
	-- isso depois.
	TeamCreateElection.stop()
	-- Fecha o WebStreamClient de forma SÍNCRONA aqui, em vez de confiar no
	-- cleanup do loop runConnection (task.spawn): plugin.Unloading provavelmente
	-- mata a coroutine antes dela acordar do task.wait e rodar seu próprio
	-- newClient:Close(). Bug real confirmado em teste ao vivo, 2026-07-04
	-- (docs/DECISIONS.md): reloads repetidos do plugin vazavam um
	-- WebStreamClient cada, até atingir o limite de 6 por Studio
	-- (.claude/rules/luau.md) e travar toda nova conexão.
	if client ~= nil then
		pcall(function()
			client:Close()
		end)
	end
	client = nil
	-- Zera o dedupe de toast de rejeição de porta: um novo start() deve poder
	-- notificar de novo se reencontrar uma porta ocupada.
	lastRejectedPortToasted = nil
	-- Estado visual: "disconnected" (botão azul, ação = conectar) — o loop de
	-- runConnection já não vai sobrescrever porque enabled == false (ele volta
	-- cedo ao notar isso). runConnection NUNCA seta "disconnected" sozinho:
	-- esse estado parado é responsabilidade exclusiva do stop().
	PluginUI.setConnectionStatus("disconnected")
	log("parado.")
end

local function start(pluginObject)
	if enabled then
		log("já está rodando.")
		return
	end
	-- Defesa em profundidade (2026-07-20, BUG 1 — docs/DECISIONS.md): start()
	-- recusa a si mesmo em Run/Play, no MESMO padrão de guarda de idempotência
	-- já usado acima (`if enabled then ... return end`). Cobre qualquer
	-- chamador futuro que esqueça de checar antes. Os call-sites que já sabem
	-- de antemão que isRunOrPlayMode() é verdadeiro CONTINUAM checando por
	-- conta própria antes de chamar start() (ver onConnect abaixo) — só eles
	-- sabem o CONTEXTO da chamada (ação explícita do usuário) para decidir se
	-- vale um toast (Logger.notify); aqui dentro só loga (Logger.log), sem
	-- toast, porque start() não sabe se foi autostart, onConnect ou o guard de
	-- transição (que na prática nunca cai aqui: só chama start() de volta
	-- quando JÁ detectou o retorno à edição).
	if isInRunOrPlayMode() then
		log("start() recusado: Studio em modo Run/Play (F8/F5); conecte após voltar para edição normal.")
		return
	end
	enabled = true
	currentToken += 1
	local myToken = currentToken
	-- Estado visual imediato: o clique em CONNECT (ou o auto-start) já coloca o
	-- botão em "connecting" (laranja) antes mesmo da 1ª tentativa de WS em
	-- runConnection, sem esperar o loop começar.
	PluginUI.setConnectionStatus("connecting")
	local ports, explicitPort = Config.resolveCandidatePorts(pluginObject)
	local okUserId, resolvedUserId = pcall(function()
		return StudioService:GetUserId()
	end)
	-- Logger.init ANTES de SourceWatcher.start()/TeamCreateElection.start()/
	-- TeamCreateLease.start(): esses três já podem logar (via `log`/Logger.log)
	-- durante a própria inicialização (ex.: "observação iniciada", "sessão
	-- criada"), então o encaminhamento por WS precisa estar disponível o quanto
	-- antes — mesmo cuidado de ordem já seguido para SourceWatcher.init/
	-- TeamCreateLease.init abaixo.
	Logger.init(sendMessage)
	-- M4.5: injeta o callback de toast do painel — Logger.notify(...) (usado
	-- pelos poucos pontos "toast-worthy" deste arquivo e de
	-- TeamCreateSchema.luau) passa a acionar PluginUI.notify a partir de
	-- agora. Antes deste ponto (e se PluginUI.init tiver falhado, ver
	-- PluginUI.luau), Logger.notify se comporta como Logger.log.
	Logger.initNotify(PluginUI.notify)
	SourceWatcher.init(sendMessage)
	SourceWatcher.start()
	TeamCreateElection.start(if okUserId then resolvedUserId else 0)
	-- TeamCreateLease depois de TeamCreateElection: ensureIntent (chamado só
	-- durante handleWriteSource, não aqui) depende de
	-- TeamCreateElection.getSessionFolder() já existir. init() (M3.3) injeta o
	-- mesmo callback sendMessage que SourceWatcher já usa, para o ciclo de
	-- checkLeaseDrift poder emitir `leaseChanged` espontâneo.
	TeamCreateLease.init(sendMessage)
	TeamCreateLease.start()
	-- TeamCreatePresence depois de TeamCreateElection, mesmo motivo de
	-- TeamCreateLease acima: updateOwnPresence/checkPresenceDrift dependem de
	-- TeamCreateElection.getSessionFolder()/getClientId() já existirem.
	TeamCreatePresence.init(sendMessage)
	TeamCreatePresence.start()
	task.spawn(runConnection, myToken, ports, explicitPort, pluginObject)
	-- 2026-07-16: Logger.debug (ruído rotineiro de boot, ver Logger.luau) —
	-- continua encaminhado por WS, só não polui o Output a cada conexão. O
	-- status visível de verdade ("conectado"/"reconectando"/"falha") é o
	-- consolidado dentro de runConnection (ver comentários lá).
	if explicitPort then
		Logger.debug(("iniciado. Conectando à porta %d..."):format(ports[1]))
	else
		Logger.debug(("iniciado. Sem porta salva ainda; testando candidatas (%s)..."):format(table.concat(ports, ", ")))
	end
end

-- --------------------------------------------------- guarda de Run/Play (F8/F5)
--
-- Checa a transição de RunService:IsRunning() a cada Config.POLL_INTERVAL_SECONDS
-- (ver comentário de wasInRunOrPlayMode acima). Loop próprio, roda pela vida
-- inteira do plugin (desconectado por plugin.Unloading abaixo, junto dos
-- outros).
local runModeMonitorEnabled = true

local function checkRunModeTransition()
	local nowInRunOrPlayMode = isInRunOrPlayMode()

	if nowInRunOrPlayMode and not wasInRunOrPlayMode then
		-- Transição edição -> Run/Play: suspende o sync se estava rodando.
		wasInRunOrPlayMode = true
		if enabled then
			runGuardStoppedSync = true
			log("F8/F5 (Run/Play) detectado; sync suspenso durante o teste.")
			stop()
		end
	elseif not nowInRunOrPlayMode and wasInRunOrPlayMode then
		-- Transição Run/Play -> edição (ressalva: também dispara em falso se o
		-- teste só foi PAUSADO, ver comentário de wasInRunOrPlayMode acima —
		-- limitação conhecida, não resolvida).
		wasInRunOrPlayMode = false
		if runGuardStoppedSync then
			runGuardStoppedSync = false
			log("retorno ao modo de edição detectado; retomando sync.")
			task.spawn(start, plugin)
		end
	end
end

task.spawn(function()
	while runModeMonitorEnabled do
		task.wait(Config.POLL_INTERVAL_SECONDS)
		if not runModeMonitorEnabled then
			break
		end
		checkRunModeTransition()
	end
end)

-- ------------------------------------------------------------------- UI (M4.5)
--
-- Substitui a antiga toolbar de 3 botões (Conectar/Parar/Alternar porta) por
-- 1 botão só que alterna o painel (PluginUI.luau cria toolbar+
-- DockWidgetPluginGui+monta a árvore Vide) — este arquivo continua sendo o
-- ÚNICO dono de start()/stop()/troca de porta; PluginUI só invoca os
-- callbacks abaixo e reflete estado via setConnectionStatus/setPort (chamados
-- dentro de runConnection/start/stop, ver acima).
--
-- onPortChange reusa EXATAMENTE a mesma sequência que o antigo botão
-- "Alternar porta" fazia (SetSetting + stop() + start(plugin)) — só
-- generalizada para um valor arbitrário digitado no painel em vez de
-- alternar entre 2 constantes fixas (34980/34981, que eram só uma
-- ferramenta de teste para 2 Studios na mesma máquina — o campo de porta do
-- painel substitui essa necessidade sem precisar de nenhum botão dedicado).
PluginUI.init(plugin, {
	onConnect = function()
		-- Guard de Run/Play no botão CONNECT (2026-07-20, BUG 1 — antes desta
		-- correção este era o ÚNICO ponto de entrada de start() sem NENHUM
		-- guard, documentado como "fora de escopo" na tarefa de 2026-07-16 que
		-- criou o guard de transição). Agora que autostart é opt-in (default
		-- OFF, ver Config.resolveAutoStartEnabled), CONNECT manual é o fluxo
		-- normal — clicar nele já em Run/Play (ex.: plugin recarregado durante
		-- um teste em andamento) faria start() rodar livre, porque o guard de
		-- TRANSIÇÃO (checkRunModeTransition) nunca veria a transição
		-- edição->Run/Play (o sync já nasceria dentro do Run/Play) e por isso
		-- nunca chamaria stop() de volta. Checagem feita AQUI, além da mesma
		-- checagem dentro de start() (defesa em profundidade, ver comentário
		-- lá): só este call-site sabe que é uma ação EXPLÍCITA do usuário —
		-- merece feedback visível (toast via Logger.notify), mesmo padrão dos
		-- outros pontos M4.5 que notificam recusas (ex.: lease negada).
		if isInRunOrPlayMode() then
			notify("CONNECT ignorado: Studio em modo Run/Play (F8/F5); conecte após voltar para edição normal.")
			return
		end
		task.spawn(start, plugin)
	end,
	onDisconnect = stop,
	onPortChange = function(newPort)
		-- Guarda de reentrância/dedupe (ver comentário no topo do arquivo):
		-- ignora uma 2ª chamada de FocusLost residual que dispararia um
		-- stop()+start() concorrente, matando a conexão recém-criada.
		if portChangeInFlight then
			log(("troca de porta para %d ignorada: outra troca ainda em andamento"):format(newPort))
			return
		end
		if lastPortChangeValue == newPort and (os.clock() - lastPortChangeAt) < PORT_CHANGE_DEDUPE_SECONDS then
			log(("troca de porta para %d ignorada: repetição do mesmo valor em <%ds"):format(
				newPort,
				PORT_CHANGE_DEDUPE_SECONDS
			))
			return
		end
		portChangeInFlight = true
		lastPortChangeValue = newPort
		lastPortChangeAt = os.clock()
		task.spawn(function()
			local currentPort = Config.resolvePort(plugin)
			local okSet, errSet = pcall(function()
				plugin:SetSetting(Config.PORT_SETTING_KEY, newPort)
			end)
			if not okSet then
				log("falha ao mudar porta pelo painel:", tostring(errSet))
				-- Libera a guarda ANTES de sair: sem isso, uma falha de SetSetting
				-- deixaria portChangeInFlight travado em true para sempre,
				-- bloqueando toda troca de porta futura (bug pior que o que estamos
				-- corrigindo).
				portChangeInFlight = false
				return
			end
			log(("porta alterada pelo painel %d -> %d; reconectando..."):format(currentPort, newPort))
			-- stop()+start() em pcall só para GARANTIR que a guarda sempre baixa
			-- (um erro aqui deixaria portChangeInFlight travado, ver acima) — o
			-- erro, se houver, continua sendo logado, não engolido silenciosamente.
			local okCycle, errCycle = pcall(function()
				stop()
				start(plugin)
			end)
			-- Reinicia a janela de dedupe a partir do FIM do stop()+start() (que
			-- pode ter yieldado): é a partir daqui que o PortRow fica vulnerável de
			-- novo, até runConnection atualizar state.port(). Só então libera a
			-- flag de reentrância.
			lastPortChangeAt = os.clock()
			portChangeInFlight = false
			if not okCycle then
				log("erro ao reconectar após troca de porta:", tostring(errCycle))
			end
		end)
	end,
	-- 2026-07-20 (pedido do usuário): toggle real de "Reconectar
	-- automaticamente ao abrir a place" na tela de configurações do painel
	-- (ui/StatusPanel.luau) — REUSA Config.AUTOSTART_SETTING_KEY, que já
	-- existia desde 2026-07-16 (ver comentário de start()/auto-start no fim
	-- do arquivo) só sem UI dedicada; nenhuma setting nova. Diferente de
	-- onNotificationsToggle (preferência passiva, só persiste), este AGE na
	-- hora ao ligar — decisão de UX explícita do usuário: ligar o toggle
	-- enquanto desconectado deveria conectar já, não só valer "da próxima
	-- vez".
	onAutoReconnectToggle = function(newValue)
		local okSet, errSet = pcall(function()
			plugin:SetSetting(Config.AUTOSTART_SETTING_KEY, newValue)
		end)
		if not okSet then
			log("falha ao salvar preferência de auto-reconectar:", tostring(errSet))
			return
		end
		if not newValue then
			-- Desligar só afeta o PRÓXIMO carregamento do plugin/place
			-- (bloco de auto-start no fim deste arquivo) — NÃO derruba uma
			-- sessão já conectada agora: o usuário pediu pra parar de
			-- conectar sozinho no futuro, não pra desconectar o presente
			-- (isso é o que DISCONNECT/onDisconnect já faz, se for o que
			-- ele quiser).
			log("auto-reconectar desligado; só afeta o próximo carregamento do plugin/place.")
			return
		end
		-- Ligar: tenta conectar JÁ (mesma chamada que onConnect faz),
		-- respeitando o MESMO guard de Run/Play — nunca conecta livre por
		-- trás de um F8/F5 em andamento, mesmo padrão de feedback (toast)
		-- que onConnect já dá quando recusado por esse motivo. Se já
		-- conectado (enabled == true), start() se recusa sozinho
		-- (idempotência, ver guard no topo de start()) — nada extra a
		-- checar aqui além do SetSetting acima.
		if isInRunOrPlayMode() then
			notify(
				"Auto-reconectar ativado, mas o Studio está em modo Run/Play (F8/F5);"
					.. " conecte manualmente após voltar para edição normal."
			)
			return
		end
		task.spawn(start, plugin)
	end,
})
PluginUI.setPort(Config.resolvePort(plugin))

plugin.Unloading:Connect(stop)
-- PluginUI.stop() é um ciclo de vida SEPARADO do stop() de conexão acima
-- (ver PluginUI.luau): só desliga o refresh em segundo plano da tabela de
-- sessões; o painel em si (toolbar+widget) não precisa ser destruído, o
-- Studio cuida disso ao descarregar o plugin.
plugin.Unloading:Connect(PluginUI.stop)
-- Encerra o loop do guard de Run/Play (acima) junto com o resto do ciclo de
-- vida do plugin.
plugin.Unloading:Connect(function()
	runModeMonitorEnabled = false
end)

log("plugin carregado. Toolbar 'SyncTeam' alterna o painel de status; use o botão CONNECT para conectar.")

-- ------------------------------------------------------------ auto-start
--
-- 2026-07-16 (pedido do usuário): autostart passou a ser OPT-IN, default
-- DESLIGADO (Config.AUTOSTART_SETTING_KEY/resolveAutoStartEnabled, default
-- false — oposto do padrão de NOTIFICATIONS_SETTING_KEY). Antes desta
-- mudança, `start(plugin)` era chamado incondicionalmente aqui (só sujeito ao
-- guard de Run/Play abaixo) — o dev não tinha como optar por conectar
-- manualmente. Agora o dev decide quando conectar clicando em CONNECT no
-- painel (onConnect acima já chama `task.spawn(start, plugin)`, mesmo
-- caminho); só quem ligar Config.AUTOSTART_SETTING_KEY volta a ter o
-- comportamento antigo — 2026-07-20: agora um toggle real ("Reconectar
-- automaticamente ao abrir a place", tela de configurações do painel, ver
-- onAutoReconnectToggle em PluginUI.init acima e ui/StatusPanel.luau); antes
-- disso só dava pra ligar via plugin:SetSetting(...) no Command Bar.
--
-- Mesmo padrão de carregamento validado no M0.5
-- (.claude/agent-memory/luau-dev.md): o Studio auto-executa o Script raiz do
-- plugin ao (re)carregar — seja como arquivo .lua solto na pasta de Plugins,
-- seja como .rbxm buildado via `rojo build`. start() tem guard de
-- idempotência (`if enabled then return end`) para tolerar reload/
-- reinstalação duplicada, o que segue relevante mesmo com autostart opt-in
-- (ex.: reload com a setting ligada).
--
-- Guarda de Run/Play (ver isInRunOrPlayMode() acima). Atualizado 2026-07-20
-- (BUG 1, docs/DECISIONS.md): antes desta correção só o autostart e o guard
-- de TRANSIÇÃO (checkRunModeTransition) tinham essa checagem — o botão
-- CONNECT (onConnect, PluginUI.init acima) ficava de fora, documentado como
-- "fora de escopo" na tarefa original de 2026-07-16. Isso deixou de ser
-- aceitável quando autostart virou opt-in/default OFF (mesma sessão de
-- 2026-07-16): CONNECT manual passou a ser o fluxo normal, não mais um atalho
-- raro, então precisava do mesmo guard. Agora os TRÊS pontos de entrada
-- (autostart aqui, onConnect, e start() como defesa em profundidade) usam a
-- MESMA função isInRunOrPlayMode().
if not Config.resolveAutoStartEnabled(plugin) then
	log("autostart desligado; use o painel (toggle na toolbar) pra conectar manualmente.")
elseif isInRunOrPlayMode() then
	log("Studio em modo Run/Play (RunService:IsRunning()==true) no carregamento; sync não iniciado automaticamente.")
else
	task.spawn(start, plugin)
end
]]></string>
    </Properties>
    <Item class="ModuleScript" referent="1">
      <Properties>
        <string name="Name">Config</string>
        <string name="Source"><![CDATA[-- SyncTeam — Config do plugin de produção (M1)
--
-- Constantes centralizadas: porta WS, timings de polling/reconexão, versão
-- de protocolo, versão do plugin, e a lista fixa de containers observados.
--
-- Fora de escopo aqui: constantes de coordenação do TestService.SyncTeam
-- (pulso 2s / stale 8s / cleanup 20s) — isso é M3, ver .claude/rules/luau.md
-- e docs/MILESTONES.md.

local Config = {}

-- Porta padrão do servidor WebSocket local hospedado pela extensão VS Code.
-- Escolhida nova (não reutiliza 34901/34902, usadas pelos spikes M0/M0.5) só
-- para não colidir se algum spike antigo ainda estiver instalado/rodando ao
-- mesmo tempo que o plugin de produto.
Config.DEFAULT_PORT = 1400

-- Chave de plugin:GetSetting/SetSetting para permitir porta configurável sem
-- reescrever código (regra de "porta configurável com default fixo" de
-- .claude/rules/typescript.md, que vale também do lado do plugin). Ainda sem
-- UI para setar isso — usuário avançado pode chamar
-- plugin:SetSetting("SyncTeam_WsPort", <porta>) pelo Command Bar do Studio.
Config.PORT_SETTING_KEY = "SyncTeam_WsPort"

-- Chave de plugin:GetSetting/SetSetting para a única opção real das
-- configurações do painel de status (M4.5, plugin/src/ui/): "Mostrar
-- notificações" — controla só se o TOAST aparece (Toast.luau); o log no
-- Output nunca é condicionado a isso (Logger.notify sempre loga, ver
-- Logger.luau). Default true (ligado) quando a setting nunca foi tocada.
Config.NOTIFICATIONS_SETTING_KEY = "SyncTeam_ShowNotifications"

-- Chave de plugin:GetSetting/SetSetting para autostart (2026-07-16, pedido do
-- usuário após teste real). Ao contrário de NOTIFICATIONS_SETTING_KEY
-- (default true/ligado), o default AQUI é false/DESLIGADO — decisão
-- deliberada: o comportamento anterior (auto-start incondicional ao carregar
-- o plugin, ver init.server.luau) conectava sem o dev pedir; a partir de
-- agora o dev decide quando conectar clicando em CONNECT no painel, e só quem
-- ligar esta setting (2026-07-20: toggle real "Reconectar automaticamente ao
-- abrir a place" na tela de configurações do painel, ver
-- plugin/src/ui/StatusPanel.luau — antes disso só via
-- plugin:SetSetting(...) no Command Bar) volta a ter auto-start.
Config.AUTOSTART_SETTING_KEY = "SyncTeam_AutoStart"

-- Lista de portas candidatas usada SÓ quando não há nenhuma porta
-- explicitamente persistida em plugin:GetSetting(PORT_SETTING_KEY) (nem por
-- SetSetting manual, nem por uma descoberta automática de sessão anterior —
-- ver Config.resolveCandidatePorts). ESTOPGAP para o cenário de teste de 2
-- Studios na mesma máquina compartilhando a MESMA pasta de Plugins (2 contas
-- via "Add Account" carregam o mesmo arquivo de plugin, então cada Studio
-- precisa descobrir sozinho qual harness/porta ainda está livre — ver
-- docs/PROJECT_STATUS.md). Em uso normal de produção (1 dev, 1 extensão) só
-- a primeira porta desta lista chega a importar; a segunda nunca é
-- alcançada porque a primeira tentativa já conecta.
Config.CANDIDATE_PORTS = { 1400, 1401 }

-- Janela curta (segundos) usada só para o heurístico de "rejeição
-- provável" da auto-descoberta de porta (init.server.luau, runConnection):
-- se a conexão cair SEM nunca ter recebido nenhuma mensagem do harness
-- dentro desta janela, é tratada como "porta provavelmente ocupada por
-- outro Studio" e o plugin avança para a próxima candidata em vez de
-- esperar RECONNECT_SECONDS. Deliberadamente NÃO depende de interpretar o
-- `code`/`errorMessage` do evento Error do WebStreamClient (não há
-- confirmação salva em .claude/research/ sobre o que CreateWebStreamClient
-- expõe para o close code 1013 do harness — ver SyncServer.ts) — só de
-- observação local (tempo decorrido + mensagens recebidas), que não exige
-- pesquisa de API nova.
Config.PROBABLE_REJECTION_WINDOW_SECONDS = 3

-- Atraso entre tentar uma candidata rejeitada e a próxima da lista —
-- deliberadamente bem menor que RECONNECT_SECONDS (não faz sentido esperar
-- muito antes de tentar a alternativa se a porta atual está ocupada por
-- OUTRO Studio), mas não é zero para não virar busy-loop se todas as
-- portas candidatas estiverem ocupadas ao mesmo tempo.
Config.CANDIDATE_RETRY_DELAY_SECONDS = 0.75

-- Caminho garantido de detecção de mudança de Source (ver DECISIONS.md
-- 2026-07-03): sinal é só fast-path, nunca a única via.
Config.POLL_INTERVAL_SECONDS = 0.5

Config.RECONNECT_SECONDS = 3

-- Detecção de conexão morta por AUSÊNCIA de mensagens (init.server.luau,
-- runConnection). Garantia independente dos eventos Closed/Error do
-- WebStreamClient, que podem NÃO disparar quando o servidor WS da extensão
-- morre sem enviar frame de close (ex.: "Reload Window" do VS Code mata o
-- processo da extensão). A extensão manda `{kind:"ping"}` a cada 5s enquanto
-- conectada (vscode-extension HeartbeatMonitor.ts) e ela mesma derruba a
-- conexão se ficar 15s sem receber NENHUMA mensagem do plugin. Do lado do
-- plugin: se passar este intervalo sem receber NENHUMA mensagem (nem o ping
-- periódico, nem qualquer outra), a conexão é tratada como morta e forçamos
-- reconexão. Escolhido 20s (4 intervalos de ping) em vez de 15s: dá 1 ping de
-- folga sobre o timeout da extensão, evitando um teardown falso por um único
-- ping atrasado/perdido, ao custo de no máximo ~5s a mais exibindo "conectado"
-- após uma queda real — aceitável (o bug original era ficar "conectado" por
-- MUITO mais que isso). Só o plugin RESPONDE ao ping (pong); nunca origina
-- ping próprio — a ausência do ping da extensão é o único sinal usado aqui.
Config.DEAD_CONNECTION_TIMEOUT_SECONDS = 20

-- Handshake versionado (M1: começou em 1). Bump para 2 no M2 (breaking change
-- deliberado, docs/MILESTONES.md): readSource/writeSource passam a endereçar
-- por UUID (ScriptRegistry) em vez de path; writeSource sem `uuid` continua
-- significando criação (agora aloca um uuid novo); nova mensagem espontânea
-- scriptMoved. Extensão decide o que fazer em mismatch de versão.
Config.PROTOCOL_VERSION = 2
Config.PLUGIN_VERSION = "0.2.0"

-- Nomes de pasta que marcam árvore de dependências vendorizadas por Wally
-- (https://wally.sh) — convenção padrão: `Packages/` é a mais comum, mas
-- projetos com dependências separadas por lado (server/client/dev) também
-- usam `ServerPackages`/`DevPackages`. Risco de arquitetura (2026-07-16,
-- aprovado pelo usuário, ver docs/DECISIONS.md): dois devs podem ter
-- `wally.lock`/pastas `Packages/` locais divergentes (versão desatualizada
-- de um lado); se o SyncTeam tratasse esses ModuleScripts como qualquer
-- outro, o Source do pacote vendorizado desatualizado de um dev poderia ser
-- empurrado ao Team Create compartilhado, alterando silenciosamente a
-- dependência de TODOS os devs. Usado por Config.isInsideExcludedPackageFolder
-- para excluir esses scripts do LIVE EDIT SYNC (watch de mudança de Source +
-- arbitragem de lease) nos dois sentidos — mas NÃO do discovery/identidade
-- (ScriptRegistry/listScripts continuam normais, para o "Refresh Sync" da
-- extensão poder detectar "esse pacote já existe, não duplicar"; criação de
-- instância nova continua funcionando igual, só depois de criada é que ela
-- entra em "modo vendorizado").
Config.SYNC_EXCLUDED_FOLDER_NAMES = {
	Packages = true,
	ServerPackages = true,
	DevPackages = true,
}

-- true se `instance` estiver, em qualquer profundidade, dentro de uma pasta
-- cujo Name é exatamente um dos SYNC_EXCLUDED_FOLDER_NAMES (sobe
-- instance.Parent até a raiz observada/game). Usado para pular a instância
-- APENAS do polling de mudança de Source e da arbitragem de lease — nunca do
-- registro de identidade/listScripts/criação (ver comentário acima e
-- docs/DECISIONS.md 2026-07-16).
function Config.isInsideExcludedPackageFolder(instance)
	local current = instance and instance.Parent
	while current ~= nil do
		if Config.SYNC_EXCLUDED_FOLDER_NAMES[current.Name] then
			return true
		end
		current = current.Parent
	end
	return false
end

-- Containers observados recursivamente por Script/LocalScript/ModuleScript.
-- Decisão M1 (docs/MILESTONES.md): plugin "burro"/genérico, lista fixa; a
-- extensão é quem mapeia contra o default.project.json do projeto do
-- usuário e ignora caminhos fora de qualquer ponto de montagem.
function Config.getWatchedRoots()
	local StarterPlayer = game:GetService("StarterPlayer")
	return {
		game:GetService("ServerScriptService"),
		StarterPlayer.StarterPlayerScripts,
		game:GetService("ReplicatedStorage"),
		game:GetService("ServerStorage"),
		game:GetService("StarterGui"),
		game:GetService("Workspace"),
	}
end

-- Porta efetiva: setting do plugin se presente e válida, senão o default.
function Config.resolvePort(pluginObject)
	local ok, value = pcall(function()
		return pluginObject:GetSetting(Config.PORT_SETTING_KEY)
	end)
	if ok and type(value) == "number" and value > 0 then
		return math.floor(value)
	end
	return Config.DEFAULT_PORT
end

-- Lista de portas a tentar + se ela veio de uma porta JÁ EXPLICITAMENTE
-- setada (manual via botão "Alternar porta", ou persistida por uma
-- descoberta automática de sessão anterior via runConnection). Quando
-- explícita, a lista tem 1 item só e é a ÚNICA tentada (nunca cicla) —
-- CANDIDATE_PORTS só entra em jogo quando NÃO há nenhuma setting ainda.
function Config.resolveCandidatePorts(pluginObject)
	local ok, value = pcall(function()
		return pluginObject:GetSetting(Config.PORT_SETTING_KEY)
	end)
	if ok and type(value) == "number" and value > 0 then
		return { math.floor(value) }, true
	end
	return Config.CANDIDATE_PORTS, false
end

-- Preferência efetiva de "Mostrar notificações" (M4.5): setting do plugin se
-- presente e booleana, senão default true. Só GetSetting pode devolver nil
-- (nunca setado) ou um valor de tipo errado (schema corrompido/versão
-- antiga) — os dois caem no default, nunca erram.
function Config.resolveNotificationsEnabled(pluginObject)
	local ok, value = pcall(function()
		return pluginObject:GetSetting(Config.NOTIFICATIONS_SETTING_KEY)
	end)
	if ok and type(value) == "boolean" then
		return value
	end
	return true
end

-- Preferência efetiva de autostart (2026-07-16): setting do plugin se
-- presente e booleana, senão default FALSE (oposto de
-- resolveNotificationsEnabled — ver comentário de AUTOSTART_SETTING_KEY
-- acima). GetSetting pode devolver nil (nunca setado, o caso normal para
-- quem nunca abriu o toggle de "Reconectar automaticamente ao abrir a
-- place" nas configurações do painel — que também nasce desligado) ou um
-- valor de tipo errado — ambos caem no default desligado, nunca erram para
-- o lado de conectar sozinho sem o dev pedir.
function Config.resolveAutoStartEnabled(pluginObject)
	local ok, value = pcall(function()
		return pluginObject:GetSetting(Config.AUTOSTART_SETTING_KEY)
	end)
	if ok and type(value) == "boolean" then
		return value
	end
	return false
end

return Config
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="2">
      <Properties>
        <string name="Name">Logger</string>
        <string name="Source"><![CDATA[-- SyncTeam — Logger centralizado (observabilidade de teste automatizado)
--
-- Motivação (pedido do orquestrador, 2026-07-07): antes desta tarefa, 6
-- módulos do plugin (init.server.luau, TeamCreateElection.luau,
-- TeamCreateSchema.luau, TeamCreateLease.luau, ScriptRegistry.luau,
-- SourceWatcher.luau) tinham cada um sua PRÓPRIA função local `log(...)`,
-- todas idênticas:
--   local function log(...)
--       print(("[SyncTeam %s]"):format(os.date("%H:%M:%S")), ...)
--   end
-- Isso obrigava o orquestrador/IA a depender do usuário colar manualmente o
-- painel Output do Studio para saber o que acontece durante um teste — um
-- gargalo para testes autônomos. Este módulo centraliza log() e, ADICIONAL ao
-- print() de sempre (comportamento inalterado, continua aparecendo no Output
-- do Studio normalmente, com a MESMA chamada `print(prefix, ...)` de antes),
-- encaminha o texto renderizado pela conexão WS já existente (mesmo
-- `sendMessage` injetado por SourceWatcher.init/TeamCreateLease.init) como
-- `{kind = "log", text = "<string>"}`. O lado da extensão/harness (tarefa
-- paralela de outro agente, extension-dev) grava isso em arquivo — permite ler
-- o log via Read sem depender do usuário nem do Studio Output.
--
-- Formato do PREFIXO mantido IDÊNTICO ao anterior de propósito
-- ("[SyncTeam HH:MM:SS]") — docs/PROJECT_STATUS.md e docs/DECISIONS.md citam
-- esse prefixo literalmente em várias entradas, e o `print(prefix, ...)`
-- continua sendo a MESMA chamada de antes (não foi reescrito/reformatado) —
-- só passou a viver aqui em vez de duplicado em 6 arquivos.
--
-- Reconstrução do campo `text` enviado por WS: `prefix .. " " .. tostring(a1)
-- .. " " .. tostring(a2) ...` (espaço como separador). Isso é uma
-- RECONSTRUÇÃO best-effort do conteúdo, não uma cópia byte-a-byte do que o
-- Output do Studio renderiza internamente para múltiplos argumentos de
-- `print` (separador exato do Output não documentado/verificado nesta tarefa,
-- `[Hipótese]`) — irrelevante para o objetivo (observabilidade de teste), já
-- que o `print(...)` em si (o que aparece no Output) não foi alterado nem
-- reformatado.
--
-- Sem fila/buffer: mensagens de log perdidas enquanto desconectado não são um
-- problema (objetivo é só observabilidade em tempo real durante teste, não
-- log persistente garantido) — mesmo espírito de `sendMessage` em
-- init.server.luau, que também descarta silenciosamente sem conexão.
--
-- CUIDADO DE RECURSÃO (ver init.server.luau): `sendMessage` (a função que
-- efetivamente envia pela conexão WS, definida em init.server.luau) loga
-- internamente quando descarta uma mensagem (sem conexão) ou falha ao
-- enviar. Esses dois logs internos usam `print` PURO ali, NUNCA
-- `Logger.log`/`log` — se usassem, uma falha de envio disparia: Logger.log
-- -> sendMessage -> (falha) -> log da falha via Logger.log -> sendMessage de
-- novo -> ciclo sem saída natural (a cada tentativa gera uma nova mensagem de
-- log sobre a tentativa anterior). Ver comentário em init.server.luau.
--
-- M4.5 (painel de status, plugin/src/ui/): adicionado `Logger.notify(...)`,
-- uma segunda via de injeção (`Logger.initNotify`) paralela a `Logger.init`.
-- Motivo de não reusar o mesmo callback de `sendMessage`/`Logger.init`: aquele
-- é especificamente "encaminhar como {kind='log'} pela conexão WS" (canal de
-- observabilidade de teste, ver cabeçalho acima); este é "isto é
-- toast-worthy" (canal de UX dentro do próprio Studio, sem relação com WS).
-- `Logger.notify(...)` SEMPRE faz exatamente o que `Logger.log(...)` já
-- fazia (print + forward por WS, incondicional — spec da tarefa: "o log no
-- Output NUNCA é condicionado" à preferência de notificação) e, ADICIONALMENTE,
-- chama o callback de notify (se injetado) com o texto renderizado — quem
-- injeta (PluginUI.notify, ver plugin/src/ui/PluginUI.luau) decide se anima
-- um toast visível, olhando a preferência "Mostrar notificações"
-- (Config.NOTIFICATIONS_SETTING_KEY) — essa decisão fica INTEIRAMENTE do lado
-- de UI, nunca aqui. Só os poucos call-sites já identificados como "erro
-- genuíno" (não evento rotineiro) foram trocados de `log(...)` para
-- `notify(...)`: ver TeamCreateSchema.luau (reconciliação de duplicata) e
-- init.server.luau (lease negada, falha de reconexão WS).

local Logger = {}

-- callback(message: table), injetado por Logger.init — mesmo padrão já usado
-- em SourceWatcher.init(sendMessage)/TeamCreateLease.init(sendMessage). nil
-- até init.server.luau chamar Logger.init dentro de start(); nesse intervalo
-- (e sempre que a conexão cair), Logger.log só faz o print — sem erro.
local sendMessage = nil

-- callback(text: string), injetado por Logger.initNotify (M4.5) — nil até
-- init.server.luau chamar Logger.initNotify(PluginUI.notify), dentro de
-- start() (mesmo lugar/ordem de Logger.init). Nesse intervalo, Logger.notify
-- se comporta exatamente como Logger.log (só não há ninguém para avisar).
local onNotify = nil

-- Injeta o callback de envio espontâneo. Chamado por init.server.luau, no
-- mesmo lugar/ordem em que já chama SourceWatcher.init(sendMessage)/
-- TeamCreateLease.init(sendMessage), dentro de start().
function Logger.init(onMessage)
	sendMessage = onMessage
end

-- Injeta o callback de notificação visual (M4.5). Chamado por
-- init.server.luau dentro de start(), ao lado de Logger.init.
function Logger.initNotify(callback)
	onNotify = callback
end

-- Núcleo compartilhado de Logger.log/Logger.debug/Logger.notify: monta o
-- prefixo, imprime CONDICIONALMENTE (`shouldPrint`, ver Logger.debug abaixo),
-- encaminha por WS se houver sendMessage injetado (SEMPRE, print ou não — a
-- observabilidade de teste automatizado nunca depende do que aparece no
-- Output do Studio, ver Tools/README.md), e devolve o texto renderizado (para
-- Logger.notify repassar ao callback de notify sem reconstruir a string).
local function render(shouldPrint, ...)
	local prefix = ("[SyncTeam %s]"):format(os.date("%H:%M:%S"))
	if shouldPrint then
		print(prefix, ...)
	end

	local count = select("#", ...)
	local text = prefix
	for index = 1, count do
		local value = select(index, ...)
		text = text .. " " .. tostring(value)
	end

	if sendMessage ~= nil then
		sendMessage({ kind = "log", text = text })
	end

	return text
end

-- Mesma assinatura/comportamento de todo `log(...)` que existia espalhado
-- pelos 6 arquivos: aceita qualquer número de argumentos, formata com o
-- mesmo prefixo de sempre e imprime. Adicionalmente, se houver um
-- `sendMessage` injetado, encaminha o texto renderizado como mensagem
-- espontânea `{kind = "log", text = ...}` — melhor esforço, nunca lança erro
-- nem enfileira nada.
function Logger.log(...)
	render(true, ...)
end

-- 2026-07-16 (consolidação de ruído de boot, pedido do usuário após teste
-- real: rajada de ~7 linhas de subsistema a cada conexão). Mesmo forward por
-- WS de Logger.log (Tools/README.md continua enxergando tudo, observabilidade
-- de teste automatizado intacta), mas SEM `print()` — não aparece no Output
-- do Studio. Uso: eventos de inicialização de subsistema que são informação
-- ROTINEIRA (reconciliação de registry, ciclos internos iniciados/parados,
-- tentativa otimista de conexão antes de estabilizar) — nunca para eventos
-- que o usuário precisa perceber sem abrir um log externo (erro real, mudança
-- de liderança, lease negada — esses continuam Logger.log/Logger.notify).
function Logger.debug(...)
	render(false, ...)
end

-- Igual a Logger.log (mesmo print, mesmo forward por WS, SEMPRE — nunca
-- condicionado a preferência nenhuma), e ADICIONALMENTE chama o callback de
-- notify injetado (se houver) com o texto renderizado — melhor esforço,
-- protegido por pcall (a UI pode falhar por qualquer motivo de Instance/
-- Tween; uma falha ali nunca pode derrubar quem chamou Logger.notify no meio
-- de lógica de coordenação real). Usar SÓ nos poucos pontos já identificados
-- como "merece toast" (ver cabeçalho do arquivo) — todo o resto continua
-- `Logger.log`.
function Logger.notify(...)
	local text = render(true, ...)
	if onNotify ~= nil then
		local ok, err = pcall(onNotify, text)
		if not ok then
			print(("[SyncTeam %s]"):format(os.date("%H:%M:%S")), "falha ao notificar UI:", tostring(err))
		end
	end
end

return Logger
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="3">
      <Properties>
        <string name="Name">ScriptRegistry</string>
        <string name="Source"><![CDATA[-- SyncTeam — Registry de identidade de script (M2)
--
-- TestService.SyncTeam.Scripts.<uuid> = Folder { InstanceRef: ObjectValue,
-- CanonicalPath: StringValue (display-only) }. Porta da IDEIA validada em
-- dois Studios reais no RojoCoop (TeamCreateSchema.lua/createScript+readScript
-- e TeamCreateCoordinator:__resolveScriptRegistry) — sem eleição/leases/
-- schema versionado (SchemaVersion, sessões, leases), que ficam para o M3
-- (docs/MILESTONES.md). Aqui é só a estrutura mínima Scripts/<uuid>.
--
-- Identidade nunca é path nem attribute (decisão registrada,
-- docs/DECISIONS.md 2026-07-02): sempre UUID (HttpService:GenerateGUID(false))
-- + ObjectValue apontando para a Instance.
--
-- CORREÇÃO (docs/DECISIONS.md 2026-07-04, bug real confirmado em teste com 2
-- Studios): `InstanceRef.Value == nil` NUNCA é sinal de "instância
-- destruída" — `ObjectValue.Value` não zera automaticamente quando a
-- Instance referenciada é destruída (comportamento intencional confirmado
-- por staff da Roblox no DevForum, ver
-- .claude/research/2026-07-04-objectvalue-destroy-detection.md; o teste do
-- RojoCoop citado antes aqui só validou isso contra um MOCK, nunca contra o
-- engine real). Detecção de "destruído de verdade" usa
-- `ScriptRegistry.isInstanceDestroyed` (Parent == nil + confirmação por pcall
-- de reatribuição de Parent), nunca `InstanceRef.Value == nil` isolado.
-- `DescendantRemoving` continua não sendo usado para essa decisão porque
-- também dispara por reparent para fora da árvore observada, sem a
-- instância ter sido destruída de verdade.

local HttpService = game:GetService("HttpService")

local Logger = require(script.Parent.Logger)
local TeamCreateSchema = require(script.Parent.TeamCreateSchema)

local ScriptRegistry = {}

local scriptsFolder = nil -- TestService.SyncTeam.Scripts

-- Estado em memória (escopo de sessão do plugin, reconstruído por reconcile()
-- a cada start()). uuidByInstance é o inverso de recordByUuid[uuid].instance,
-- mantido separado só para lookup O(1) por Instance.
local uuidByInstance = {} -- Instance -> uuid
local recordByUuid = {} -- uuid -> { folder, instanceRef, canonicalPath (StringValue), instance }

local log = Logger.log

-- Container raiz (TestService.SyncTeam) extraído para TeamCreateSchema.luau
-- nesta fatia (M3.1) porque TeamCreateElection.luau também precisa dele
-- (Sessions/<clientId> + LeaderClientId/LeaderTerm/NextJoinSequence, mesmo
-- nível de Scripts) — evita duplicar "criar Folder SyncTeam sob TestService
-- se não existir" em dois módulos.
local function ensureContainers()
	if scriptsFolder ~= nil then
		return
	end
	scriptsFolder = TeamCreateSchema.ensureFolder("Scripts")
end

-- Detecta "removida da árvore observada" — nome documentado como
-- `isInstanceDestroyed` mas, na prática, é `Parent == nil`, sem
-- confirmação por pcall.
--
-- CORREÇÃO 2 (docs/DECISIONS.md 2026-07-04, teste ao vivo): a primeira
-- versão desta função exigia `pcall(function() instance.Parent = instance.Parent end)`
-- falhar (só falha quando `Destroy()` real trava a propriedade `Parent`).
-- Em teste real repetido, apagar um script pelo Explorer do Studio NUNCA
-- fez essa confirmação falhar — hipótese: o "Delete" do Explorer aparenta
-- fazer um soft-delete (só reparenta pra nil, mantendo a Instance viva e
-- editável) para suportar Ctrl+Z/undo, sem chamar Instance:Destroy() de
-- verdade nesse momento. Isso é `[Hipótese]`, não confirmado contra
-- documentação oficial (pesquisa anterior só confirmou o comportamento de
-- `ObjectValue.Value` em `Destroy()`, não o comportamento do Explorer
-- delete). Reparentar de verdade (`instance.Parent = novoPai`) é uma
-- atribuição atômica que nunca passa por um estado intermediário
-- observável com Parent nil — então, para os containers que este plugin
-- observa (Services/pastas reais manipuladas por humano via Explorer, não
-- reparenting programático via nil intermediário), `Parent == nil` sozinho
-- já é um sinal prático suficiente de "não está mais na árvore observada",
-- sem precisar da confirmação por pcall.
function ScriptRegistry.isInstanceDestroyed(instance)
	if instance == nil then
		return true
	end
	return instance.Parent == nil
end

-- Varre scriptsFolder procurando uma entrada JÁ EXISTENTE (possivelmente
-- replicada de outro Studio via Team Create) cujo InstanceRef aponte pra essa
-- MESMA Instance. Usado por resolveOrAllocate para não gerar um uuid novo
-- quando outro Studio já alocou um para essa Instance — bug real confirmado
-- em teste com 2 Studios (docs/DECISIONS.md 2026-07-04): sem essa varredura,
-- dois Studios acabavam alocando uuids diferentes para o mesmo script
-- replicado. Entradas cuja Instance já foi destruída de verdade
-- (isInstanceDestroyed) são ignoradas — não fazem sentido reaproveitar.
local function findRegistryEntryFor(instance)
	for _, folder in ipairs(scriptsFolder:GetChildren()) do
		if not folder:IsA("Folder") then
			continue
		end
		local instanceRef = folder:FindFirstChild("InstanceRef")
		local canonicalPath = folder:FindFirstChild("CanonicalPath")
		if
			instanceRef == nil
			or not instanceRef:IsA("ObjectValue")
			or canonicalPath == nil
			or not canonicalPath:IsA("StringValue")
		then
			continue
		end
		local candidate = instanceRef.Value
		if candidate == instance and not ScriptRegistry.isInstanceDestroyed(candidate) then
			return folder.Name, instanceRef, canonicalPath
		end
	end
	return nil
end

-- Cria (ou reaproveita, se já existir sob o mesmo nome) a estrutura
-- Folder/InstanceRef/CanonicalPath para um uuid já decidido, e popula os
-- mapas em memória. Uso interno de resolveOrAllocate() e reconcile().
local function createOrAdoptRecord(uuid, instance, canonicalPathStr)
	local folder = scriptsFolder:FindFirstChild(uuid)
	if folder == nil then
		folder = Instance.new("Folder")
		folder.Name = uuid
		folder.Parent = scriptsFolder
	end
	local instanceRef = folder:FindFirstChild("InstanceRef")
	if instanceRef == nil then
		instanceRef = Instance.new("ObjectValue")
		instanceRef.Name = "InstanceRef"
		instanceRef.Parent = folder
	end
	instanceRef.Value = instance
	local canonicalPath = folder:FindFirstChild("CanonicalPath")
	if canonicalPath == nil then
		canonicalPath = Instance.new("StringValue")
		canonicalPath.Name = "CanonicalPath"
		canonicalPath.Parent = folder
	end
	canonicalPath.Value = canonicalPathStr or ""

	local record = { folder = folder, instanceRef = instanceRef, canonicalPath = canonicalPath, instance = instance }
	recordByUuid[uuid] = record
	uuidByInstance[instance] = uuid
	return record
end

function ScriptRegistry.init()
	ensureContainers()
end

-- Reconciliação: chamar 1x no início de cada SourceWatcher.start(), ANTES de
-- escanear/observar qualquer Instance. Percorre Scripts:GetChildren() e, para
-- cada entrada cuja Instance referenciada ainda for válida (não destruída de
-- verdade, ver isInstanceDestroyed) e observada (isWatched(instance) ==
-- true), reaproveita o uuid em memória — identidade sobrevive a reload do
-- plugin dentro da mesma sessão de place. Entradas cuja Instance já foi
-- destruída de verdade ou que não são mais observadas (fora dos containers de
-- Config.getWatchedRoots()) são destruídas na hora: mesma regra de "delete"
-- do steady-state, só que aplicada retroativamente ao que aconteceu enquanto
-- o plugin estava parado/recarregando.
function ScriptRegistry.reconcile(isWatched)
	ensureContainers()
	local reused, stale = 0, 0
	for _, folder in ipairs(scriptsFolder:GetChildren()) do
		if not folder:IsA("Folder") then
			continue
		end
		local instanceRef = folder:FindFirstChild("InstanceRef")
		local canonicalPath = folder:FindFirstChild("CanonicalPath")
		if
			instanceRef == nil
			or not instanceRef:IsA("ObjectValue")
			or canonicalPath == nil
			or not canonicalPath:IsA("StringValue")
		then
			-- Entrada corrompida/incompleta (schema versionado/validação é M3);
			-- não é escopo desta fatia decidir o que fazer com lixo malformado.
			continue
		end
		local instance = instanceRef.Value
		if ScriptRegistry.isInstanceDestroyed(instance) or not isWatched(instance) then
			folder:Destroy()
			stale += 1
			continue
		end
		recordByUuid[folder.Name] =
			{ folder = folder, instanceRef = instanceRef, canonicalPath = canonicalPath, instance = instance }
		uuidByInstance[instance] = folder.Name
		reused += 1
	end
	-- 2026-07-16: rebaixado para Logger.debug (ruído rotineiro de boot, ver
	-- Logger.luau) — continua encaminhado por WS para observabilidade de
	-- teste, só não aparece mais no Output do Studio a cada conexão.
	Logger.debug(("registry reconciliado: %d reaproveitados, %d removidos (obsoletos)."):format(reused, stale))
end

-- Resolve o uuid de uma Instance observada, alocando um novo (e criando a
-- entrada no registry) se ela ainda não tiver um — nem reconciliado do
-- registry existente, nem alocado antes nesta sessão. Retorna uuid, isNew.
--
-- CORREÇÃO (docs/DECISIONS.md 2026-07-04, bug real confirmado em teste com 2
-- Studios): antes de gerar um uuid novo, também busca no registry
-- COMPARTILHADO (findRegistryEntryFor) por uma entrada que já aponte pra essa
-- Instance — não só no mapa em memória local (uuidByInstance). Cobre o caso
-- de uma Instance replicada de outro Studio (que já alocou uuid pra ela)
-- aparecer via DescendantAdded DEPOIS que o reconcile() inicial já rodou;
-- sem essa varredura, os dois Studios alocavam uuids diferentes para o mesmo
-- script.
function ScriptRegistry.resolveOrAllocate(instance, canonicalPathStr)
	ensureContainers()
	local existing = uuidByInstance[instance]
	if existing ~= nil then
		return existing, false
	end
	local existingUuid, instanceRef, canonicalPath = findRegistryEntryFor(instance)
	if existingUuid ~= nil then
		local folder = scriptsFolder:FindFirstChild(existingUuid)
		recordByUuid[existingUuid] = { folder = folder, instanceRef = instanceRef, canonicalPath = canonicalPath, instance = instance }
		uuidByInstance[instance] = existingUuid
		log(("resolveOrAllocate: reaproveitado uuid=%s já existente no registry compartilhado."):format(existingUuid))
		return existingUuid, false
	end
	local uuid = HttpService:GenerateGUID(false)
	createOrAdoptRecord(uuid, instance, canonicalPathStr)
	return uuid, true
end

-- Instance atual para um uuid, ou nil se desconhecido OU se a Instance já foi
-- destruída de verdade (ver isInstanceDestroyed — InstanceRef.Value sozinho
-- NÃO detecta isso, ver cabeçalho do arquivo).
function ScriptRegistry.getInstance(uuid)
	local record = recordByUuid[uuid]
	if record == nil then
		return nil
	end
	local instance = record.instanceRef.Value
	if ScriptRegistry.isInstanceDestroyed(instance) then
		return nil
	end
	return instance
end

function ScriptRegistry.getUuid(instance)
	return uuidByInstance[instance]
end

function ScriptRegistry.getCanonicalPath(uuid)
	local record = recordByUuid[uuid]
	if record == nil then
		return nil
	end
	return record.canonicalPath.Value
end

function ScriptRegistry.updateCanonicalPath(uuid, newPath)
	local record = recordByUuid[uuid]
	if record ~= nil then
		record.canonicalPath.Value = newPath
	end
end

-- Destrói a entrada do registry (Folder inteiro) e limpa os mapas em memória.
-- Não decide sozinho SE deve remover — quem chama (SourceWatcher, ciclo de
-- poll) já decidiu que a Instance foi destruída.
function ScriptRegistry.remove(uuid)
	local record = recordByUuid[uuid]
	if record == nil then
		return
	end
	uuidByInstance[record.instance] = nil
	recordByUuid[uuid] = nil
	record.folder:Destroy()
end

-- Itera um SNAPSHOT (tirado antes de qualquer callback rodar) de todas as
-- entradas vivas do registry, chamando callback(uuid, instance,
-- storedCanonicalPath). `instance` vem direto de InstanceRef.Value — pode ser
-- uma referência "morta" (Instance já destruída de verdade, ver cabeçalho do
-- arquivo); quem chama decide isso com ScriptRegistry.isInstanceDestroyed,
-- não `instance == nil` (nunca acontece por essa via). Snapshot é necessário
-- porque o callback do chamador (checkRegistryDrift em SourceWatcher) pode
-- chamar ScriptRegistry.remove() para o próprio uuid em processamento —
-- mutar recordByUuid durante a iteração de `pairs` sobre ele mesmo não é
-- seguro em Luau.
function ScriptRegistry.forEach(callback)
	local snapshot = {}
	for uuid, record in recordByUuid do
		table.insert(snapshot, { uuid = uuid, instance = record.instanceRef.Value, storedPath = record.canonicalPath.Value })
	end
	for _, entry in snapshot do
		callback(entry.uuid, entry.instance, entry.storedPath)
	end
end

return ScriptRegistry
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="4">
      <Properties>
        <string name="Name">SourceWatcher</string>
        <string name="Source"><![CDATA[-- SyncTeam — Observação e escrita de Source (plugin de produção, M2)
--
-- Porta de spikes/m0_5-local-pipeline/plugin/SyncTeamLab.lua e
-- spikes/m0-source-replication/SyncTeamM0.lua para observação GENÉRICA dos
-- containers reais listados em Config.getWatchedRoots(), em vez de uma
-- única pasta sandbox.
--
-- Identidade de script (M2, docs/MILESTONES.md): UUID + ObjectValue via
-- ScriptRegistry (TestService.SyncTeam.Scripts/<uuid>), nunca mais só o
-- caminho no DataModel. `pathFor`/`resolvePath` continuam existindo — path é
-- usado para exibição (CanonicalPath, campo `path` nas mensagens) e para
-- resolver/criar Instances a partir do project.json do lado da extensão —
-- mas NUNCA mais como chave de endereçamento de leitura/escrita.
--
-- Detecção de mudança de Source: NUNCA só o sinal.
-- GetPropertyChangedSignal("Source") não dispara de forma confiável depois
-- de ScriptEditorService:UpdateSourceAsync (confirmado em teste real, M0.5,
-- 2026-07-03 — docs/DECISIONS.md, .claude/rules/luau.md). O sinal fica
-- conectado só como fast-path; o polling periódico (Config.POLL_INTERVAL_SECONDS)
-- é o caminho garantido. As duas vias chamam checkSourceChanged, que faz
-- dedupe por instância via lastSourceByInstance. O mesmo ciclo de polling
-- também detecta rename/move e delete via ScriptRegistry (checkRegistryDrift)
-- — ver comentário lá embaixo sobre por que delete não usa DescendantRemoving.

local ScriptEditorService = game:GetService("ScriptEditorService")

local Config = require(script.Parent.Config)
local Logger = require(script.Parent.Logger)
local ScriptRegistry = require(script.Parent.ScriptRegistry)

local SourceWatcher = {}

local sendMessage = nil -- callback(message: table), injetado por SourceWatcher.init
local enabled = false
local currentToken = 0 -- token de geração: invalida polling/observadores de uma geração anterior
-- (pegadinha real encontrada no M0: uma flag booleana sozinha não basta
-- quando start()/stop() pode ser chamado de novo antes de um task.wait
-- antigo acordar — ver .claude/agent-memory/luau-dev.md)

local watched = {} -- LuaSourceContainer -> RBXScriptConnection (sinal fast-path)
local lastSourceByInstance = {} -- LuaSourceContainer -> último Source visto (dedupe sinal+polling)
local recentWrites = {} -- LuaSourceContainer -> os.clock() da última escrita local via writeSource
local rootConnections = {} -- DescendantAdded/DescendantRemoving dos containers observados

local log = Logger.log

-- ------------------------------------------------------------------ caminho

-- Caminho completo relativo a `game` (ex.: "ServerScriptService/Foo/Bar").
-- nil se a instância não estiver (mais) sob `game` (ex.: destruída antes do
-- Removing terminar de processar). Display-only a partir do M2 (ver cabeçalho).
-- Adicionado 2026-07-16 (consolidação de log de boot, ver init.server.luau/
-- Logger.luau): número de scripts atualmente observados, para compor a linha
-- única "conectado" exibida ao usuário quando a conexão estabiliza. Leitura
-- simples do tamanho de `watched` — sem custo além de percorrer a tabela (já
-- feito de igual forma dentro de SourceWatcher.start() para o log de debug
-- "observação iniciada").
function SourceWatcher.getWatchedCount()
	local count = 0
	for _ in watched do
		count += 1
	end
	return count
end

function SourceWatcher.pathFor(instance)
	local parts = {}
	local current = instance
	while current ~= nil and current ~= game do
		table.insert(parts, 1, current.Name)
		current = current.Parent
	end
	if current ~= game then
		return nil
	end
	return table.concat(parts, "/")
end

-- Resolve "ServerScriptService/Foo/Bar" a partir de `game`. Se
-- createClassName for passado, cria Folders intermediários e o nó final com
-- essa classe quando não existirem — mesma lógica do resolvePath dos
-- spikes, agora operando a partir de `game` em vez de uma pasta sandbox.
-- Usado só no modo criação do writeSource (sem uuid) — leitura/atualização
-- resolvem por uuid via resolveByUuid.
function SourceWatcher.resolvePath(path, createClassName)
	if type(path) ~= "string" or path == "" then
		return nil, "path vazio"
	end
	local parts = string.split(path, "/")
	local current = game
	for index, name in parts do
		local child = current:FindFirstChild(name)
		if child == nil and index == 1 then
			-- Primeiro segmento deveria ser um serviço padrão (ServerScriptService,
			-- Workspace, etc.), sempre presente — GetService como fallback
			-- defensivo caso o serviço ainda não tenha sido tocado no DataModel.
			local ok, service = pcall(game.GetService, game, name)
			if ok then
				child = service
			end
		end
		if child == nil then
			if createClassName == nil then
				return nil, ("'%s' não encontrado em '%s'"):format(name, current:GetFullName())
			end
			local isFinal = index == #parts
			local ok, created = pcall(Instance.new, if isFinal then createClassName else "Folder")
			if not ok then
				return nil, ("falha ao criar '%s': %s"):format(name, tostring(created))
			end
			created.Name = name
			created.Parent = current
			child = created
		end
		current = child
	end
	return current
end

-- Instance atual para um uuid, validada como LuaSourceContainer vivo. nil se
-- o uuid é desconhecido ou a Instance já foi destruída (delete detectado no
-- próximo ciclo de poll, se ainda não tiver sido).
function SourceWatcher.resolveByUuid(uuid)
	local instance = ScriptRegistry.getInstance(uuid)
	if instance == nil or not instance:IsA("LuaSourceContainer") then
		return nil
	end
	return instance
end

function SourceWatcher.getUuid(instance)
	return ScriptRegistry.getUuid(instance)
end

-- ------------------------------------------------------------- detecção

local function checkSourceChanged(instance, via)
	-- Pastas vendorizadas (Packages/ServerPackages/DevPackages, ver Config.luau
	-- 2026-07-16): nunca puxar Studio->disco uma edição nelas. Retorna ANTES de
	-- tocar lastSourceByInstance (nenhum estado de dedupe é criado para essas
	-- instâncias) — discovery/identidade (ScriptRegistry, watchScript) continua
	-- normal, só a detecção de mudança de Source é pulada aqui.
	if Config.isInsideExcludedPackageFolder(instance) then
		return
	end
	local current = instance.Source
	if current == lastSourceByInstance[instance] then
		return
	end
	lastSourceByInstance[instance] = current
	local wroteAt = recentWrites[instance]
	local origin = if wroteAt ~= nil and os.clock() - wroteAt < 1 then "plugin" else "studio"
	local path = SourceWatcher.pathFor(instance)
	if path == nil then
		return
	end
	local uuid = ScriptRegistry.getUuid(instance)
	if sendMessage ~= nil then
		sendMessage({
			kind = "sourceChanged",
			uuid = uuid,
			path = path,
			source = current,
			className = instance.ClassName,
			origin = origin,
			via = via,
		})
	end
	-- 2026-07-20 (BUG 2, ruído de uso contínuo — docs/DECISIONS.md): rotineiro/
	-- alta frequência (dispara a cada edição de Source, tanto via sinal quanto
	-- polling, não só no boot) -> Logger.debug.
	Logger.debug(("sourceChanged uuid=%s '%s' via %s (origin=%s)"):format(tostring(uuid), path, via, origin))
end

-- Registra a observação de Source E resolve/aloca o uuid da Instance no
-- ScriptRegistry, nessa ordem, de forma síncrona. Retorna o uuid (nunca nil
-- para uma Instance que passa o IsA abaixo). Idempotente: se já observada,
-- só devolve o uuid já conhecido (sem reallocar nada).
local function watchScript(instance)
	if watched[instance] ~= nil then
		return ScriptRegistry.getUuid(instance)
	end
	if not instance:IsA("LuaSourceContainer") then
		return nil
	end
	-- Baseline capturada NA HORA de começar a observar, nunca esperando o
	-- próximo poll nem o DescendantAdded (evento adiado). Pegadinha real do
	-- M0.5: se a baseline só é capturada depois, uma escrita imediata
	-- seguinte pode já estar refletida nela, mascarando a própria mudança
	-- que se queria detectar. Ver .claude/agent-memory/luau-dev.md.
	lastSourceByInstance[instance] = instance.Source
	watched[instance] = instance:GetPropertyChangedSignal("Source"):Connect(function()
		checkSourceChanged(instance, "sinal")
	end)
	local uuid = ScriptRegistry.resolveOrAllocate(instance, SourceWatcher.pathFor(instance))
	return uuid
end

-- Só cuida da bookkeeping local (conexão de sinal, caches de dedupe). NÃO
-- toca no ScriptRegistry nem emite scriptRemoved: DescendantRemoving dispara
-- tanto para delete real (Instance:Destroy()) quanto para reparent para fora
-- da árvore observada (Instance ainda existe, só saiu dos containers de
-- Config.getWatchedRoots()) — os dois casos parecem idênticos daqui. A
-- decisão "isso foi delete de verdade" cabe só a checkRegistryDrift, que usa
-- ScriptRegistry.isInstanceDestroyed (Parent == nil + confirmação por pcall)
-- no próprio registry, no ciclo de poll — ver docs/MILESTONES.md (M2) e
-- ScriptRegistry.luau. NUNCA `InstanceRef.Value == nil`: correção registrada
-- em docs/DECISIONS.md 2026-07-04 (bug real confirmado em teste com 2
-- Studios) — `ObjectValue.Value` não zera quando a Instance referenciada é
-- destruída.
local function unwatchScript(instance)
	local connection = watched[instance]
	if connection ~= nil then
		connection:Disconnect()
	end
	watched[instance] = nil
	lastSourceByInstance[instance] = nil
	recentWrites[instance] = nil
end

-- Processa uma entrada JÁ CONFIRMADA como destruída de verdade
-- (ScriptRegistry.isInstanceDestroyed já checado por quem chama): remove do
-- registry e emite scriptRemoved. Compartilhado entre checkRegistryDrift
-- (ciclo de poll, caminho GARANTIDO) e checkDeadFastPath (fast-path opcional
-- via DescendantRemoving, ver scanAndWatch) — extraído para não duplicar o
-- trio remove+sendMessage+log em dois lugares, já que a mesma entrada pode
-- ser detectada como morta por qualquer um dos dois caminhos.
local function emitScriptRemoved(uuid, storedPath)
	ScriptRegistry.remove(uuid)
	if sendMessage ~= nil then
		sendMessage({ kind = "scriptRemoved", uuid = uuid, path = storedPath })
	end
	log(("scriptRemoved uuid=%s path='%s'"):format(uuid, tostring(storedPath)))
end

-- Detecção de rename/move e delete, no mesmo ciclo que já detecta mudança de
-- Source (spec M2). Para cada entrada viva do registry: se a Instance foi
-- destruída de verdade (ScriptRegistry.isInstanceDestroyed — NUNCA
-- `instance == nil`, que não é o sinal correto, ver docs/DECISIONS.md
-- 2026-07-04), emite scriptRemoved e destrói a entrada; senão, recomputa o
-- caminho canônico atual e compara com o guardado — se mudou, emite
-- scriptMoved e atualiza CanonicalPath.
--
-- CAMINHO GARANTIDO: roda a cada Config.POLL_INTERVAL_SECONDS
-- independentemente de qualquer sinal/evento ter disparado ou não — ver
-- checkDeadFastPath abaixo para o atalho opcional de latência.
local function checkRegistryDrift()
	ScriptRegistry.forEach(function(uuid, instance, storedPath)
		if ScriptRegistry.isInstanceDestroyed(instance) then
			emitScriptRemoved(uuid, storedPath)
			return
		end
		local currentPath = SourceWatcher.pathFor(instance)
		if currentPath == nil or currentPath == storedPath then
			return
		end
		ScriptRegistry.updateCanonicalPath(uuid, currentPath)
		if sendMessage ~= nil then
			sendMessage({
				kind = "scriptMoved",
				uuid = uuid,
				oldPath = storedPath,
				newPath = currentPath,
				className = instance.ClassName,
			})
		end
		log(("scriptMoved uuid=%s '%s' -> '%s'"):format(uuid, tostring(storedPath), currentPath))
	end)
end

-- Fast-path OPCIONAL de latência para delete, acionado por DescendantRemoving
-- (ver conexão em scanAndWatch). NUNCA é o caminho garantido — isso continua
-- sendo checkRegistryDrift, a cada ciclo de poll; se este fast-path nunca
-- disparar scriptRemoved na prática, não é regressão, só significa que essa
-- otimização de latência não está rendendo nada (o próximo poll cobre).
--
-- Cuidado de timing (registrado em .claude/agent-memory/luau-dev.md):
-- DescendantRemoving dispara ANTES da remoção terminar — é "Removing", não
-- "Removed". No momento exato do handler, `instance.Parent` ainda pode ser o
-- Parent ANTIGO (não nil), inclusive para um Destroy() real — então checar
-- ScriptRegistry.isInstanceDestroyed SINCRONAMENTE aqui tenderia a sempre
-- devolver falso, mesmo pra delete de verdade. O task.defer() abaixo cede um
-- resumption point pra dar chance da destruição real terminar de travar o
-- Parent antes da checagem. **[Hipótese, não confirmada em Studio real nesta
-- tarefa]**: não há como testar o timing exato (defer vs SignalBehavior
-- Immediate/Deferred) sem um Studio real — ver roteiro manual no
-- PROJECT_STATUS.md. Se a suposição estiver errada e o defer não for
-- suficiente, o fast-path simplesmente não emite nada e o polling entrega o
-- scriptRemoved no ciclo seguinte, exatamente como antes desta mudança.
--
-- Dedupe: reconfere ScriptRegistry.getUuid(instance) == uuid depois do defer,
-- porque enquanto o defer esperava, checkRegistryDrift (ciclo de poll) ou
-- outro disparo deste mesmo fast-path pode já ter processado e removido essa
-- entrada (ScriptRegistry.remove limpa uuidByInstance[instance]) — sem essa
-- reconfirmação, poderíamos emitir scriptRemoved duplicado para o mesmo uuid.
local function checkDeadFastPath(uuid, instance, storedPath)
	task.defer(function()
		if ScriptRegistry.getUuid(instance) ~= uuid then
			return -- já processado por checkRegistryDrift ou outro disparo enquanto o defer esperava
		end
		if ScriptRegistry.isInstanceDestroyed(instance) then
			emitScriptRemoved(uuid, storedPath)
		end
	end)
end

local function pollLoop(myToken)
	while enabled and currentToken == myToken do
		task.wait(Config.POLL_INTERVAL_SECONDS)
		if not enabled or currentToken ~= myToken then
			break
		end
		for instance in watched do
			checkSourceChanged(instance, "polling")
		end
		checkRegistryDrift()
	end
end

-- --------------------------------------------------------------- escrita

-- Escreve a Source garantindo que a instância já esteja observada (e com
-- uuid alocado) ANTES da escrita, de forma síncrona e na mesma pilha de
-- chamada (mesma pegadinha do M0.5 citada em watchScript acima).
function SourceWatcher.writeSource(instance, newSource)
	watchScript(instance)
	recentWrites[instance] = os.clock()
	local ok = pcall(function()
		ScriptEditorService:UpdateSourceAsync(instance, function()
			return newSource
		end)
	end)
	if ok then
		lastSourceByInstance[instance] = instance.Source
		return true, "UpdateSourceAsync"
	end
	local okDirect, errDirect = pcall(function()
		instance.Source = newSource
	end)
	if okDirect then
		lastSourceByInstance[instance] = instance.Source
		return true, ".Source"
	end
	return false, tostring(errDirect)
end

-- --------------------------------------------------------------- listagem

function SourceWatcher.listScripts()
	local scripts = {}
	for instance in watched do
		local path = SourceWatcher.pathFor(instance)
		local uuid = ScriptRegistry.getUuid(instance)
		if path ~= nil and uuid ~= nil then
			table.insert(scripts, { uuid = uuid, path = path, className = instance.ClassName })
		end
	end
	return scripts
end

-- ------------------------------------------------------------ start/stop

-- onMessage(message: table) é chamado para eventos espontâneos
-- (sourceChanged/scriptAdded/scriptRemoved/scriptMoved); quem injeta decide
-- como/se enviar pela conexão WS ativa.
function SourceWatcher.init(onMessage)
	sendMessage = onMessage
end

local function isInstanceWatchable(instance)
	if not instance:IsA("LuaSourceContainer") then
		return false
	end
	for _, root in Config.getWatchedRoots() do
		if instance:IsDescendantOf(root) then
			return true
		end
	end
	return false
end

function SourceWatcher.start()
	if enabled then
		return
	end
	enabled = true
	currentToken += 1
	local myToken = currentToken

	-- Reconciliação (item 2 do M2): reaproveita uuids do registry existente
	-- para Instances ainda observadas ANTES de qualquer scan tratar algo como
	-- "novo" — identidade sobrevive a reload do plugin na mesma sessão de
	-- place. ScriptRegistry.reconcile também já limpa entradas obsoletas
	-- (Instance destruída ou fora dos containers observados).
	ScriptRegistry.init()
	ScriptRegistry.reconcile(isInstanceWatchable)

	local function scanAndWatch(root)
		for _, descendant in root:GetDescendants() do
			watchScript(descendant)
		end
		table.insert(
			rootConnections,
			root.DescendantAdded:Connect(function(descendant)
				if currentToken ~= myToken then
					return
				end
				if descendant:IsA("LuaSourceContainer") then
					local uuid = watchScript(descendant)
					local path = SourceWatcher.pathFor(descendant)
					if path ~= nil and uuid ~= nil and sendMessage ~= nil then
						sendMessage({ kind = "scriptAdded", uuid = uuid, path = path, className = descendant.ClassName })
					end
				end
			end)
		)
		table.insert(
			rootConnections,
			root.DescendantRemoving:Connect(function(descendant)
				if currentToken ~= myToken then
					return
				end
				if watched[descendant] ~= nil then
					-- Fast-path opcional (ver checkDeadFastPath acima): captura
					-- uuid/storedPath ANTES de unwatchScript, que só faz
					-- bookkeeping local e nunca toca o ScriptRegistry.
					local uuid = ScriptRegistry.getUuid(descendant)
					if uuid ~= nil then
						checkDeadFastPath(uuid, descendant, ScriptRegistry.getCanonicalPath(uuid))
					end
					unwatchScript(descendant)
				end
			end)
		)
	end

	for _, root in Config.getWatchedRoots() do
		scanAndWatch(root)
	end

	task.spawn(pollLoop, myToken)

	local count = 0
	for _ in watched do
		count += 1
	end
	-- 2026-07-16: Logger.debug (ruído rotineiro de boot, ver Logger.luau) —
	-- continua encaminhado por WS, só não polui o Output a cada conexão.
	Logger.debug(("observação iniciada (%d scripts encontrados nos containers observados)."):format(count))
end

function SourceWatcher.stop()
	if not enabled then
		return
	end
	enabled = false
	currentToken += 1
	for _, connection in rootConnections do
		connection:Disconnect()
	end
	table.clear(rootConnections)
	for _, connection in watched do
		connection:Disconnect()
	end
	table.clear(watched)
	table.clear(lastSourceByInstance)
	table.clear(recentWrites)
	log("observação parada.")
end

return SourceWatcher
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="5">
      <Properties>
        <string name="Name">TeamCreateElection</string>
        <string name="Source"><![CDATA[-- SyncTeam — Sessions + heartbeat + eleição de líder (M3.1)
--
-- Porte DIRETO do algoritmo já validado em 2 Studios reais no RojoCoop
-- (TeamCreateElection.lua: elect/observeCandidate/assignJoinSequences — copiados
-- sem alterar a lógica nem as constantes de tempo) e do ciclo de
-- heartbeat/tick que os conecta ao schema (TeamCreateCoordinator.lua:
-- __tick/__readSessions/__assignJoinSequences/__cleanupStaleSessions),
-- simplificado para o escopo desta fatia: SEM leases/intents/SchemaVersion
-- (isso é M3.2/M3.3, docs/MILESTONES.md) e sem comparação com servidor Rust
-- (não existe servidor no SyncTeam).
--
-- Schema sob TestService.SyncTeam/ (container raiz compartilhado com
-- ScriptRegistry via TeamCreateSchema.luau, novo nesta fatia):
--   LeaderClientId: StringValue, LeaderTerm: IntValue, NextJoinSequence: IntValue
--   Sessions/<clientId>/ (ClientId, UserId, Username, JoinSequence, Pulse,
--     ObservedRole: StringValue "leader"|"follower")
--
-- Decisões tomadas nesta fatia (registradas também em
-- docs/PROJECT_STATUS.md/luau-dev.md, não 100% especificadas na tarefa):
--
-- 1. ClientId é gerado de NOVO a cada start() (HttpService:GenerateGUID(false)),
--    não persistido entre reloads do plugin. Motivo: stop() já remove a
--    própria entrada de Sessions/ de forma SÍNCRONA (item 6 da tarefa, mesmo
--    cuidado do fix de WebStreamClient do M2) — não há entrada órfã
--    acumulando por reload normal, então persistir clientId só ganharia
--    continuidade de JoinSequence/ObservedRole entre reloads, o que não tem
--    valor aqui (o modelo trata cada start() como uma nova sessão de
--    participante, igual ao RojoCoop: TeamCreateCoordinator.new recebe um
--    clientId novo por instância do coordinator, nunca persistido em disco).
-- 2. Username via Players:GetNameFromUserIdAsync (pcall, fallback
--    tostring(userId)) — MESMO padrão já usado e validado no RojoCoop
--    (TeamCreateCoordinator:__resolveUsername), portado sem alteração. Não é
--    pesquisa de API nova: é porte de componente já exercitado em 2 Studios
--    reais (tabela de componentes validados do CLAUDE.md).
-- 3. Log claro de liderança ("sou o líder agora (term N)" / "líder atual: X
--    (term N)") sugerido como opcional pela tarefa — implementado, ajuda a
--    validar visualmente com 2 Studios reais depois.
--
-- CORREÇÃO (2026-07-07, docs/DECISIONS.md): primeiro teste real com 2
-- Studios confirmou split-brain de liderança (termos divergentes, 6 vs 1,
-- no mesmo tick). Causa raiz: `TeamCreateSchema.ensureRoot()`/
-- `ensureFolder("Sessions")` eram chamados só 1x dentro de start() (`tick()`
-- rodava sincronamente logo depois, ANTES de qualquer garantia de que a
-- replicação do outro Studio já tinha assentado) e o RESULTADO era cacheado
-- em `rootValues`/`sessionsFolder` para o resto da sessão — se duas
-- Instances-singleton (Folder ou Value) chegassem a ser criadas em paralelo
-- por dois Studios (clássica corrida "FindFirstChild nil -> Instance.new"),
-- cada Studio ficava preso lendo/escrevendo pra sempre na SUA cópia local,
-- mesmo depois da réplica do outro lado chegar como Instance irmã. Fix em
-- duas partes: (a) `TeamCreateSchema.getOrCreate` agora reconcilia
-- duplicatas sempre que é chamado, com desempate determinístico/replicado
-- (atributo `SyncTeamOrigin`) e merge que nunca perde estado (reparent de
-- filhos de Folder; máximo de contadores IntValue) — ver comentário de
-- cabeçalho de TeamCreateSchema.luau; (b) `tick()` (não só start()) agora
-- CHAMA DE NOVO `ensureRoot()`/`ensureFolder("Sessions")` a cada pulso e
-- reatribui `rootValues`/`sessionsFolder`, para este Studio sempre convergir
-- pra Instance canônica atual em vez de ficar preso na referência capturada
-- 1x. Continua sendo best-effort (replicação assíncrona nunca dá garantia
-- 100%), mas agora AUTOCORRIGE em vez de divergir permanentemente.

local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")

local Logger = require(script.Parent.Logger)
local TeamCreateSchema = require(script.Parent.TeamCreateSchema)

local TeamCreateElection = {}

-- Constantes validadas em 2 Studios reais no RojoCoop (incluindo failover
-- forçado) — NÃO alterar sem registro em docs/DECISIONS.md
-- (.claude/rules/luau.md).
TeamCreateElection.PULSE_INTERVAL_SECONDS = 2
TeamCreateElection.STALE_AFTER_SECONDS = 8
TeamCreateElection.CLEANUP_AFTER_SECONDS = 20
TeamCreateElection.PROMOTION_OBSERVATIONS = 2

local log = Logger.log

-- ------------------------------------------------- algoritmo de eleição
-- Porte 1:1 de RojoCoop/rojo-7.7.0-rc.1/plugin/src/TeamCreateElection.lua —
-- não redesenhar (docs/MILESTONES.md, M3.1).

local function isLive(session, staleAfter)
	return session.heartbeatAge <= staleAfter
end

local function compareAssigned(left, right)
	if left.joinSequence ~= right.joinSequence then
		return left.joinSequence < right.joinSequence
	end
	return left.clientId < right.clientId
end

-- Bootstrap (nenhuma sessão viva tem JoinSequence > 0 ainda): menor clientId
-- assume. Eleição normal: menor JoinSequence vivo, clientId como desempate.
function TeamCreateElection.elect(sessions, staleAfter)
	staleAfter = staleAfter or TeamCreateElection.STALE_AFTER_SECONDS

	local assigned = {}
	local unassigned = {}

	for _, session in ipairs(sessions) do
		if isLive(session, staleAfter) then
			if session.joinSequence > 0 then
				table.insert(assigned, session)
			else
				table.insert(unassigned, session)
			end
		end
	end

	if #assigned > 0 then
		table.sort(assigned, compareAssigned)
		return assigned[1].clientId
	end

	table.sort(unassigned, function(left, right)
		return left.clientId < right.clientId
	end)

	return if unassigned[1] then unassigned[1].clientId else nil
end

-- Promoção de líder só depois de N (PROMOTION_OBSERVATIONS) observações
-- consecutivas do MESMO candidato — evita flapping de líder por uma leitura
-- instável isolada de sessions.
function TeamCreateElection.observeCandidate(previous, candidate, requiredObservations)
	requiredObservations = requiredObservations or TeamCreateElection.PROMOTION_OBSERVATIONS

	if candidate == nil then
		return { candidate = nil, observations = 0, leader = nil }
	end

	local observations = 1
	if previous ~= nil and previous.candidate == candidate then
		observations = previous.observations + 1
	end

	return {
		candidate = candidate,
		observations = observations,
		leader = if observations >= requiredObservations then candidate else nil,
	}
end

function TeamCreateElection.assignJoinSequences(sessions, nextJoinSequence)
	local unassigned = {}
	for _, session in ipairs(sessions) do
		if session.joinSequence <= 0 then
			table.insert(unassigned, session)
		end
	end

	table.sort(unassigned, function(left, right)
		return left.clientId < right.clientId
	end)

	local assignments = {}
	for _, session in ipairs(unassigned) do
		assignments[session.clientId] = nextJoinSequence
		nextJoinSequence += 1
	end

	return assignments, nextJoinSequence
end

-- ------------------------------------------------------------- estado

local enabled = false
local currentToken = 0 -- token de geração (mesmo padrão de SourceWatcher/init.server.luau)

local sessionsFolder = nil -- TestService.SyncTeam.Sessions
local rootValues = nil -- {LeaderClientId, LeaderTerm, NextJoinSequence} (Instances de valor)

local clientId = nil
local userId = 0
local sessionFolder = nil -- TestService.SyncTeam.Sessions.<clientId>
local sessionValues = nil -- {ClientId, UserId, Username, JoinSequence, Pulse, ObservedRole}

local pulseObservations = {} -- clientId -> {pulse, observedAt}
local candidateObservation = nil -- {candidate, observations, leader}
local announcedLeader = nil

-- ------------------------------------------------------------- schema (Sessions/<clientId>)

local SESSION_VALUE_CLASSES = {
	ClientId = "StringValue",
	UserId = "IntValue",
	Username = "StringValue",
	JoinSequence = "IntValue",
	Pulse = "IntValue",
	ObservedRole = "StringValue",
}

local function getOrCreate(parent, className, name)
	local existing = parent:FindFirstChild(name)
	if existing ~= nil then
		return existing
	end
	local value = Instance.new(className)
	value.Name = name
	value.Parent = parent
	return value
end

-- Cria (ou reaproveita, se já existisse por algum motivo) a própria entrada
-- de sessão e popula os campos iniciais. Chamado 1x em start().
local function ensureOwnSession()
	local folder = sessionsFolder:FindFirstChild(clientId)
	if folder == nil then
		folder = Instance.new("Folder")
		folder.Name = clientId
		folder.Parent = sessionsFolder
	end

	local values = {}
	for name, className in SESSION_VALUE_CLASSES do
		values[name] = getOrCreate(folder, className, name)
	end

	values.ClientId.Value = clientId
	values.UserId.Value = userId
	if values.ObservedRole.Value == "" then
		values.ObservedRole.Value = "follower"
	end

	sessionFolder = folder
	sessionValues = values
end

-- Lê uma entrada de Sessions/<clientId> já existente (própria ou de outro
-- Studio, replicada via Team Create). nil se a entrada estiver incompleta
-- (schema versionado/validação é M3.2/M3.3, fora de escopo desta fatia).
local function readSessionEntry(folder)
	local values = {}
	for name, className in SESSION_VALUE_CLASSES do
		local value = folder:FindFirstChild(name)
		if value == nil or not value:IsA(className) then
			return nil
		end
		values[name] = value
	end
	return {
		folder = folder,
		values = values,
		clientId = values.ClientId.Value,
		joinSequence = values.JoinSequence.Value,
		pulse = values.Pulse.Value,
		userId = values.UserId.Value,
		username = values.Username.Value,
	}
end

-- Varre Sessions/ e devolve as entradas válidas com heartbeatAge calculado
-- por OBSERVAÇÃO local de mudança de Pulse (mesmo princípio já usado para
-- Source.Changed/scriptRemoved desde o M0.5/M2: nunca confiar só num
-- timestamp remoto, medir localmente desde a última vez que o Pulse mudou).
local function readSessions(now)
	local sessions = {}
	for _, folder in ipairs(sessionsFolder:GetChildren()) do
		if not folder:IsA("Folder") then
			continue
		end
		local entry = readSessionEntry(folder)
		if entry == nil or entry.clientId == "" then
			continue
		end

		local observation = pulseObservations[entry.clientId]
		if observation == nil or observation.pulse ~= entry.pulse then
			observation = { pulse = entry.pulse, observedAt = now }
			pulseObservations[entry.clientId] = observation
		end
		entry.heartbeatAge = math.max(0, now - observation.observedAt)

		table.insert(sessions, entry)
	end
	return sessions
end

-- Atribui JoinSequence a sessões vivas ainda sem uma (chamado só pelo líder).
local function applyJoinSequenceAssignments(sessions)
	local liveSessions = {}
	for _, session in ipairs(sessions) do
		if session.heartbeatAge <= TeamCreateElection.STALE_AFTER_SECONDS then
			table.insert(liveSessions, session)
		end
	end

	local assignments, newNext = TeamCreateElection.assignJoinSequences(liveSessions, rootValues.NextJoinSequence.Value)
	for _, session in ipairs(liveSessions) do
		local assigned = assignments[session.clientId]
		if assigned ~= nil and session.values.JoinSequence.Value <= 0 then
			session.values.JoinSequence.Value = assigned
			-- 2026-07-20 (BUG 2, ruído de uso contínuo — docs/DECISIONS.md):
			-- rotineiro (dispara por sessão que entra, não só no boot) ->
			-- Logger.debug.
			Logger.debug(("joinSequence atribuído clientId=%s sequence=%d"):format(session.clientId, assigned))
		end
	end
	rootValues.NextJoinSequence.Value = newNext
end

-- Remove (Folder:Destroy()) sessões (que não a própria) obsoletas há mais de
-- CLEANUP_AFTER_SECONDS — só o líder faz isso (item 5 da tarefa). A própria
-- sessão nunca é limpa por aqui: sai de Sessions/ só via stop() síncrono
-- (item 6) ou porque outro Studio a considera obsoleta se este Studio caiu
-- sem chamar stop() (plugin.Unloading cobre o caso normal).
local function cleanupStaleSessions(sessions)
	for _, session in ipairs(sessions) do
		if
			session.clientId ~= clientId
			and session.heartbeatAge >= TeamCreateElection.CLEANUP_AFTER_SECONDS
			and session.folder.Parent == sessionsFolder
		then
			log(("removendo sessão obsoleta clientId=%s heartbeatAge=%.1fs"):format(session.clientId, session.heartbeatAge))
			session.folder:Destroy()
			pulseObservations[session.clientId] = nil
		end
	end
end

-- ------------------------------------------------------------------- tick

local function tick()
	if not enabled or sessionFolder == nil or sessionFolder.Parent == nil then
		return
	end

	-- CORREÇÃO (2026-07-07, docs/DECISIONS.md — split-brain de liderança
	-- confirmado em teste real com 2 Studios): `rootValues`/`sessionsFolder`
	-- eram capturados 1x em start() e nunca mais reavaliados — se uma
	-- duplicata (ver TeamCreateSchema.luau) só fosse reconciliada DEPOIS
	-- desse instante (replicação do Team Create ainda assentando), este
	-- Studio continuava lendo/escrevendo pra sempre numa cópia local que
	-- podia já ter sido esvaziada/destruída pela reconciliação de outro
	-- Studio. `TeamCreateSchema.ensureRoot()`/`ensureFolder()` já reconciliam
	-- duplicatas sozinhos a cada chamada (idempotente e barato — poucos
	-- filhos) — chamar de novo AQUI, a cada pulso, é o que garante que este
	-- Studio sempre aponta pra Instance CANÔNICA mais recente antes de ler ou
	-- escrever `LeaderTerm`/`LeaderClientId`/`NextJoinSequence`/Sessions.
	local root = TeamCreateSchema.ensureRoot()
	rootValues = root.values
	sessionsFolder = TeamCreateSchema.ensureFolder("Sessions")

	local now = os.clock()
	sessionValues.Pulse.Value += 1

	local sessions = readSessions(now)
	local candidate = TeamCreateElection.elect(sessions, TeamCreateElection.STALE_AFTER_SECONDS)
	candidateObservation = TeamCreateElection.observeCandidate(
		candidateObservation,
		candidate,
		TeamCreateElection.PROMOTION_OBSERVATIONS
	)
	local leaderClientId = candidateObservation.leader

	if leaderClientId == clientId then
		if rootValues.LeaderClientId.Value ~= clientId then
			rootValues.LeaderTerm.Value += 1
			rootValues.LeaderClientId.Value = clientId
			log(("sou o líder agora (term %d)"):format(rootValues.LeaderTerm.Value))
		end
		applyJoinSequenceAssignments(sessions)
		cleanupStaleSessions(sessions)
	end

	local localRole = if leaderClientId == clientId then "leader" else "follower"
	sessionValues.ObservedRole.Value = localRole

	if leaderClientId ~= nil and leaderClientId ~= announcedLeader then
		announcedLeader = leaderClientId
		if leaderClientId ~= clientId then
			log(("líder atual: %s (term %d)"):format(leaderClientId, rootValues.LeaderTerm.Value))
		end
	end
end

-- ------------------------------------------------------------ start/stop

-- userIdParam: resultado de StudioService:GetUserId() (já resolvido pelo
-- chamador, init.server.luau — este módulo não chama StudioService
-- diretamente para não duplicar o pcall que init.server.luau já faz para o
-- `hello`).
function TeamCreateElection.start(userIdParam)
	if enabled then
		return
	end
	enabled = true
	currentToken += 1
	local myToken = currentToken

	local root = TeamCreateSchema.ensureRoot()
	rootValues = root.values
	sessionsFolder = TeamCreateSchema.ensureFolder("Sessions")

	-- Decisão 1 (ver cabeçalho do arquivo): clientId novo a cada start(), não
	-- persistido entre reloads — stop() remove a própria entrada de forma
	-- síncrona, então não há acúmulo de lixo por reload normal.
	clientId = HttpService:GenerateGUID(false)
	userId = userIdParam or 0
	pulseObservations = {}
	candidateObservation = nil
	announcedLeader = nil

	ensureOwnSession()
	-- 2026-07-16: Logger.debug (ruído rotineiro de boot, ver Logger.luau) —
	-- continua encaminhado por WS, só não polui o Output a cada conexão.
	Logger.debug(("sessão criada clientId=%s userId=%d"):format(clientId, userId))

	-- Username via Players:GetNameFromUserIdAsync (yield), então roda em
	-- task.spawn separado — decisão 2 do cabeçalho. Reconfere token/enabled
	-- antes de escrever de volta (mesmo cuidado de todo yield neste projeto:
	-- start()/stop() pode ter rodado de novo enquanto isso resolvia).
	task.spawn(function()
		local fallback = tostring(userId)
		local username = fallback
		if userId > 0 then
			local ok, resolved = pcall(Players.GetNameFromUserIdAsync, Players, userId)
			if ok and type(resolved) == "string" and resolved ~= "" then
				username = resolved
			end
		end
		if enabled and currentToken == myToken and sessionValues ~= nil then
			sessionValues.Username.Value = username
		end
	end)

	tick()
	task.spawn(function()
		while enabled and currentToken == myToken do
			task.wait(TeamCreateElection.PULSE_INTERVAL_SECONDS)
			if enabled and currentToken == myToken then
				tick()
			end
		end
	end)
end

-- Remove a própria entrada de Sessions/ de forma SÍNCRONA (item 6 da
-- tarefa) — não depende do loop de heartbeat (task.spawn) notar isso depois.
-- Mesmo cuidado já tomado com WebStreamClient:Close() no fix do M2
-- (docs/DECISIONS.md 2026-07-04): plugin.Unloading pode não dar chance de
-- uma coroutine assíncrona rodar cleanup.
function TeamCreateElection.stop()
	if not enabled then
		return
	end
	enabled = false
	currentToken += 1

	if sessionFolder ~= nil and sessionFolder.Parent ~= nil then
		sessionFolder:Destroy()
	end

	log(("sessão removida clientId=%s"):format(tostring(clientId)))

	sessionFolder = nil
	sessionValues = nil
	clientId = nil
	candidateObservation = nil
	announcedLeader = nil
	pulseObservations = {}
end

-- Exposto só para eventual UI/diagnóstico futuro (não usado nesta fatia).
function TeamCreateElection.getClientId()
	return clientId
end

-- Exposto para TeamCreateLease.luau (M3.2): o Folder
-- TestService.SyncTeam.Sessions.<clientId> da PRÓPRIA sessão, onde
-- TeamCreateLease cria a subpasta LeaseIntents/<uuid> ao registrar um
-- intent de edição. nil se a eleição não estiver rodando (start() não
-- chamado ainda, ou stop() já rodou) OU se a sessão tiver sido destruída —
-- quem chama trata nil como "degradar sem lease" (ver
-- TeamCreateLease.ensureIntent), nunca como erro fatal.
function TeamCreateElection.getSessionFolder()
	if sessionFolder == nil or sessionFolder.Parent == nil then
		return nil
	end
	return sessionFolder
end

function TeamCreateElection.isLeader()
	return rootValues ~= nil and clientId ~= nil and rootValues.LeaderClientId.Value == clientId
end

-- ---------------------------------------------------------- leitura p/ UI (M4.5)
--
-- Getters read-only adicionados para o painel de status do plugin
-- (plugin/src/ui/), pedido explícito da tarefa ("se já existir algo assim,
-- use; se faltar, adicione um getter pequeno e read-only, não mude a lógica
-- interna"). Nenhuma das duas funções abaixo cria/muta Instance nenhuma nem
-- participa do ciclo de eleição — só leem o estado já mantido por tick().

-- ClientId do líder atual, ou nil se a eleição ainda não convergiu nenhuma
-- vez nesta sessão (rootValues ainda não lido) ou se LeaderClientId está
-- vazio (bootstrap, nenhum term concedido ainda).
function TeamCreateElection.getLeaderClientId()
	if rootValues == nil then
		return nil
	end
	local value = rootValues.LeaderClientId.Value
	return if value ~= "" then value else nil
end

-- Snapshot de todas as sessões atualmente em Sessions/ (própria incluída —
-- decisão desta fatia: a UI mostra "quem mais está na sessão" incluindo o
-- próprio Studio, já que ele também pode ser o líder ou estar editando algo).
-- Array de { clientId, username, userId, joinSequence }, em nenhuma ordem
-- garantida (quem chama decide como ordenar) — mesmo formato de campo de
-- readSessionEntry, só que sem heartbeatAge (a UI não filtra por liveness
-- nesta fatia: uma sessão que já saiu de Sessions/ simplesmente não aparece
-- mais no próximo refresh, não precisa de um terceiro estado "stale" na
-- tabela). nil-safe: devolve {} se a eleição não estiver rodando ainda.
function TeamCreateElection.listSessions()
	if sessionsFolder == nil then
		return {}
	end
	local sessions = {}
	for _, folder in ipairs(sessionsFolder:GetChildren()) do
		if not folder:IsA("Folder") then
			continue
		end
		local entry = readSessionEntry(folder)
		if entry ~= nil and entry.clientId ~= "" then
			table.insert(sessions, {
				clientId = entry.clientId,
				username = entry.username,
				userId = entry.userId,
				joinSequence = entry.joinSequence,
			})
		end
	end
	return sessions
end

return TeamCreateElection
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="6">
      <Properties>
        <string name="Name">TeamCreateLease</string>
        <string name="Source"><![CDATA[-- SyncTeam — Leases autoritativas por script (M3.2)
--
-- Porte do algoritmo de decisão já validado em 2 Studios reais no RojoCoop:
-- `TeamCreateShadowLease.lua` (chooseWinner/assignRequestSequences/
-- groupByScript — cópia direta da lógica de comparação, sem alterar) e
-- `TeamCreateCoordinator.lua` (ciclo __assignRequestSequences/
-- __reconcileShadowLeases/__tick — mesmo ciclo, ignorando tudo sobre
-- comparação com servidor Rust e SchemaVersion, que não existem aqui).
--
-- DIFERENÇA DELIBERADA em relação ao RojoCoop (docs/DECISIONS.md
-- 2026-07-02, docs/ARCHITECTURE.md): lá as leases eram "shadow" (só
-- observação, nunca bloqueavam escrita — quem bloqueava de verdade era o
-- servidor Rust). Aqui as leases são AUTORITATIVAS desde o início: o plugin
-- recusa `writeSource` de quem não é o dono. Ver `TeamCreateLease.canWrite`
-- e a integração em `init.server.luau` (`handleWriteSource`).
--
-- OUTRA DIFERENÇA: o RojoCoop arbitrava a própria identidade do script
-- (scriptKey) dentro do ciclo de leases (`__resolveScriptRegistry`), porque
-- não tinha registry de UUID prévio. O SyncTeam já resolve identidade desde
-- o M2 (`ScriptRegistry.luau`) — os intents aqui já chegam com um uuid
-- conhecido (chave da pasta `LeaseIntents/<uuid>`), então não existe
-- equivalente a `__resolveScriptRegistry` nesta fatia.
--
-- Schema (sob TestService.SyncTeam, container raiz de TeamCreateSchema.luau):
--   NextLeaseRequestSequence: IntValue (adicionado a TeamCreateSchema.ROOT_VALUES)
--   Sessions/<clientId>/LeaseIntents/<uuid>/ (IntentId: StringValue GUID,
--     Pulse: IntValue, RequestSequence: IntValue, ScriptRef: ObjectValue)
--     — subpasta de Sessions/<clientId>, que é OWNED por TeamCreateElection;
--     este módulo só lê/escreve dentro dela via
--     TeamCreateElection.getSessionFolder() (accessor novo desta fatia).
--   Leases/<uuid>/ (OwnerClientId: StringValue, LeaseId: StringValue GUID,
--     LeaderTerm: IntValue, RequestSequence: IntValue)
--
-- Decisões tomadas nesta fatia (registradas também em
-- docs/PROJECT_STATUS.md/luau-dev.md, não 100% especificadas na tarefa):
--
-- 1. A checagem "tenho a lease deste uuid?" e a recusa de writeSource NÃO
--    ficam dentro de SourceWatcher.luau — ficam em init.server.luau
--    (handleWriteSource), no mesmo lugar que já distingue modo
--    atualização/criação pela presença de `uuid`. Motivo: manter
--    SourceWatcher.luau focado só em I/O de Source + ScriptRegistry (como
--    já documentado no cabeçalho dele); TeamCreateElection/TeamCreateLease
--    já são requeridos em init.server.luau, que é quem orquestra semântica
--    de protocolo — evita criar uma dependência nova de SourceWatcher para
--    TeamCreateLease só para isso.
-- 2. Ciclo do líder roda em `task.spawn` PRÓPRIO deste módulo (não
--    acoplado ao tick interno de TeamCreateElection), checando
--    `TeamCreateElection.isLeader()` no início de cada iteração — opção
--    explicitamente sugerida como alternativa mais simples pela tarefa, e
--    que evita tocar no loop de heartbeat já validado do M3.1.
-- 3. "Vivo" para um intent é decidido só pela observação local de mudança
--    do próprio `Pulse` (mesmo princípio de Source.Changed/scriptRemoved/
--    heartbeat desde M0.5/M2/M3.1) — NÃO verifica adicionalmente se a
--    SESSÃO dona está viva (RojoCoop fazia essa checagem extra em
--    `__readLiveIntents`). Simplificação deliberada: como o Pulse do
--    intent só é incrementado por um writeSource local (não por um timer
--    de heartbeat independente), se a sessão dona morrer o Pulse do
--    intent também para de mudar e ele fica "morto" pela ótica desta
--    checagem, no mesmo prazo (STALE_AFTER_SECONDS). Revisitar se teste
--    real mostrar um cenário onde isso diverge.
-- 4. Pastas de intent NUNCA são destruídas por este módulo quando ficam
--    obsoletas (só as entradas em `Leases/<uuid>` são criadas/atualizadas/
--    destruídas). Diferente do RojoCoop (`__pulseLocalIntents` removia
--    intents locais inativos expirados). Consequência aceita: uma sessão
--    de Studio longa, editando muitos scripts diferentes, acumula uma
--    pasta `LeaseIntents/<uuid>` por script já tocado, nunca removida
--    enquanto a sessão estiver viva — só é limpa quando a sessão inteira
--    morre (Folder:Destroy() em `TeamCreateElection.stop()` ou
--    `cleanupStaleSessions`, que destrói `Sessions/<clientId>` inteiro,
--    levando `LeaseIntents` junto). Não é escopo desta fatia (não pedido
--    na tarefa); registrar como possível polish futuro se virar problema
--    real.
--
-- M3.3 (expor identidade + mudança de lease pra extensão) — decisão tomada
-- aqui, não em SourceWatcher.luau (opção (b) das duas oferecidas pela
-- tarefa): `checkLeaseDrift`, ciclo PRÓPRIO deste módulo (task.spawn a
-- Config.POLL_INTERVAL_SECONDS, ver start()), varre
-- ScriptRegistry.forEach comparando TeamCreateLease.getOwner(uuid) contra o
-- último dono visto (lastOwnerByUuid, dedupe) e emite `leaseChanged
-- {uuid, ownerClientId, ownerDisplayName}` via callback injetado por
-- TeamCreateLease.init(onMessage) (mesmo padrão de SourceWatcher.init).
-- Motivo de NÃO usar a opção (a): o cabeçalho deste arquivo já documenta
-- (decisão 1 acima) que a integração de lease foi mantida FORA de
-- SourceWatcher.luau de propósito; colocar checkLeaseDrift lá criaria
-- exatamente a dependência nova (SourceWatcher -> TeamCreateLease) que essa
-- decisão evitou. Rodar a Config.POLL_INTERVAL_SECONDS (0.5s), não
-- PULSE_INTERVAL_SECONDS (2s): leaseChanged é sinal de UX (arquivo virou
-- read-only ou foi liberado), então a responsividade alvo é a mesma do
-- resto da UI de sincronização (Source), não a cadência de heartbeat de
-- eleição. Primeira observação de um uuid nesta sessão só grava baseline
-- sem emitir (evita rajada de leaseChanged para leases já existentes no
-- momento em que este Studio conecta) — ver comentário em checkLeaseDrift.

local HttpService = game:GetService("HttpService")

local Config = require(script.Parent.Config)
local Logger = require(script.Parent.Logger)
local TeamCreateSchema = require(script.Parent.TeamCreateSchema)
local TeamCreateElection = require(script.Parent.TeamCreateElection)
local ScriptRegistry = require(script.Parent.ScriptRegistry)

local TeamCreateLease = {}

local log = Logger.log

-- M3.3: callback(message: table) injetado por TeamCreateLease.init, mesmo
-- padrão de SourceWatcher.init — usado só para emitir `leaseChanged`
-- espontâneo (checkLeaseDrift abaixo). Quem injeta (init.server.luau) decide
-- como/se enviar pela conexão WS ativa.
--
-- BUG CORRIGIDO (2026-07-04, code review): esta declaração `local` precisa
-- vir ANTES de `TeamCreateLease.init` abaixo. Na ordem original (init()
-- definida antes deste `local`), a atribuição `sendMessage = onMessage`
-- dentro de init() criava/escrevia uma variável GLOBAL solta em vez de
-- fechar sobre esta local — checkLeaseDrift (que fecha sobre a local
-- declarada aqui) nunca recebia o valor injetado, e nenhum `leaseChanged`
-- jamais era enviado. Ver docs/DECISIONS.md.
local sendMessage = nil

-- Injeta o callback usado por checkLeaseDrift para emitir `leaseChanged`
-- espontâneo (M3.3). Chamado por init.server.luau antes de
-- TeamCreateLease.start(), mesmo padrão de SourceWatcher.init.
function TeamCreateLease.init(onMessage)
	sendMessage = onMessage
end

-- ------------------------------------------------------------------ estado

local enabled = false
local currentToken = 0 -- token de geração (mesmo padrão de todos os outros módulos deste plugin)

local leasesFolder = nil -- TestService.SyncTeam.Leases
local sessionsFolder = nil -- TestService.SyncTeam.Sessions (lido, não é dono — TeamCreateElection é o dono)
local rootValues = nil -- {LeaderClientId, LeaderTerm, NextJoinSequence, NextLeaseRequestSequence}

local ownIntents = {} -- uuid -> { folder, values = {IntentId, Pulse, RequestSequence, ScriptRef} }
local intentPulseObservations = {} -- "clientId:uuid" -> {pulse, observedAt} (bookkeeping do ciclo do líder)

-- M3.3: uuid -> último OwnerClientId observado (dedupe), OU NO_OWNER_KEY
-- quando a última observação foi "sem lease". Mesmo princípio de dedupe por
-- último valor visto já usado para Source/registry/sessões desde
-- M0.5/M2/M3.1 (nunca reagir a estado, só a MUDANÇA de estado observada
-- localmente). Ausência de uma chave em lastOwnerByUuid significa "uuid
-- ainda não observado nesta sessão" — usado para não emitir leaseChanged na
-- primeira vez que um uuid é visto (baseline, evita rajada de mensagens para
-- leases já existentes no momento em que este Studio conecta/inicia).
local lastOwnerByUuid = {}
local NO_OWNER_KEY = "" -- sentinela: OwnerClientId real é sempre um GUID não-vazio

local INTENT_VALUE_CLASSES = {
	IntentId = "StringValue",
	Pulse = "IntValue",
	RequestSequence = "IntValue",
	ScriptRef = "ObjectValue",
}

local LEASE_VALUE_CLASSES = {
	OwnerClientId = "StringValue",
	LeaseId = "StringValue",
	LeaderTerm = "IntValue",
	RequestSequence = "IntValue",
}

local function getOrCreate(parent, className, name)
	local existing = parent:FindFirstChild(name)
	if existing ~= nil then
		return existing
	end
	local value = Instance.new(className)
	value.Name = name
	value.Parent = parent
	return value
end

local function ensureContainers()
	if leasesFolder ~= nil then
		return
	end
	local root = TeamCreateSchema.ensureRoot()
	rootValues = root.values
	leasesFolder = TeamCreateSchema.ensureFolder("Leases")
	sessionsFolder = TeamCreateSchema.ensureFolder("Sessions")
end

-- ------------------------------------------------------- intent (todo Studio)

-- Cria/atualiza o próprio intent de edição para `uuid` sob
-- Sessions/<meuClientId>/LeaseIntents/<uuid>, incrementando Pulse. Chamado
-- ANTES de toda escrita em modo atualização (spec M3.2, item 1) — quem
-- decide QUANDO chamar é init.server.luau (handleWriteSource), não este
-- módulo. Degrada silenciosamente (sem erro) se a sessão local ainda não
-- estiver disponível (eleição não iniciada/reiniciando) — a checagem de
-- lease seguinte (canWrite) trata "sem intent registrado ainda" como
-- "sem lease" e permite otimisticamente (spec M3.2, item 2).
function TeamCreateLease.ensureIntent(uuid, instance)
	if not enabled or type(uuid) ~= "string" or uuid == "" then
		return
	end
	ensureContainers()

	local sessionFolder = TeamCreateElection.getSessionFolder()
	if sessionFolder == nil then
		return
	end

	local intentsFolder = sessionFolder:FindFirstChild("LeaseIntents")
	if intentsFolder == nil then
		intentsFolder = Instance.new("Folder")
		intentsFolder.Name = "LeaseIntents"
		intentsFolder.Parent = sessionFolder
	end

	local record = ownIntents[uuid]
	if record == nil or record.folder.Parent == nil then
		local folder = intentsFolder:FindFirstChild(uuid)
		if folder == nil then
			folder = Instance.new("Folder")
			folder.Name = uuid
			folder.Parent = intentsFolder
		end
		local values = {}
		for name, className in INTENT_VALUE_CLASSES do
			values[name] = getOrCreate(folder, className, name)
		end
		if values.IntentId.Value == "" then
			values.IntentId.Value = HttpService:GenerateGUID(false)
		end
		record = { folder = folder, values = values }
		ownIntents[uuid] = record
	end

	record.values.ScriptRef.Value = instance
	record.values.Pulse.Value += 1
end

-- ------------------------------------------------- checagem de lease (todo Studio)

-- OwnerClientId atual de Leases/<uuid>, ou nil se a entrada não existe
-- (ninguém foi arbitrado ainda) ou está malformada.
function TeamCreateLease.getOwner(uuid)
	ensureContainers()
	local folder = leasesFolder:FindFirstChild(uuid)
	if folder == nil then
		return nil
	end
	local ownerValue = folder:FindFirstChild("OwnerClientId")
	if ownerValue == nil or not ownerValue:IsA("StringValue") or ownerValue.Value == "" then
		return nil
	end
	return ownerValue.Value
end

-- true se o clientId local pode escrever em `uuid` agora. Spec M3.2 (item 2):
-- sem lease registrada ainda (ninguém arbitrado) OU dono == eu => permite
-- otimisticamente; dono == outro clientId => nega. Segundo valor de retorno
-- é o clientId do dono atual, só quando a escrita é negada (para a mensagem
-- de erro).
function TeamCreateLease.canWrite(uuid)
	local owner = TeamCreateLease.getOwner(uuid)
	if owner == nil then
		return true, nil
	end
	local myClientId = TeamCreateElection.getClientId()
	if owner == myClientId then
		return true, nil
	end
	return false, owner
end

-- Nome amigável para mensagens de erro: username da sessão do clientId, com
-- fallback pro próprio clientId se a sessão não tiver username resolvido
-- ainda (mesma corrida do M3.1: username é resolvido de forma assíncrona
-- via task.spawn separado, pode não estar pronto no primeiro tick).
function TeamCreateLease.describeClient(clientId)
	if clientId == nil then
		return "desconhecido"
	end
	ensureContainers()
	local folder = sessionsFolder:FindFirstChild(clientId)
	if folder ~= nil then
		local username = folder:FindFirstChild("Username")
		if username ~= nil and username:IsA("StringValue") and username.Value ~= "" then
			return username.Value
		end
	end
	return clientId
end

-- --------------------------------------------------- algoritmo de decisão
-- Porte 1:1 de RojoCoop/rojo-7.7.0-rc.1/plugin/src/TeamCreateShadowLease.lua
-- — não redesenhar (docs/MILESTONES.md, M3.2).

local function compareForSequencing(left, right)
	if left.joinSequence ~= right.joinSequence then
		return left.joinSequence < right.joinSequence
	end
	if left.clientId ~= right.clientId then
		return left.clientId < right.clientId
	end
	return left.intentId < right.intentId
end

local function assignRequestSequences(intents, nextSequence)
	local pending = {}
	for _, intent in ipairs(intents) do
		if intent.requestSequence <= 0 then
			table.insert(pending, intent)
		end
	end
	table.sort(pending, compareForSequencing)

	local assignments = {}
	for _, intent in ipairs(pending) do
		assignments[intent.intentId] = nextSequence
		nextSequence += 1
	end
	return assignments, nextSequence
end

local function compareIntent(left, right)
	if left.requestSequence ~= right.requestSequence then
		return left.requestSequence < right.requestSequence
	end
	if left.joinSequence ~= right.joinSequence then
		return left.joinSequence < right.joinSequence
	end
	if left.clientId ~= right.clientId then
		return left.clientId < right.clientId
	end
	return left.intentId < right.intentId
end

-- SEM PREEMPÇÃO: se o dono atual ainda tem intent vivo no grupo, continua
-- sendo o dono, independente de RequestSequence — só entra a comparação
-- completa quando o dono atual não está mais entre os candidatos vivos.
local function chooseWinner(currentOwnerClientId, intents)
	local ordered = table.clone(intents)
	table.sort(ordered, compareIntent)
	for _, intent in ipairs(ordered) do
		if intent.clientId == currentOwnerClientId then
			return intent
		end
	end
	return ordered[1]
end

local function groupByUuid(intents)
	local grouped = {}
	for _, intent in ipairs(intents) do
		grouped[intent.uuid] = grouped[intent.uuid] or {}
		table.insert(grouped[intent.uuid], intent)
	end
	return grouped
end

-- ------------------------------------------------------- ciclo do líder

-- Varre Sessions/*/LeaseIntents/* e devolve só os intents "vivos" (Pulse
-- mudou há menos de STALE_AFTER_SECONDS, observado localmente — ver decisão
-- 3 no cabeçalho). joinSequence vem da sessão dona (Sessions/<clientId>/
-- JoinSequence), lido diretamente (não precisa de aliveness própria da
-- sessão, ver decisão 3).
local function readLiveIntents(now)
	local intents = {}
	for _, sessionFolder in ipairs(sessionsFolder:GetChildren()) do
		if not sessionFolder:IsA("Folder") then
			continue
		end
		local ownerClientId = sessionFolder.Name
		local joinSequenceValue = sessionFolder:FindFirstChild("JoinSequence")
		local joinSequence = if joinSequenceValue ~= nil and joinSequenceValue:IsA("IntValue")
			then joinSequenceValue.Value
			else 0

		local intentsFolder = sessionFolder:FindFirstChild("LeaseIntents")
		if intentsFolder == nil then
			continue
		end

		for _, folder in ipairs(intentsFolder:GetChildren()) do
			if not folder:IsA("Folder") then
				continue
			end
			local uuid = folder.Name
			local values = {}
			local valid = true
			for name, className in INTENT_VALUE_CLASSES do
				local value = folder:FindFirstChild(name)
				if value == nil or not value:IsA(className) then
					valid = false
					break
				end
				values[name] = value
			end
			if not valid then
				continue
			end
			local scriptInstance = values.ScriptRef.Value
			if scriptInstance == nil then
				continue
			end

			local observationKey = ownerClientId .. ":" .. uuid
			local pulse = values.Pulse.Value
			local observation = intentPulseObservations[observationKey]
			if observation == nil or observation.pulse ~= pulse then
				observation = { pulse = pulse, observedAt = now }
				intentPulseObservations[observationKey] = observation
			end
			local heartbeatAge = math.max(0, now - observation.observedAt)
			if heartbeatAge > TeamCreateElection.STALE_AFTER_SECONDS then
				continue -- intent morto: dev parou de escrever nesse uuid
			end

			table.insert(intents, {
				uuid = uuid,
				clientId = ownerClientId,
				joinSequence = joinSequence,
				intentId = values.IntentId.Value,
				requestSequence = values.RequestSequence.Value,
				values = values,
				scriptInstance = scriptInstance,
			})
		end
	end
	return intents
end

-- Atribui RequestSequence (via NextLeaseRequestSequence) aos intents vivos
-- que ainda não têm um — porte de
-- TeamCreateCoordinator:__assignRequestSequences.
local function applyRequestSequenceAssignments(intents)
	local assignments, newNext = assignRequestSequences(intents, rootValues.NextLeaseRequestSequence.Value)
	for _, intent in ipairs(intents) do
		local assigned = assignments[intent.intentId]
		if assigned ~= nil and intent.values.RequestSequence.Value <= 0 then
			intent.values.RequestSequence.Value = assigned
			intent.requestSequence = assigned
			-- 2026-07-20 (BUG 2, ruído de uso contínuo — docs/DECISIONS.md):
			-- rotineiro/alta frequência (dispara por script tocado, não só no
			-- boot) -> Logger.debug. Continua encaminhado por WS.
			Logger.debug(("lease intentSequenced intentId=%s sequence=%d"):format(intent.intentId, assigned))
		end
	end
	rootValues.NextLeaseRequestSequence.Value = newNext
end

local function readLease(folder)
	local values = {}
	for name, className in LEASE_VALUE_CLASSES do
		local value = folder:FindFirstChild(name)
		if value == nil or not value:IsA(className) then
			return nil
		end
		values[name] = value
	end
	return { folder = folder, values = values, ownerClientId = values.OwnerClientId.Value }
end

-- Cria/atualiza Leases/<uuid> pro vencedor de cada grupo (agrupado por
-- uuid), rotacionando LeaseId quando dono OU termo mudam; remove
-- Leases/<uuid> cujo grupo não tem mais nenhum intent vivo (spec M3.2, itens
-- 3-5) — porte de TeamCreateCoordinator:__reconcileShadowLeases, sem a
-- checagem de ObjectValueIdentityValidated (não existe no SyncTeam — a
-- identidade UUID+ObjectValue já é a base do projeto desde o M2, não uma
-- feature opcional a validar em runtime).
local function reconcileLeases(intents, leaderTerm)
	local grouped = groupByUuid(intents)

	local existing = {}
	for _, folder in ipairs(leasesFolder:GetChildren()) do
		if folder:IsA("Folder") then
			existing[folder.Name] = folder
		end
	end

	for uuid, scriptIntents in grouped do
		local leaseFolder = existing[uuid]
		local currentOwner = nil
		if leaseFolder ~= nil then
			local lease = readLease(leaseFolder)
			currentOwner = lease and lease.ownerClientId
		end

		local winner = chooseWinner(currentOwner, scriptIntents)
		if winner == nil then
			continue
		end

		if leaseFolder == nil then
			leaseFolder = Instance.new("Folder")
			leaseFolder.Name = uuid
			leaseFolder.Parent = leasesFolder
		end
		local values = {}
		for name, className in LEASE_VALUE_CLASSES do
			values[name] = getOrCreate(leaseFolder, className, name)
		end

		local ownerChanged = values.OwnerClientId.Value ~= winner.clientId
		local termChanged = values.LeaderTerm.Value ~= leaderTerm
		if ownerChanged or termChanged or values.LeaseId.Value == "" then
			values.LeaseId.Value = HttpService:GenerateGUID(false)
		end
		values.OwnerClientId.Value = winner.clientId
		values.LeaderTerm.Value = leaderTerm
		values.RequestSequence.Value = winner.requestSequence

		if ownerChanged or termChanged then
			-- 2026-07-20 (BUG 2, ruído de uso contínuo — docs/DECISIONS.md):
			-- rotineiro/alta frequência (troca de dono acontece a cada início
			-- de edição de script diferente, não só no boot) -> Logger.debug.
			Logger.debug(("lease concedida uuid=%s owner=%s term=%d requestSequence=%d"):format(
				uuid,
				winner.clientId,
				leaderTerm,
				winner.requestSequence
			))
		end

		existing[uuid] = nil
	end

	-- Sobrou em `existing` = uuid sem NENHUM intent vivo neste ciclo: libera
	-- de verdade (spec M3.2, item 5).
	for uuid, folder in existing do
		-- 2026-07-20 (BUG 2, mesmo critério de "lease concedida" acima):
		-- rotineiro/alta frequência -> Logger.debug.
		Logger.debug(("lease liberada uuid=%s (sem intents vivos)"):format(uuid))
		folder:Destroy()
	end
end

local function leaderTick()
	if not TeamCreateElection.isLeader() then
		return
	end
	local now = os.clock()
	local intents = readLiveIntents(now)
	applyRequestSequenceAssignments(intents)
	reconcileLeases(intents, rootValues.LeaderTerm.Value)
end

-- ------------------------------------------------------ leaseChanged (M3.3)

-- Roda em TODO Studio (não só o líder): para cada uuid CONHECIDO localmente
-- (ScriptRegistry.forEach — o mesmo registry de identidade do M2), compara o
-- dono atual (getOwner) com o último dono visto (dedupe, lastOwnerByUuid) e
-- emite `leaseChanged {uuid, ownerClientId, ownerDisplayName}` só quando
-- muda. Mesmo padrão exato de checkSourceChanged/checkRegistryDrift em
-- SourceWatcher.luau (cache do último valor visto por chave, dedupe).
--
-- Decisão desta fatia (não 100% especificada na tarefa): a PRIMEIRA vez que
-- um uuid aparece no registry nesta sessão só grava a baseline, sem emitir —
-- evita uma rajada de `leaseChanged` para todo script já com lease existente
-- no exato momento em que este Studio conecta/inicia (informação que a
-- extensão não pediu proativamente ainda nesta fatia; fica para um futuro
-- "estado inicial" se necessário). Consequência aceita, análoga à limitação
-- já documentada para LeaseIntents: se um uuid é removido do registry
-- (script deletado) a entrada correspondente em lastOwnerByUuid nunca é
-- limpa — lixo pequeno e inofensivo em memória, não em replicação.
local function checkLeaseDrift()
	ScriptRegistry.forEach(function(uuid, instance, storedPath)
		local owner = TeamCreateLease.getOwner(uuid)
		local ownerKey = owner or NO_OWNER_KEY
		local lastKey = lastOwnerByUuid[uuid]

		if lastKey == nil then
			-- Primeira observação deste uuid nesta sessão: só baseline.
			lastOwnerByUuid[uuid] = ownerKey
			return
		end
		if lastKey == ownerKey then
			return
		end
		lastOwnerByUuid[uuid] = ownerKey

		local ownerDisplayName = TeamCreateLease.describeClient(owner)
		if sendMessage ~= nil then
			sendMessage({
				kind = "leaseChanged",
				uuid = uuid,
				ownerClientId = owner,
				ownerDisplayName = ownerDisplayName,
			})
		end
		-- 2026-07-20 (BUG 2, ruído de uso contínuo — docs/DECISIONS.md):
		-- rotineiro/alta frequência (dispara por script tocado a cada troca de
		-- dono, não só no boot) -> Logger.debug.
		Logger.debug(("leaseChanged uuid=%s owner=%s (%s)"):format(uuid, tostring(owner), ownerDisplayName))
	end)
end

-- ---------------------------------------------------------- leitura p/ UI (M4.5)
--
-- Read-only, pedido pelo painel de status do plugin (plugin/src/ui/): "quem
-- está editando o quê agora" — não muda nada do ciclo de arbitragem acima,
-- só itera Leases/<uuid> já concedidas. Reusa readLease (mesmo parser da
-- leaderTick). ensureContainers() garante leasesFolder mesmo se chamado
-- antes de qualquer start() (painel pode renderizar antes da eleição ligar).
function TeamCreateLease.forEachLease(callback)
	ensureContainers()
	for _, folder in ipairs(leasesFolder:GetChildren()) do
		if not folder:IsA("Folder") then
			continue
		end
		local lease = readLease(folder)
		if lease ~= nil and lease.ownerClientId ~= "" then
			callback(folder.Name, lease.ownerClientId)
		end
	end
end

-- ------------------------------------------------------------ start/stop

-- Roda seu PRÓPRIO task.spawn a cada PULSE_INTERVAL_SECONDS (decisão 2 do
-- cabeçalho) — não duplica o loop de heartbeat de TeamCreateElection, só
-- reusa a mesma constante de intervalo.
function TeamCreateLease.start()
	if enabled then
		return
	end
	enabled = true
	currentToken += 1
	local myToken = currentToken

	ensureContainers()
	ownIntents = {}
	intentPulseObservations = {}
	lastOwnerByUuid = {}

	task.spawn(function()
		while enabled and currentToken == myToken do
			task.wait(TeamCreateElection.PULSE_INTERVAL_SECONDS)
			if enabled and currentToken == myToken then
				leaderTick()
			end
		end
	end)

	-- Ciclo PRÓPRIO de checkLeaseDrift (M3.3), independente do leaderTick
	-- acima: roda em TODO Studio (não só líder) e usa
	-- Config.POLL_INTERVAL_SECONDS (0.5s, mesmo intervalo de
	-- checkSourceChanged/checkRegistryDrift em SourceWatcher.luau) em vez de
	-- PULSE_INTERVAL_SECONDS (2s) — leaseChanged é sinal de UX (arquivo
	-- ficou read-only/liberado), então vale a mesma responsividade já usada
	-- para o resto da UI de sincronização, não a cadência mais lenta de
	-- heartbeat/eleição.
	task.spawn(function()
		while enabled and currentToken == myToken do
			task.wait(Config.POLL_INTERVAL_SECONDS)
			if enabled and currentToken == myToken then
				checkLeaseDrift()
			end
		end
	end)

	-- 2026-07-16: Logger.debug (ruído rotineiro de boot, ver Logger.luau) —
	-- continua encaminhado por WS, só não polui o Output a cada conexão.
	Logger.debug("leases: ciclo iniciado.")
end

-- Não precisa destruir LeaseIntents/Leases explicitamente: pastas de intent
-- vivem sob Sessions/<clientId>, destruídas em cascata quando
-- TeamCreateElection.stop() destrói a própria sessão (síncrono, já
-- acontece independentemente desta chamada). Só limpa estado em memória.
function TeamCreateLease.stop()
	if not enabled then
		return
	end
	enabled = false
	currentToken += 1
	ownIntents = {}
	intentPulseObservations = {}
	lastOwnerByUuid = {}
	log("leases: ciclo parado.")
end

return TeamCreateLease
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="7">
      <Properties>
        <string name="Name">TeamCreatePresence</string>
        <string name="Source"><![CDATA[-- SyncTeam — Presença: cursor/seleção/arquivo ativo (M4)
--
-- PASSTHROUGH PURO de dados opacos vindos da extensão VS Code — decisão já
-- fechada na tarefa (docs/MILESTONES.md, M4): a origem do cursor/seleção é o
-- VS Code, nunca o editor de script do Studio. Este módulo NUNCA lê cursor de
-- uma Instance de Script; só grava o que a extensão manda na PRÓPRIA
-- Sessions/<clientId>/Presence (Team Create replica pro Studio remoto) e
-- observa as entradas Presence de OUTRAS sessões pra notificar a própria
-- extensão. Mesmo padrão exato de TeamCreateLease.luau: schema/ensure, ciclo
-- de poll a Config.POLL_INTERVAL_SECONDS, dedupe por último valor visto,
-- callback injetado via init() para emitir mensagem espontânea.
--
-- Schema (sob Sessions/<clientId>, dono é TeamCreateElection — este módulo só
-- lê/escreve dentro dela via TeamCreateElection.getSessionFolder() para a
-- PRÓPRIA sessão, e via sessionsFolder:GetChildren() [lido, não é dono] para
-- as demais — mesmo princípio de TeamCreateLease.ensureIntent/checkLeaseDrift):
--   Presence/ (ActiveScriptUuid: StringValue [""=nenhum script ativo],
--     CursorLine: IntValue [-1=null], CursorColumn: IntValue [-1=null],
--     SelectionStartLine: IntValue [-1=null], SelectionStartColumn: IntValue
--     [-1=null])
--
-- Contrato de protocolo fechado com ui-dev (não mudar nomes/tipos sem
-- registrar em docs/DECISIONS.md e avisar o outro lado):
--   1. `presenceUpdate` (extensão -> plugin, espontânea, sem requestId, sem
--      ack): grava a PRÓPRIA Presence (TeamCreatePresence.updateOwnPresence).
--      `uuid = null` (que chega como `message.uuid == nil` depois do
--      JSONDecode — Lua não distingui campo ausente de null, mesma limitação
--      já documentada em docs/DECISIONS.md 2026-07-04 para o sentido inverso)
--      significa "nenhum editor ativo correspondendo a um script sincronizado
--      — limpar minha presença".
--   2. `presenceChanged`/`presenceLeft` (plugin -> extensão, espontânea):
--      emitidas pelo MESMO ciclo de poll que já observa leases
--      (checkPresenceDrift, Config.POLL_INTERVAL_SECONDS), convertendo os
--      sentinelas -1/"" de volta para `null` no JSON — o lado JS nunca vê
--      sentinela.
--
-- Decisões desta fatia, não 100% especificadas na tarefa (ver também
-- .claude/agent-memory/luau-dev.md):
--
-- 1. **`updateOwnPresence` escreve IMEDIATAMENTE ao receber a mensagem**, não
--    é enfileirada para o ciclo de poll — só o LADO DE OBSERVAÇÃO (outras
--    sessões) usa o ciclo de Config.POLL_INTERVAL_SECONDS. Isso é simétrico ao
--    padrão já usado para writeSource (escreve na hora que a mensagem chega),
--    não ao padrão de ensureIntent+leaderTick (que tem um ciclo de decisão
--    separado porque envolve arbitragem entre Studios) — aqui não há
--    arbitragem nenhuma, é só "gravar o que me mandaram".
-- 2. **Dedupe por chave composta (string concatenada dos 5 campos), não por
--    tabela**: como Presence tem 5 campos (não 1 só, como o OwnerClientId de
--    TeamCreateLease), comparar tabelas por igualdade não funciona em Lua
--    (identidade de referência, não de valor) — a chave é
--    `uuid|cursorLine|cursorColumn|selStartLine|selStartCol` (sentinelas
--    crus, antes de converter pra null), mesmo princípio do NO_OWNER_KEY de
--    TeamCreateLease.checkLeaseDrift, só que estendido a múltiplos campos.
-- 3. **Baseline na primeira observação de um clientId nesta sessão**: só
--    grava, nunca emite — mesmo princípio (e mesmo motivo: evitar rajada de
--    mensagens para presença já existente no momento em que este Studio
--    conecta) já documentado e decidido em TeamCreateLease.checkLeaseDrift
--    para leaseChanged. Aplica-se tanto a presenceChanged quanto a
--    presenceLeft.
-- 4. **`presenceLeft` tem DOIS gatilhos distintos**: (a) a sessão observada
--    ZEROU a própria presença (ActiveScriptUuid virou "" — extensão limpou/
--    fechou o arquivo) — detectado dentro do loop principal de
--    checkPresenceDrift, mesma passada que detectaria um presenceChanged; (b)
--    a sessão SUMIU inteira de Sessions/ (Folder destruído — via stop()
--    síncrono do dev remoto, mesmo comportamento medido no M3.1 de ~3s em
--    shutdown gracioso, ou via cleanupStaleSessions do líder após 20s) —
--    detectado numa segunda passada comparando o snapshot desta rodada
--    (seenThisCycle) contra lastPresenceByClientId. Não foi necessário
--    duplicar nenhuma lógica de staleness própria (Pulse/heartbeatAge): o
--    módulo confia inteiramente no ciclo de vida já existente da sessão
--    (TeamCreateElection) para o Folder eventualmente desaparecer — mesmo
--    espírito de checkLeaseDrift, que também não reimplementa staleness de
--    sessão (RojoCoop fazia essa checagem dupla em __readLiveIntents; aqui,
--    como lá, decisão deliberada de não duplicar).
-- 5. **`describeClient` duplicado aqui** (não reusa
--    TeamCreateLease.describeClient) para não criar uma dependência cruzada
--    entre TeamCreatePresence e TeamCreateLease só por causa de ~5 linhas de
--    lookup de Username — mesmo raciocínio já registrado em docs/DECISIONS.md
--    (2026-07-04) para ScriptRegistry.reconcile/findRegistryEntryFor: duplicar
--    é mais legível que forçar uma abstração compartilhada entre dois módulos
--    que hoje não têm nenhuma outra razão para se conhecer.
-- 6. **Escrita de `updateOwnPresence` protegida por pcall**: diferente da
--    maioria das escritas internas deste plugin (que só manipulam dados já
--    conhecidos/gerados localmente), os 4 campos numéricos aqui vêm de uma
--    mensagie JSON EXTERNA e não confiável — `IntValue.Value` exige um número
--    íntegro; um valor malformado do lado JS lançaria erro em vez de
--    degradar. Seguindo `.claude/rules/luau.md` ("toda chamada em pcall;
--    falha degrada com log claro, nunca quebra o plugin inteiro"), a escrita
--    dos 5 valores é feita dentro de um pcall só, logando e descartando a
--    atualização inteira em caso de falha (nunca deixa a Presence num estado
--    parcialmente escrito).
-- 7. **Deletar a chave ATUAL de `lastPresenceByClientId` durante a própria
--    iteração de `pairs` é seguro em Lua** (documentado no manual da
--    linguagem: só inserir chaves NOVAS durante a travessia é
--    comportamento indefinido) — usado no loop de "sessão sumiu" abaixo.
--    Diferente do cuidado de snapshot em ScriptRegistry.forEach, que existe
--    porque ali o callback do CHAMADOR podia remover uma chave DIFERENTE da
--    que estava sendo iterada; aqui só removemos a própria chave da iteração
--    corrente, então não precisa de snapshot.

local Config = require(script.Parent.Config)
local Logger = require(script.Parent.Logger)
local TeamCreateSchema = require(script.Parent.TeamCreateSchema)
local TeamCreateElection = require(script.Parent.TeamCreateElection)

local TeamCreatePresence = {}

local log = Logger.log

-- callback(message: table) injetado por TeamCreatePresence.init, mesmo padrão
-- de SourceWatcher.init/TeamCreateLease.init — usado só para emitir
-- `presenceChanged`/`presenceLeft` espontâneos (checkPresenceDrift abaixo).
local sendMessage = nil

function TeamCreatePresence.init(onMessage)
	sendMessage = onMessage
end

-- ------------------------------------------------------------------ estado

local enabled = false
local currentToken = 0 -- token de geração (mesmo padrão de todos os outros módulos deste plugin)

local sessionsFolder = nil -- TestService.SyncTeam.Sessions (lido, não é dono — TeamCreateElection é o dono)

-- clientId -> chave composta do último valor visto (dedupe, ver decisão 2 no
-- cabeçalho). Chave ausente == "clientId ainda não observado nesta sessão"
-- (baseline, decisão 3).
local lastPresenceByClientId = {}

local PRESENCE_VALUE_CLASSES = {
	ActiveScriptUuid = "StringValue",
	CursorLine = "IntValue",
	CursorColumn = "IntValue",
	SelectionStartLine = "IntValue",
	SelectionStartColumn = "IntValue",
}

-- "Nenhuma presença" — mesmos sentinelas usados quando a extensão manda
-- uuid=null (ActiveScriptUuid="") e quando a Presence de outra sessão ainda
-- não existe/está incompleta.
local NONE_PRESENCE = {
	uuid = "",
	cursorLine = -1,
	cursorColumn = -1,
	selectionStartLine = -1,
	selectionStartColumn = -1,
}

local function getOrCreate(parent, className, name)
	local existing = parent:FindFirstChild(name)
	if existing ~= nil then
		return existing
	end
	local value = Instance.new(className)
	value.Name = name
	value.Parent = parent
	return value
end

local function ensureContainers()
	if sessionsFolder ~= nil then
		return
	end
	sessionsFolder = TeamCreateSchema.ensureFolder("Sessions")
end

-- --------------------------------------------------- própria presença (write)

-- Grava a PRÓPRIA Presence a partir de uma mensagem `presenceUpdate` recebida
-- da extensão (chamado por init.server.luau, sem ack — spec M4, item 1).
-- Degrada sem erro se a sessão local ainda não estiver disponível (eleição
-- não iniciada/reiniciando), mesmo princípio de TeamCreateLease.ensureIntent.
function TeamCreatePresence.updateOwnPresence(message)
	if not enabled then
		return
	end

	local sessionFolder = TeamCreateElection.getSessionFolder()
	if sessionFolder == nil then
		return
	end

	local presenceFolder = sessionFolder:FindFirstChild("Presence")
	if presenceFolder == nil then
		presenceFolder = Instance.new("Folder")
		presenceFolder.Name = "Presence"
		presenceFolder.Parent = sessionFolder
	end

	local values = {}
	for name, className in PRESENCE_VALUE_CLASSES do
		values[name] = getOrCreate(presenceFolder, className, name)
	end

	-- Decisão 6 (cabeçalho): dado numérico vem de mensagem externa não
	-- confiável — IntValue.Value exige inteiro, protegido por pcall.
	local ok, err = pcall(function()
		values.ActiveScriptUuid.Value = if type(message.uuid) == "string" then message.uuid else ""
		values.CursorLine.Value = if type(message.cursorLine) == "number" then message.cursorLine else -1
		values.CursorColumn.Value = if type(message.cursorColumn) == "number" then message.cursorColumn else -1
		values.SelectionStartLine.Value = if type(message.selectionStartLine) == "number"
			then message.selectionStartLine
			else -1
		values.SelectionStartColumn.Value = if type(message.selectionStartColumn) == "number"
			then message.selectionStartColumn
			else -1
	end)
	if not ok then
		log(("presenceUpdate: falha ao gravar (dado malformado?): %s"):format(tostring(err)))
	end
end

-- --------------------------------------------------- outras sessões (observação)

-- Nome amigável para presenceChanged: username da sessão do clientId, com
-- fallback pro próprio clientId (mesmo padrão de
-- TeamCreateLease.describeClient, duplicado aqui — decisão 5 no cabeçalho).
local function describeClient(clientId)
	ensureContainers()
	local folder = sessionsFolder:FindFirstChild(clientId)
	if folder ~= nil then
		local username = folder:FindFirstChild("Username")
		if username ~= nil and username:IsA("StringValue") and username.Value ~= "" then
			return username.Value
		end
	end
	return clientId
end

-- Lê a Presence de outra sessão, ou nil se ausente/incompleta (schema
-- malformado/em processo de criação — tratado como NONE_PRESENCE por quem
-- chama, mesmo espírito de readSessionEntry/readLease retornando nil).
local function readPresenceValues(presenceFolder)
	local values = {}
	for name, className in PRESENCE_VALUE_CLASSES do
		local value = presenceFolder:FindFirstChild(name)
		if value == nil or not value:IsA(className) then
			return nil
		end
		values[name] = value
	end
	return {
		uuid = values.ActiveScriptUuid.Value,
		cursorLine = values.CursorLine.Value,
		cursorColumn = values.CursorColumn.Value,
		selectionStartLine = values.SelectionStartLine.Value,
		selectionStartColumn = values.SelectionStartColumn.Value,
	}
end

local function presenceKey(presence)
	return table.concat({
		presence.uuid,
		tostring(presence.cursorLine),
		tostring(presence.cursorColumn),
		tostring(presence.selectionStartLine),
		tostring(presence.selectionStartColumn),
	}, "|")
end

-- Converte sentinelas (-1/"") de volta para null e emite presenceChanged, OU
-- emite presenceLeft se a presença zerou pra "nenhum" (decisão 4a do
-- cabeçalho) — chamado só quando a chave de dedupe mudou em relação à última
-- observada para este clientId.
local function emitPresence(clientId, presence)
	if presence.uuid == "" then
		if sendMessage ~= nil then
			sendMessage({ kind = "presenceLeft", clientId = clientId })
		end
		-- 2026-07-20 (BUG 2, ruído de uso contínuo — docs/DECISIONS.md):
		-- rotineiro/alta frequência (zera a cada troca/fechamento de arquivo no
		-- VS Code, não só saída real da sessão) -> Logger.debug.
		Logger.debug(("presenceLeft clientId=%s (presença zerada)"):format(clientId))
		return
	end

	local displayName = describeClient(clientId)
	if sendMessage ~= nil then
		sendMessage({
			kind = "presenceChanged",
			clientId = clientId,
			displayName = displayName,
			uuid = presence.uuid,
			cursorLine = if presence.cursorLine == -1 then nil else presence.cursorLine,
			cursorColumn = if presence.cursorColumn == -1 then nil else presence.cursorColumn,
			selectionStartLine = if presence.selectionStartLine == -1 then nil else presence.selectionStartLine,
			selectionStartColumn = if presence.selectionStartColumn == -1 then nil else presence.selectionStartColumn,
		})
	end
	-- 2026-07-20 (BUG 2, ruído de uso contínuo — docs/DECISIONS.md): rotineiro/
	-- alta frequência (dispara a cada movimento de cursor/seleção) -> Logger.debug.
	Logger.debug(("presenceChanged clientId=%s (%s) uuid=%s cursor=%d,%d"):format(
		clientId,
		displayName,
		presence.uuid,
		presence.cursorLine,
		presence.cursorColumn
	))
end

-- Ciclo de observação (M4): para cada sessão viva que não seja a própria,
-- compara a Presence atual contra o último valor visto (dedupe) e emite
-- presenceChanged/presenceLeft na mudança; para sessões que tinham presença
-- conhecida e SUMIRAM desta varredura (Folder destruído), emite presenceLeft
-- (decisão 4b do cabeçalho). Roda no mesmo ciclo/cadência de
-- TeamCreateLease.checkLeaseDrift (Config.POLL_INTERVAL_SECONDS).
local function checkPresenceDrift()
	ensureContainers()
	local myClientId = TeamCreateElection.getClientId()
	local seenThisCycle = {}

	for _, folder in ipairs(sessionsFolder:GetChildren()) do
		if not folder:IsA("Folder") then
			continue
		end
		local clientId = folder.Name
		if clientId == myClientId then
			continue -- spec M4, item 3: nunca a própria sessão
		end
		seenThisCycle[clientId] = true

		local presence = NONE_PRESENCE
		local presenceFolder = folder:FindFirstChild("Presence")
		if presenceFolder ~= nil then
			local read = readPresenceValues(presenceFolder)
			if read ~= nil then
				presence = read
			end
		end

		local key = presenceKey(presence)
		local lastKey = lastPresenceByClientId[clientId]

		if lastKey == nil then
			-- Primeira observação deste clientId nesta sessão: só baseline
			-- (decisão 3 do cabeçalho, mesmo princípio de checkLeaseDrift).
			lastPresenceByClientId[clientId] = key
			continue
		end
		if lastKey == key then
			continue
		end
		lastPresenceByClientId[clientId] = key
		emitPresence(clientId, presence)
	end

	-- Sobrou em lastPresenceByClientId sem aparecer nesta varredura = sessão
	-- removida de Sessions/ (decisão 4b). Deletar a chave ATUAL durante esta
	-- iteração é seguro em Lua (decisão 7 do cabeçalho).
	for clientId in lastPresenceByClientId do
		if clientId ~= myClientId and not seenThisCycle[clientId] then
			lastPresenceByClientId[clientId] = nil
			if sendMessage ~= nil then
				sendMessage({ kind = "presenceLeft", clientId = clientId })
			end
			-- 2026-07-20 (BUG 2, mesmo critério do presenceLeft acima): sessão
			-- some de Sessions/ também por timeout/cleanupStaleSessions (20s),
			-- não só saída real -> Logger.debug.
			Logger.debug(("presenceLeft clientId=%s (sessão removida)"):format(clientId))
		end
	end
end

-- ---------------------------------------------------------- leitura p/ UI (M4.5)
--
-- Read-only, pedido pelo painel de status do plugin (plugin/src/ui/): "essa
-- sessão está vendo algum script agora (sem lease de escrita)?" — reusa
-- readPresenceValues, mesmo parser de checkPresenceDrift. Não participa do
-- ciclo de observação/dedupe acima (não mexe em lastPresenceByClientId).
-- nil se a sessão não existe, não tem Presence ainda, ou zerou (uuid == "").
function TeamCreatePresence.getActiveUuid(clientId)
	ensureContainers()
	local folder = sessionsFolder:FindFirstChild(clientId)
	if folder == nil then
		return nil
	end
	local presenceFolder = folder:FindFirstChild("Presence")
	if presenceFolder == nil then
		return nil
	end
	local values = readPresenceValues(presenceFolder)
	if values == nil or values.uuid == "" then
		return nil
	end
	return values.uuid
end

-- ------------------------------------------------------------ start/stop

-- Ciclo PRÓPRIO deste módulo (mesmo padrão de checkLeaseDrift em
-- TeamCreateLease.luau): task.spawn a Config.POLL_INTERVAL_SECONDS, guardado
-- por token de geração.
function TeamCreatePresence.start()
	if enabled then
		return
	end
	enabled = true
	currentToken += 1
	local myToken = currentToken

	ensureContainers()
	lastPresenceByClientId = {}

	task.spawn(function()
		while enabled and currentToken == myToken do
			task.wait(Config.POLL_INTERVAL_SECONDS)
			if enabled and currentToken == myToken then
				checkPresenceDrift()
			end
		end
	end)

	-- 2026-07-16: Logger.debug (ruído rotineiro de boot, ver Logger.luau) —
	-- continua encaminhado por WS, só não polui o Output a cada conexão.
	Logger.debug("presença: ciclo iniciado.")
end

-- Não precisa destruir a própria Presence explicitamente: vive sob
-- Sessions/<clientId>, destruída em cascata quando TeamCreateElection.stop()
-- destrói a própria sessão de forma síncrona (mesmo raciocínio já registrado
-- em TeamCreateLease.stop() para LeaseIntents). Só limpa estado em memória.
function TeamCreatePresence.stop()
	if not enabled then
		return
	end
	enabled = false
	currentToken += 1
	lastPresenceByClientId = {}
	log("presença: ciclo parado.")
end

return TeamCreatePresence
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="8">
      <Properties>
        <string name="Name">TeamCreateSchema</string>
        <string name="Source"><![CDATA[-- SyncTeam — Container raiz compartilhado de TestService.SyncTeam (M3.1)
--
-- Extraído nesta fatia porque dois módulos agora precisam de
-- "criar Folder SyncTeam sob TestService se não existir": ScriptRegistry.luau
-- (Scripts/<uuid>, desde o M2) e TeamCreateElection.luau (Sessions/<clientId>,
-- LeaderClientId/LeaderTerm/NextJoinSequence, desta fatia M3.1). Antes desta
-- tarefa essa lógica só existia duplicada dentro de
-- ScriptRegistry.ensureContainers — TODO cumprido (ver comentário lá).
--
-- Escopo estritamente mínimo: só o container raiz e os valores de
-- coordenação de eleição (LeaderClientId/LeaderTerm/NextJoinSequence) que
-- MILESTONES.md (M3.1) pede no mesmo nível de TestService.SyncTeam.Scripts.
-- Nada de SchemaVersion/intents versionados aqui.
--
-- M3.2 (leases por script, ver plugin/src/TeamCreateLease.luau) adicionou
-- NextLeaseRequestSequence ao mesmo nível — reusa o padrão já existente de
-- "valor de coordenação direto sob a raiz", não um container próprio.
--
-- CORREÇÃO (2026-07-07, docs/DECISIONS.md — split-brain de liderança
-- confirmado em teste real com 2 Studios): o antigo `getOrCreate`
-- (`FindFirstChild` -> se nil, `Instance.new`+`.Parent`) é um clássico
-- "singleton preguiçoso" — se dois Studios chamam `ensureRoot()`/
-- `ensureFolder()` quase ao mesmo tempo, ANTES da réplica do Team Create de
-- um assentar no outro, os dois veem `FindFirstChild(...) == nil` e cada um
-- cria sua PRÓPRIA Instance (Roblox permite duas Instances irmãs com o mesmo
-- Name — não faz merge). Cada Studio então guarda a referência retornada
-- (cacheada por quem chama, ex. `TeamCreateElection.rootValues`) e passa a
-- ler/escrever SEMPRE nessa cópia local, mesmo depois que a réplica do outro
-- lado chegar como um segundo filho do mesmo Folder — dois "líderes"
-- genuinamente operando sobre Instances DIFERENTES, não um conflito de
-- escrita na mesma Instance. Reproduzido: `LeaderTerm` divergente (6 vs 1)
-- entre dois Studios no mesmo `tick()`.
--
-- Fix: `getOrCreate` agora RECONCILIA duplicatas sempre que é chamado (não só
-- na criação) — ver `getOrCreate` abaixo. Convergência determinística sem
-- depender de "quem viu o quê primeiro" (impossível garantir com replicação
-- assíncrona, só minimizar a janela): cada Instance criada por este módulo
-- ganha um atributo `SyncTeamOrigin` (GUID aleatório, gravado ANTES de
-- `.Parent` ser setado); se `getOrCreate` encontra mais de uma Instance com o
-- mesmo Name+ClassName sob o mesmo parent, a CANÔNICA é sempre a de menor
-- `SyncTeamOrigin` (ordem lexicográfica) — todo Studio que já tiver AMBAS as
-- duplicatas replicadas calcula a MESMA escolha, independente de qual viu
-- primeiro. As demais são MESCLADAS na canônica antes de destruídas (nunca
-- dropam estado):
--   - Folder: todo filho é reparentado pra dentro da canônica antes da casca
--     vazia ser destruída (cobre Scripts/Sessions/Leases e o próprio
--     SyncTeam) — se isso deixar netos com nomes repetidos sob a canônica
--     (ex.: duas sessões de clientId diferente por azar não colidem, mas dois
--     valores-filho tipo LeaderTerm duplicados sob a MESMA pasta raiz por uma
--     corrida separada, sim), a PRÓXIMA chamada de getOrCreate para aquele
--     nome específico reconcilia de novo — nunca perde dado, só pode levar
--     mais de um ciclo pra convergir de vez.
--   - Value numérica (IntValue): a canônica fica com o MAIOR valor entre
--     todas as duplicatas — os contadores deste projeto (LeaderTerm,
--     NextJoinSequence, NextLeaseRequestSequence) são estritamente
--     crescentes, "maior" nunca é retrocesso nem perde progresso real de
--     nenhum lado.
--   - Outras Values (StringValue como LeaderClientId): sem merge de
--     conteúdo — o ciclo de eleição já se autocorrige no tick seguinte (lê
--     Sessions/ já mesclado e reavalia liderança do zero); na pior hipótese
--     custa +1 incremento de term "desperdiçado" na convergência, nunca
--     viola exclusão mútua de líder.
-- Quem chama `ensureRoot()`/`ensureFolder()` UMA VEZ em `start()` e cacheia o
-- resultado (`TeamCreateElection.luau`) precisa continuar chamando de novo a
-- cada ciclo (`tick()`) para essa reconciliação ter efeito prático — só criar
-- a Instance duplicate-safe não helps se a referência local nunca for
-- atualizada depois de reconciliada (ver fix em TeamCreateElection.luau).

local HttpService = game:GetService("HttpService")
local TestService = game:GetService("TestService")

local Logger = require(script.Parent.Logger)

local TeamCreateSchema = {}

-- Valores de coordenação, direto sob TestService.SyncTeam (mesmo nível de
-- TestService.SyncTeam.Scripts). LeaderClientId/LeaderTerm/NextJoinSequence
-- são da eleição (M3.1); NextLeaseRequestSequence é das leases (M3.2).
local ROOT_VALUES = {
	LeaderClientId = "StringValue",
	LeaderTerm = "IntValue",
	NextJoinSequence = "IntValue",
	NextLeaseRequestSequence = "IntValue",
}

-- Atributo de desempate determinístico e REPLICADO (ver comentário de cabeçalho).
local ORIGIN_ATTRIBUTE = "SyncTeamOrigin"

local log = Logger.log

local function originOf(instance)
	return instance:GetAttribute(ORIGIN_ATTRIBUTE) or ""
end

-- Desempate primário: SyncTeamOrigin (determinístico/replicado). Se os dois
-- candidatos ainda não tiverem o atributo (Instance duplicada criada ANTES
-- desta correção — caso legado, só deve ocorrer uma vez na primeira
-- reconciliação de um schema pré-existente), cai para um desempate por
-- conteúdo replicado: `.Value` para Values (comparável, replicado de
-- verdade), contagem de filhos para Folder. `[Hipótese]`: nesse caso legado
-- (ambos sem atributo), dois Studios com visões parcialmente diferentes de
-- replicação PODEM escolher canônicos diferentes num único ciclo — não perde
-- dado (merge sempre roda antes de destruir), só pode custar 1-2 ciclos
-- extras de convergência; nunca exercitado contra Studio real, só deduzido
-- por leitura de código.
local function byOrigin(a, b)
	local originA, originB = originOf(a), originOf(b)
	if originA ~= originB then
		return originA < originB
	end
	if a:IsA("Folder") and b:IsA("Folder") then
		return #a:GetChildren() > #b:GetChildren() -- mais estado real = mais "estabelecido"
	end
	local va, vb = a.Value, b.Value
	if typeof(va) == "number" and typeof(vb) == "number" then
		return va < vb
	end
	return tostring(va) < tostring(vb)
end

-- Devolve a Instance canônica dentre TODAS as crianças de `parent` com o
-- Name+ClassName dados, criando se não existir nenhuma e RECONCILIANDO se
-- houver mais de uma (ver comentário de cabeçalho do arquivo para a
-- justificativa completa do algoritmo). Chamado a cada tick (não só 1x) por
-- quem usa este módulo — é isso que garante autocorreção contínua enquanto a
-- replicação do Team Create ainda estiver assentando.
local function getOrCreate(parent, className, name)
	local candidates = {}
	for _, child in ipairs(parent:GetChildren()) do
		if child.Name == name and child.ClassName == className then
			table.insert(candidates, child)
		end
	end

	if #candidates == 0 then
		local value = Instance.new(className)
		value.Name = name
		-- Atributo gravado ANTES de .Parent: melhor esforço para replicar
		-- junto com a criação (mesmo princípio de "registrar antes de agir"
		-- já usado no projeto para baseline de Source/uuid) — não é garantia
		-- atômica de rede, só reduz a janela em que a Instance existe sem o
		-- atributo.
		value:SetAttribute(ORIGIN_ATTRIBUTE, HttpService:GenerateGUID(false))
		value.Parent = parent
		return value
	end

	if #candidates == 1 then
		local only = candidates[1]
		if only:GetAttribute(ORIGIN_ATTRIBUTE) == nil then
			only:SetAttribute(ORIGIN_ATTRIBUTE, HttpService:GenerateGUID(false))
		end
		return only
	end

	table.sort(candidates, byOrigin)
	local canonical = candidates[1]
	if canonical:GetAttribute(ORIGIN_ATTRIBUTE) == nil then
		canonical:SetAttribute(ORIGIN_ATTRIBUTE, HttpService:GenerateGUID(false))
	end

	local isFolder = canonical:IsA("Folder")
	local maxNumeric = nil
	if not isFolder and typeof(canonical.Value) == "number" then
		maxNumeric = canonical.Value
	end

	for i = 2, #candidates do
		local duplicate = candidates[i]
		if isFolder then
			-- Reparenta TODOS os filhos antes de destruir a casca — nunca
			-- perde estado aninhado (sessões/scripts/leases que nasceram por
			-- azar sob a pasta "perdedora"). Se algum nome colidir com um
			-- filho já existente sob `canonical`, fica temporariamente
			-- duplicado um nível abaixo — resolvido pela PRÓXIMA chamada de
			-- getOrCreate sobre aquele nome específico (mesma reconciliação,
			-- aplicada de novo a cada ciclo).
			for _, grandchild in ipairs(duplicate:GetChildren()) do
				grandchild.Parent = canonical
			end
		elseif maxNumeric ~= nil and typeof(duplicate.Value) == "number" then
			maxNumeric = math.max(maxNumeric, duplicate.Value)
		end
		pcall(function()
			duplicate:Destroy()
		end)
	end

	if maxNumeric ~= nil and canonical.Value ~= maxNumeric then
		canonical.Value = maxNumeric
	end

	-- M4.5: toast-worthy (Logger.notify, não Logger.log) — reconciliar
	-- duplicatas é sinal de uma corrida real de replicação do Team Create
	-- (ver cabeçalho do arquivo), não um evento rotineiro; ajuda o usuário a
	-- perceber que algo estranho (mas autocorrigido) aconteceu. Continua
	-- logando no Output incondicionalmente (Logger.notify sempre faz isso,
	-- ver Logger.luau) — só a exibição do toast depende da preferência.
	Logger.notify(("reconciliada(s) %d duplicata(s) de %s '%s' sob %s"):format(
		#candidates - 1,
		className,
		name,
		parent:GetFullName()
	))

	return canonical
end

-- Idempotente: cria (ou reaproveita/reconcilia) TestService.SyncTeam e os
-- valores de coordenação (eleição + leases). Retorna { folder, values =
-- {LeaderClientId, LeaderTerm, NextJoinSequence, NextLeaseRequestSequence} }
-- (as próprias Instances de valor, não .Value já lido — quem chama decide
-- ler/escrever). Sem cache module-level: sempre reavalia contra
-- TestService:GetChildren() — barato (poucos filhos), e é isso que permite
-- reconciliar duplicatas criadas DEPOIS da primeira chamada (ver cabeçalho).
function TeamCreateSchema.ensureRoot()
	local rootFolder = getOrCreate(TestService, "Folder", "SyncTeam")

	local values = {}
	for name, className in ROOT_VALUES do
		values[name] = getOrCreate(rootFolder, className, name)
	end

	return { folder = rootFolder, values = values }
end

-- Cria (ou reaproveita/reconcilia) uma pasta filha direta de
-- TestService.SyncTeam — usado para "Scripts" (ScriptRegistry), "Sessions"
-- (TeamCreateElection) e "Leases" (TeamCreateLease), evitando duplicar a
-- chamada a ensureRoot() em cada módulo.
function TeamCreateSchema.ensureFolder(name)
	local root = TeamCreateSchema.ensureRoot()
	return getOrCreate(root.folder, "Folder", name)
end

return TeamCreateSchema
]]></string>
      </Properties>
    </Item>
    <Item class="Folder" referent="9">
      <Properties>
        <string name="Name">ui</string>
      </Properties>
      <Item class="ModuleScript" referent="10">
        <Properties>
          <string name="Name">PluginUI</string>
          <string name="Source"><![CDATA[-- SyncTeam — Orquestração do painel de status do plugin (M4.5)
--
-- Único ponto de contato entre init.server.luau (dono da lógica de
-- conexão/sessão/lease) e a UI (toolbar, DockWidgetPluginGui, Vide). Cria o
-- botão único de toolbar (toggle mostrar/esconder o painel — substitui os 3
-- botões antigos "Conectar"/"Parar"/"Alternar porta", spec da tarefa), o
-- DockWidgetPluginGui, monta a árvore Vide (StatusPanel.luau) dentro dele, e
-- expõe um API pequeno para init.server.luau empurrar mudanças de estado
-- (conectado/porta) e para Logger.notify acionar toasts.
--
-- Ciclo de vida DELIBERADAMENTE separado do start()/stop() de
-- init.server.luau: o painel (toolbar+widget) é criado 1x, no carregamento
-- do plugin, e sobrevive a reconexões/troca de porta (mesmo padrão que a
-- toolbar antiga já tinha — os botões não desapareciam a cada stop()+start()).
-- Só `PluginUI.stop()` (chamado em plugin.Unloading, separado da função
-- `stop()` de init.server.luau) desliga o refresh em segundo plano da
-- tabela de sessões.
--
-- Getters read-only usados (adicionados nesta mesma tarefa, ver
-- .claude/agent-memory/ui-dev.md para o raciocínio de cada um):
--   TeamCreateElection.getLeaderClientId() / .listSessions()
--   TeamCreateLease.forEachLease(callback)
--   TeamCreatePresence.getActiveUuid(clientId)
--   ScriptRegistry.getCanonicalPath(uuid) (já existia desde o M2)

local Config = require(script.Parent.Parent.Config)
local Logger = require(script.Parent.Parent.Logger)
local ScriptRegistry = require(script.Parent.Parent.ScriptRegistry)
local TeamCreateElection = require(script.Parent.Parent.TeamCreateElection)
local TeamCreateLease = require(script.Parent.Parent.TeamCreateLease)
local TeamCreatePresence = require(script.Parent.Parent.TeamCreatePresence)

local vide = require(script.Parent.Parent.Packages.Vide)
local StatusPanel = require(script.Parent.StatusPanel)
local Toast = require(script.Parent.Toast)

local PluginUI = {}

local log = Logger.log

-- ------------------------------------------------------------------ estado

local running = false
local currentToken = 0 -- mesmo idioma de token de geração do resto do plugin

local toastHandle = nil -- { show, destroy }, de Toast.mount() (ScreenGui em CoreGui)
local widget = nil -- DockWidgetPluginGui

-- Sources do Vide (estado reativo do painel). `connectionStatus`/`port` são
-- empurrados de fora (init.server.luau, via setConnectionStatus/setPort);
-- `view`/`notificationsEnabled`/`autoReconnectEnabled`/`sessionsMap` são
-- geridos aqui dentro. connectionStatus tem 3 valores (item 1 da tarefa):
-- "disconnected" (parado), "connecting" (tentando/reconectando), "connected"
-- (conexão confirmada). `autoReconnectEnabled` (2026-07-20) espelha
-- Config.AUTOSTART_SETTING_KEY — default `false` aqui só é o valor inicial
-- antes de PluginUI.init ler a setting real via
-- Config.resolveAutoStartEnabled (mesmo padrão de notificationsEnabledSource
-- abaixo, cujo default `true` também é só o placeholder pré-init).
local connectionStatusSource = vide.source("disconnected")
local portSource = vide.source(Config.DEFAULT_PORT)
local viewSource = vide.source("main")
local notificationsEnabledSource = vide.source(true)
local autoReconnectEnabledSource = vide.source(false)
local sessionsMapSource = vide.source({})

-- --------------------------------------------------------- tabela de sessões

-- Monta { [clientId] = RowData } a partir do estado já mantido por
-- TeamCreateElection/TeamCreateLease/TeamCreatePresence/ScriptRegistry — só
-- LEITURA, nenhum destes módulos é mutado aqui. RowData = { clientId,
-- username, joinSequence, isLeader, info }.
--
-- Decisão desta fatia (não 100% especificada na tarefa): inclui a PRÓPRIA
-- sessão na tabela (não só as remotas) — "quem mais está na sessão" também
-- se beneficia de mostrar o próprio status (sou eu o líder? o que eu estou
-- editando?) num relance só, sem precisar de uma seção separada "eu".
--
-- Prioridade INFO (spec da tarefa, em ordem): lease ativa no uuid ("editando
-- <path>") > presença sem lease ("vendo <path>") > "ocioso". Se uma sessão
-- tiver leases em MAIS de um uuid (extremo raro, ver TeamCreateLease.luau —
-- leases não expiram por troca de arquivo, só por inatividade), mostra a
-- PRIMEIRA encontrada por TeamCreateLease.forEachLease (ordem de iteração de
-- Leases/*, não garantida) — simplificação aceita: a tabela mostra "editando
-- algo", não necessariamente TUDO que a sessão está editando; sem essa
-- limitação a coluna INFO precisaria virar lista, fora do escopo desta v1
-- (spec: "texto único").
local function buildSessionsMap()
	local leaderClientId = TeamCreateElection.getLeaderClientId()
	local sessions = TeamCreateElection.listSessions()

	local editingUuidByClient = {}
	TeamCreateLease.forEachLease(function(uuid, ownerClientId)
		if editingUuidByClient[ownerClientId] == nil then
			editingUuidByClient[ownerClientId] = uuid
		end
	end)

	local map = {}
	for _, session in ipairs(sessions) do
		local info
		local editingUuid = editingUuidByClient[session.clientId]
		if editingUuid ~= nil then
			local path = ScriptRegistry.getCanonicalPath(editingUuid)
			info = ("editando %s"):format(path or editingUuid)
		else
			local viewingUuid = TeamCreatePresence.getActiveUuid(session.clientId)
			if viewingUuid ~= nil then
				local path = ScriptRegistry.getCanonicalPath(viewingUuid)
				info = ("vendo %s"):format(path or viewingUuid)
			else
				info = "ocioso"
			end
		end

		map[session.clientId] = {
			clientId = session.clientId,
			username = session.username,
			joinSequence = session.joinSequence,
			isLeader = leaderClientId ~= nil and session.clientId == leaderClientId,
			info = info,
		}
	end

	return map
end

local function refreshSessionsMap()
	local ok, result = pcall(buildSessionsMap)
	if ok then
		sessionsMapSource(result)
	else
		-- Nunca deixa uma leitura malformada (schema em transição de
		-- replicação, por exemplo) derrubar o loop de refresh inteiro —
		-- mesma disciplina de pcall em torno de leitura de estado
		-- compartilhado já usada no resto do plugin.
		log("painel: falha ao atualizar tabela de sessões:", tostring(result))
	end
end

-- ------------------------------------------------------------------ notify

-- Injetado em Logger.initNotify por init.server.luau (dentro de start()) —
-- chamado por Logger.notify(...) para os poucos eventos "toast-worthy"
-- (lease negada, reconciliação de duplicata do schema, falha de reconexão
-- WS). O log no Output já aconteceu (Logger.notify faz isso incondicionalmente,
-- ANTES de chamar este callback) — aqui só decide se anima o toast visível,
-- olhando a preferência "Mostrar notificações".
--
-- Não força mais o painel (DockWidgetPluginGui) a abrir: desde que o toast
-- virou um ScreenGui flutuante independente em CoreGui (ver Toast.luau), ele
-- aparece sozinho sobre o Studio, sem depender do painel estar aberto — abrir
-- o painel à força seria intrusivo (o usuário pode tê-lo fechado de
-- propósito). Ressalva: a pesquisa indica que o overlay via CoreGui talvez só
-- cubra o viewport 3D; o log no Output continua sendo o registro garantido.
function PluginUI.notify(text)
	if not notificationsEnabledSource() then
		return
	end
	if toastHandle ~= nil then
		toastHandle.show(text)
	end
end

-- --------------------------------------------------------- setters (init.server.luau)

-- Empurrado por init.server.luau nas transições de conexão dentro de
-- runConnection/start/stop — puramente refletir estado, nenhuma lógica de
-- conexão mora aqui. `status` ∈ {"disconnected","connecting","connected"};
-- valores inválidos são ignorados (defensivo). Dedupe: só escreve a Source se
-- o valor mudou de verdade — runConnection chama "connecting" repetidamente a
-- cada volta do loop, e escrever o mesmo valor reexecutaria os effects do
-- botão à toa.
local VALID_STATUSES = { disconnected = true, connecting = true, connected = true }
function PluginUI.setConnectionStatus(status)
	if VALID_STATUSES[status] and status ~= connectionStatusSource() then
		connectionStatusSource(status)
	end
end

-- Empurrado por init.server.luau sempre que uma porta é tentada/confirmada/
-- persistida (auto-descoberta ou manual) — o campo de porta do painel
-- reflete isso ao vivo.
function PluginUI.setPort(port)
	if type(port) == "number" then
		portSource(math.floor(port))
	end
end

-- ------------------------------------------------------------------ init/stop

-- Chamado 1x por init.server.luau, fora do ciclo start()/stop() (mesmo
-- lugar/momento em que a toolbar antiga era criada) — cria toolbar+widget,
-- monta a árvore Vide, e inicia o refresh em segundo plano da tabela de
-- sessões. `callbacks` = { onConnect, onDisconnect, onPortChange(newPort),
-- onAutoReconnectToggle(newValue) } (mesma nomenclatura/contrato de
-- start()/stop()/troca de porta já existentes em init.server.luau — este
-- módulo só invoca, nunca reimplementa a lógica de conexão).
-- `onAutoReconnectToggle` é repassado DIRETO pro StatusPanel sem lógica
-- própria aqui (diferente de onNotificationsToggle, implementado abaixo só
-- com plugin:SetSetting): a ação de "ligar auto-reconectar tenta conectar já
-- respeitando o guard de Run/Play" precisa de start()/isInRunOrPlayMode(),
-- que só init.server.luau conhece.
function PluginUI.init(pluginObject, callbacks)
	if running then
		return
	end

	-- API de Studio nunca antes usada neste projeto (DockWidgetPluginGuiInfo/
	-- CreateDockWidgetPluginGui, ver .claude/research/2026-07-15-*)
	-- protegida por pcall — uma falha aqui degrada para "sem painel visível"
	-- em vez de derrubar o restante do plugin (conexão/sync continuam
	-- funcionando via init.server.luau independente disso).
	local ok, err = pcall(function()
		notificationsEnabledSource(Config.resolveNotificationsEnabled(pluginObject))
		autoReconnectEnabledSource(Config.resolveAutoStartEnabled(pluginObject))

		local toolbar = pluginObject:CreateToolbar("SyncTeam")
		local toggleButton = toolbar:CreateButton(
			"syncteam-toggle-panel",
			"Mostra/esconde o painel de status do SyncTeam",
			"",
			"SyncTeam"
		)
		toggleButton.ClickableWhenViewportHidden = true

		local widgetInfo = DockWidgetPluginGuiInfo.new(
			Enum.InitialDockState.Right,
			false, -- initialEnabled: só vale na primeiríssima instalação; Studio persiste o resto
			false, -- não força esse valor por cima do estado persistido em runs futuros
			300, -- floatingXSize
			400, -- floatingYSize
			260, -- minWidth
			320 -- minHeight
		)
		widget = pluginObject:CreateDockWidgetPluginGui("SyncTeamPanel", widgetInfo)
		widget.Title = "SyncTeam"
		widget.Name = "SyncTeamPanel"

		toggleButton.Click:Connect(function()
			widget.Enabled = not widget.Enabled
		end)
		local function syncToggleButtonActiveState()
			pcall(function()
				toggleButton:SetActive(widget.Enabled)
			end)
		end
		syncToggleButtonActiveState()
		widget:GetPropertyChangedSignal("Enabled"):Connect(syncToggleButtonActiveState)

		local statusPanelCallbacks = {
			onConnect = callbacks.onConnect,
			onDisconnect = callbacks.onDisconnect,
			onPortSubmit = callbacks.onPortChange,
			-- Persistência da preferência é responsabilidade da UI (não de
			-- init.server.luau) — só afeta exibição de toast, nada de
			-- conexão/protocolo.
			onNotificationsToggle = function(newValue)
				local okSet, errSet = pcall(function()
					pluginObject:SetSetting(Config.NOTIFICATIONS_SETTING_KEY, newValue)
				end)
				if not okSet then
					log("falha ao salvar preferência de notificações:", tostring(errSet))
				end
			end,
			-- Passthrough puro (ver comentário de PluginUI.init acima): a
			-- persistência da setting E a tentativa de conectar já (quando
			-- ligado) vivem em init.server.luau, o único lugar que conhece
			-- start()/isInRunOrPlayMode().
			onAutoReconnectToggle = callbacks.onAutoReconnectToggle,
		}

		local state = {
			connectionStatus = connectionStatusSource,
			port = portSource,
			view = viewSource,
			notificationsEnabled = notificationsEnabledSource,
			autoReconnectEnabled = autoReconnectEnabledSource,
			sessionsMap = sessionsMapSource,
		}

		-- `StatusPanel.build` (e tudo que ele cria por dentro — `vide.create`
		-- com propriedades reativas, `vide.indexes`, `vide.switch`) precisa
		-- rodar DENTRO do escopo de `vide.root()` que `vide.mount` empurra —
		-- essas funções chamam `assert_stable_scope()` internamente e lançam
		-- erro fora de um root/effect ativo (bug real corrigido nesta sessão:
		-- construir a árvore ANTES de `vide.mount` deixava o widget vazio).
		vide.mount(function()
			return StatusPanel.build(state, statusPanelCallbacks)
		end, widget)
	end)

	if not ok then
		log("painel: falha ao inicializar UI (toolbar/widget):", tostring(err))
		return
	end

	-- Toast flutuante (ScreenGui em CoreGui, ver Toast.luau) criado FORA do
	-- vide.mount do painel (é independente dele) e em pcall ISOLADO: uma falha
	-- de acesso a CoreGui degrada para "sem toast visível" sem impedir o
	-- refresh da tabela de sessões abaixo (o painel já montou com sucesso).
	local okToast, errToast = pcall(function()
		toastHandle = Toast.mount()
	end)
	if not okToast then
		log("painel: falha ao criar overlay de notificação (CoreGui):", tostring(errToast))
	end

	running = true
	currentToken += 1
	local myToken = currentToken

	refreshSessionsMap()
	task.spawn(function()
		while running and currentToken == myToken do
			task.wait(Config.POLL_INTERVAL_SECONDS)
			if running and currentToken == myToken then
				refreshSessionsMap()
			end
		end
	end)

	log("painel: inicializado.")
end

-- Chamado em plugin.Unloading (init.server.luau) — separado do stop() da
-- lógica de conexão/sessão, já que o painel deve sobreviver a
-- reconexões/troca de porta ao longo da vida do plugin.
function PluginUI.stop()
	if not running then
		return
	end
	running = false
	currentToken += 1
	-- Destrói o ScreenGui do toast em CoreGui — não é auto-limpo no unload do
	-- plugin (ao contrário do DockWidgetPluginGui), então sem isso cada reload
	-- vazaria um ScreenGui em CoreGui (mesma classe de vazamento do
	-- WebStreamClient documentada em docs/DECISIONS.md).
	if toastHandle ~= nil then
		pcall(function()
			toastHandle.destroy()
		end)
		toastHandle = nil
	end
end

return PluginUI
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="11">
        <Properties>
          <string name="Name">StatusPanel</string>
          <string name="Source"><![CDATA[-- SyncTeam — Árvore de componentes Vide do painel de status (M4.5)
--
-- Constrói o conteúdo do DockWidgetPluginGui (mockup do usuário: título no
-- topo escuro, campo de porta, botão CONNECT largo, tabela USER | INFO) mais
-- a tela de configurações (troca de "tela" dentro do MESMO widget via um
-- Vide source, nunca um segundo DockWidgetPluginGui — spec da tarefa).
--
-- Recebe de PluginUI.luau (dono do ciclo de vida/estado):
--   state = {
--     connectionStatus: Source<"disconnected" | "connecting" | "connected">,
--     port: Source<number>,
--     view: Source<"main" | "settings">,
--     notificationsEnabled: Source<boolean>,
--     autoReconnectEnabled: Source<boolean>,
--     sessionsMap: Source<{ [clientId]: RowData }>,
--       -- RowData = { clientId, username, joinSequence, isLeader, info }
--   }
--   callbacks = {
--     onConnect: () -> (),
--     onDisconnect: () -> (),
--     onPortSubmit: (newPort: number) -> (),
--     onNotificationsToggle: (enabled: boolean) -> (),
--     onAutoReconnectToggle: (enabled: boolean) -> (),
--   }
--
-- `state` é uma tabela de Sources do Vide — cada campo É a própria função
-- fonte (chamável sem args para ler, com 1 arg para escrever), não um par
-- getter/setter separado; StatusPanel só LÊ (exceto `view`,
-- `notificationsEnabled` e `autoReconnectEnabled`, que este módulo também
-- escreve diretamente ao reagir a clique — trocar de tela e ligar/desligar
-- as duas preferências são estado 100% local de UI, não precisam de
-- callback de volta pra PluginUI/init.server.luau só para o VALOR mudar;
-- `onNotificationsToggle`/`onAutoReconnectToggle` existem à parte porque a
-- PERSISTÊNCIA (e, no caso de auto-reconectar, a AÇÃO de tentar conectar já
-- — ver init.server.luau) precisa de código que só quem chamou PluginUI.init
-- conhece, nunca duplicado aqui).
--
-- Decisões de layout (pixels/cores) não especificadas 100% pelo mockup do
-- usuário: documentadas em detalhe em .claude/agent-memory/ui-dev.md.

local vide = require(script.Parent.Parent.Packages.Vide)
local Theme = require(script.Parent.Theme)

local StatusPanel = {}

-- ------------------------------------------------------------------ layout
-- Constantes de posição Y acumuladas (evita somar à mão em cada função e
-- arriscar um offset errado) — únicas usadas pelas linhas fixas do topo do
-- Main View (título/porta/connect/cabeçalho da tabela); a tabela em si
-- ocupa todo o espaço restante abaixo de TABLE_Y.
local TITLE_HEIGHT = Theme.Layout.TitleBarHeight
local ROW_GAP = 8
local PORT_ROW_HEIGHT = 30
local CONNECT_ROW_HEIGHT = Theme.Layout.ButtonHeight
local HEADER_HEIGHT = 22

local PORT_ROW_Y = TITLE_HEIGHT + ROW_GAP
local CONNECT_ROW_Y = PORT_ROW_Y + PORT_ROW_HEIGHT + ROW_GAP
local HEADER_Y = CONNECT_ROW_Y + CONNECT_ROW_HEIGHT + ROW_GAP
local TABLE_Y = HEADER_Y + HEADER_HEIGHT + 4

-- Split de colunas da tabela USER | INFO, em Scale (responsivo a
-- redimensionamento do painel/widget flutuante) — mesma fração usada pelo
-- cabeçalho e por cada linha, para colunas alinharem.
local USER_COLUMN_SCALE = 0.45
local ROW_LEADING_INSET = 24 -- espaço reservado pra bolinha de líder antes do nome

-- ------------------------------------------------------------- título (main)

local function TitleBar(text)
	return vide.create "Frame" {
		Name = "TitleBar",
		Size = UDim2.new(1, 0, 0, TITLE_HEIGHT),
		BackgroundColor3 = Theme.Color.TitleBar,
		BorderSizePixel = 0,

		vide.create "TextLabel" {
			Size = UDim2.fromScale(1, 1),
			BackgroundTransparency = 1,
			Font = Theme.Font.Title,
			TextSize = 16,
			TextColor3 = Theme.Color.TitleText,
			Text = text,
		},
	}
end

-- --------------------------------------------------------------- campo de porta

local function PortRow(state, callbacks)
	-- Forward-declarado: o handler de FocusLost precisa ler `portBox.Text`
	-- (o valor JÁ EDITADO pelo usuário) depois que o evento dispara — closure
	-- captura o upvalue `portBox`, que já estará atribuído pelo momento em
	-- que o evento realmente for disparado (nunca antes: FocusLost só ocorre
	-- depois que este `vide.create` inteiro já retornou).
	local portBox
	portBox = vide.create "TextBox" {
		Name = "PortInput",
		Size = UDim2.new(1, -60, 1, -10),
		Position = UDim2.new(0, 50, 0, 5),
		BackgroundColor3 = Theme.Color.FieldBackground,
		BorderSizePixel = 0,
		Font = Theme.Font.Body,
		TextSize = 14,
		TextColor3 = Theme.Color.FieldText,
		PlaceholderText = "porta",
		ClearTextOnFocus = false,
		Text = function()
			return tostring(state.port())
		end,

		vide.create "UICorner" { CornerRadius = Theme.Layout.CornerRadius },

		-- Confirma em Enter OU perda de foco (os dois disparam FocusLost no
		-- Roblox; spec da tarefa pede os dois, sem distinguir motivo) —
		-- reusa a MESMA lógica de troca de porta já existente
		-- (onPortSubmit -> Config.PORT_SETTING_KEY + stop()+start(), ver
		-- PluginUI.luau/init.server.luau), nunca um mecanismo paralelo.
		FocusLost = function()
			local parsed = tonumber(portBox.Text)
			if parsed ~= nil and parsed > 0 and parsed == math.floor(parsed) then
				local newPort = math.floor(parsed)
				if newPort ~= state.port() then
					callbacks.onPortSubmit(newPort)
				end
			end
			-- Sempre volta a refletir o valor CONFIRMADO (não o texto cru
			-- digitado) — só muda de verdade quando PluginUI.setPort for
			-- chamado de volta, depois da reconexão de fato acontecer.
			-- Também corrige texto inválido (não-numérico, negativo etc.)
			-- sem travar o campo num estado ruim.
			portBox.Text = tostring(state.port())
		end,
	}

	return vide.create "Frame" {
		Name = "PortRow",
		Size = UDim2.new(1, -2 * Theme.Layout.Padding, 0, PORT_ROW_HEIGHT),
		Position = UDim2.new(0, Theme.Layout.Padding, 0, PORT_ROW_Y),
		BackgroundTransparency = 1,

		vide.create "TextLabel" {
			Size = UDim2.new(0, 44, 1, 0),
			BackgroundTransparency = 1,
			Font = Theme.Font.Body,
			TextSize = 13,
			TextColor3 = Theme.Color.LabelMuted,
			TextXAlignment = Enum.TextXAlignment.Left,
			Text = "Porta",
		},
		portBox,
	}
end

-- ----------------------------------------------------- CONNECT/DISCONNECT + engrenagem

local function ConnectRow(state, callbacks)
	-- Botão de 3 estados (item 1 da tarefa), cor+texto reativos a
	-- state.connectionStatus():
	--   "disconnected" -> azul  "CONNECT"       (ação: conectar)
	--   "connecting"   -> laranja "CONECTANDO..." (tentando/reconectando em loop)
	--   "connected"    -> vermelho "DISCONNECT"  (ação: desconectar)
	-- O estado laranja cobre o INTERVALO em que runConnection está tentando
	-- conectar mas ainda não confirmou (ou perdeu e está reconectando) — antes
	-- disso o botão piscava azul/vermelho a cada ciclo do loop de reconexão
	-- (bug reportado pelo usuário); agora fica laranja estável.
	local connectHovered = vide.source(false)
	local connectButton = vide.create "TextButton" {
		Name = "ConnectButton",
		Size = UDim2.new(1, -(Theme.Layout.IconButtonSize + 8), 1, 0),
		BackgroundColor3 = function()
			local status = state.connectionStatus()
			if status == "connected" then
				return if connectHovered() then Theme.Color.ConnectActiveHover else Theme.Color.ConnectActive
			elseif status == "connecting" then
				return if connectHovered() then Theme.Color.ConnectConnectingHover else Theme.Color.ConnectConnecting
			end
			return if connectHovered() then Theme.Color.ConnectIdleHover else Theme.Color.ConnectIdle
		end,
		BorderSizePixel = 0,
		AutoButtonColor = false,
		Font = Theme.Font.Bold,
		TextSize = 14,
		TextColor3 = Theme.Color.ButtonText,
		Text = function()
			local status = state.connectionStatus()
			if status == "connected" then
				return "DISCONNECT"
			elseif status == "connecting" then
				return "CONECTANDO..."
			end
			return "CONNECT"
		end,

		vide.create "UICorner" { CornerRadius = Theme.Layout.CornerRadius },

		MouseEnter = function()
			connectHovered(true)
		end,
		MouseLeave = function()
			connectHovered(false)
		end,
		Activated = function()
			-- "disconnected" (parado) é o único estado cuja ação é CONECTAR;
			-- "connecting" e "connected" ambos oferecem PARAR — onDisconnect
			-- chama stop(), que zera o loop de runConnection (cancela a
			-- tentativa em voo ou encerra a conexão viva).
			if state.connectionStatus() == "disconnected" then
				callbacks.onConnect()
			else
				callbacks.onDisconnect()
			end
		end,
	}

	local gearHovered = vide.source(false)
	local gearButton = vide.create "TextButton" {
		Name = "SettingsGear",
		Size = UDim2.fromOffset(Theme.Layout.IconButtonSize, Theme.Layout.IconButtonSize),
		Position = UDim2.new(1, -Theme.Layout.IconButtonSize, 0.5, -Theme.Layout.IconButtonSize / 2),
		BackgroundColor3 = function()
			return if gearHovered() then Theme.Color.IconButtonHover else Theme.Color.IconButton
		end,
		BorderSizePixel = 0,
		AutoButtonColor = false,
		Font = Theme.Font.Body,
		TextSize = 15,
		TextColor3 = Theme.Color.ButtonText,
		Text = "\u{2699}", -- engrenagem (⚙) — abre a tela de configurações
		TextYAlignment = Enum.TextYAlignment.Center,

		vide.create "UICorner" { CornerRadius = Theme.Layout.CornerRadius },

		MouseEnter = function()
			gearHovered(true)
		end,
		MouseLeave = function()
			gearHovered(false)
		end,
		Activated = function()
			state.view("settings")
		end,
	}

	return vide.create "Frame" {
		Name = "ConnectRow",
		Size = UDim2.new(1, -2 * Theme.Layout.Padding, 0, CONNECT_ROW_HEIGHT),
		Position = UDim2.new(0, Theme.Layout.Padding, 0, CONNECT_ROW_Y),
		BackgroundTransparency = 1,

		connectButton,
		gearButton,
	}
end

-- --------------------------------------------------------- cabeçalho da tabela

local function TableHeader()
	return vide.create "Frame" {
		Name = "TableHeader",
		Position = UDim2.new(0, Theme.Layout.Padding, 0, HEADER_Y),
		Size = UDim2.new(1, -2 * Theme.Layout.Padding, 0, HEADER_HEIGHT),
		BackgroundTransparency = 1,

		vide.create "TextLabel" {
			Size = UDim2.new(USER_COLUMN_SCALE, -ROW_LEADING_INSET, 1, 0),
			Position = UDim2.new(0, ROW_LEADING_INSET, 0, 0),
			BackgroundTransparency = 1,
			Font = Theme.Font.Bold,
			TextSize = 12,
			TextColor3 = Theme.Color.TableHeaderText,
			TextXAlignment = Enum.TextXAlignment.Left,
			Text = "USER",
		},
		vide.create "TextLabel" {
			Size = UDim2.new(1 - USER_COLUMN_SCALE, -8, 1, 0),
			Position = UDim2.new(USER_COLUMN_SCALE, 0, 0, 0),
			BackgroundTransparency = 1,
			Font = Theme.Font.Bold,
			TextSize = 12,
			TextColor3 = Theme.Color.TableHeaderText,
			TextXAlignment = Enum.TextXAlignment.Left,
			Text = "INFO",
		},
	}
end

-- ------------------------------------------------------------- linha da tabela

-- rowSource: Source<RowData>, RowData = { clientId, username, joinSequence,
-- isLeader, info }. LayoutOrder = joinSequence garante ordem visual estável
-- via UIListLayout(SortOrder=LayoutOrder) — a ordem em que vide.indexes()
-- entrega os Instances (baseado em iteração de tabela/Map em Lua) NÃO é
-- garantida, então a ordem visual correta depende inteiramente do
-- LayoutOrder, nunca da ordem de criação/parenting.
local function SessionRow(rowSource)
	return vide.create "Frame" {
		Name = "Row",
		Size = UDim2.new(1, 0, 0, Theme.Layout.RowHeight),
		LayoutOrder = function()
			return rowSource().joinSequence
		end,
		BackgroundColor3 = function()
			return if rowSource().joinSequence % 2 == 0
				then Theme.Color.RowBackgroundEven
				else Theme.Color.RowBackgroundOdd
		end,
		BorderSizePixel = 0,

		-- Bolinha de líder: SEMPRE criada (mesmo espaço reservado em toda
		-- linha, líder ou não — alinhamento consistente do nome entre
		-- linhas), só a visibilidade é reativa (spec: "bolinha... só quando
		-- aquela sessão é a líder atual; sem bolinha nas demais linhas").
		vide.create "Frame" {
			Name = "LeaderDot",
			Size = UDim2.fromOffset(8, 8),
			Position = UDim2.new(0, 8, 0.5, -4),
			BackgroundColor3 = Theme.Color.LeaderDot,
			BorderSizePixel = 0,
			Visible = function()
				return rowSource().isLeader
			end,

			vide.create "UICorner" { CornerRadius = UDim.new(1, 0) },
		},
		vide.create "TextLabel" {
			Name = "Username",
			Size = UDim2.new(USER_COLUMN_SCALE, -ROW_LEADING_INSET, 1, 0),
			Position = UDim2.new(0, ROW_LEADING_INSET, 0, 0),
			BackgroundTransparency = 1,
			Font = Theme.Font.Body,
			TextSize = 13,
			TextColor3 = Theme.Color.RowText,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextTruncate = Enum.TextTruncate.AtEnd,
			Text = function()
				return rowSource().username
			end,
		},
		vide.create "TextLabel" {
			Name = "Info",
			Size = UDim2.new(1 - USER_COLUMN_SCALE, -8, 1, 0),
			Position = UDim2.new(USER_COLUMN_SCALE, 0, 0, 0),
			BackgroundTransparency = 1,
			Font = Theme.Font.Body,
			TextSize = 13,
			TextColor3 = Theme.Color.RowInfoText,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextTruncate = Enum.TextTruncate.AtEnd,
			Text = function()
				return rowSource().info
			end,
		},
	}
end

local function SessionsTable(state)
	return vide.create "ScrollingFrame" {
		Name = "SessionsTable",
		Position = UDim2.new(0, Theme.Layout.Padding, 0, TABLE_Y),
		Size = UDim2.new(1, -2 * Theme.Layout.Padding, 1, -TABLE_Y - Theme.Layout.Padding),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 6,
		ScrollBarImageColor3 = Theme.Color.LabelMuted,
		CanvasSize = UDim2.fromOffset(0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,

		vide.create "UIListLayout" {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 2),
		},

		-- Uma linha por sessão viva (vide.indexes: chave = clientId, mantém
		-- a MESMA Instance de linha entre refreshes em vez de recriar tudo
		-- do zero a cada poll — só linhas que entram/saem de Sessions/
		-- criam/destroem Instance).
		vide.indexes(state.sessionsMap, function(rowSource)
			return SessionRow(rowSource)
		end),
	}
end

-- ------------------------------------------------------------------ main view

local function MainView(state, callbacks)
	return vide.create "Frame" {
		Name = "MainView",
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,

		TitleBar("SYNC TEAM"),
		PortRow(state, callbacks),
		ConnectRow(state, callbacks),
		TableHeader(),
		SessionsTable(state),
	}
end

-- -------------------------------------------------------------- settings view

local function SettingsRow(labelText, control, isDisabled)
	return vide.create "Frame" {
		Size = UDim2.new(1, 0, 0, 30),
		BackgroundTransparency = 1,

		vide.create "TextLabel" {
			Size = UDim2.new(0.62, 0, 1, 0),
			BackgroundTransparency = 1,
			Font = Theme.Font.Body,
			TextSize = 13,
			TextColor3 = if isDisabled then Theme.Color.DisabledText else Theme.Color.FieldText,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextWrapped = true,
			Text = labelText,
		},
		control,
	}
end

-- Única opção real desta fatia (spec da tarefa): liga/desliga o toast; o log
-- no Output NUNCA é condicionado a isso (Logger.notify sempre loga, ver
-- Logger.luau) — só a exibição visual passa por aqui.
local function NotificationsToggle(state, callbacks)
	local hovered = vide.source(false)
	return vide.create "TextButton" {
		Name = "NotificationsToggle",
		Size = UDim2.new(0.38, 0, 1, -6),
		Position = UDim2.new(0.62, 0, 0, 3),
		BackgroundColor3 = function()
			return if hovered() then Theme.Color.IconButtonHover else Theme.Color.IconButton
		end,
		BorderSizePixel = 0,
		AutoButtonColor = false,
		Font = Theme.Font.Body,
		TextSize = 12,
		TextColor3 = Theme.Color.ButtonText,
		Text = function()
			return if state.notificationsEnabled() then "Ativado" else "Desativado"
		end,

		vide.create "UICorner" { CornerRadius = Theme.Layout.CornerRadius },

		MouseEnter = function()
			hovered(true)
		end,
		MouseLeave = function()
			hovered(false)
		end,
		Activated = function()
			local newValue = not state.notificationsEnabled()
			state.notificationsEnabled(newValue)
			callbacks.onNotificationsToggle(newValue)
		end,
	}
end

-- Segunda opção real desta fatia (2026-07-20): liga/desliga
-- Config.AUTOSTART_SETTING_KEY (mesma setting que já existia sem UI, ver
-- Config.luau) — "conectar sozinho ao abrir a place/recarregar o plugin",
-- NÃO tem relação com reconexão após queda de uma sessão já viva (essa
-- já é automática e incondicional, ver Config.RECONNECT_SECONDS, e não
-- precisa de nenhuma preferência). Mesmo mirror visual de NotificationsToggle
-- (mesmo tamanho/posição/estados hover, texto "Ativado"/"Desativado") —
-- única diferença é que aqui `callbacks.onAutoReconnectToggle` também pode
-- AGIR na hora (tentar conectar já, se ligado e desconectado; ver o
-- comentário completo dessa decisão de UX em init.server.luau,
-- PluginUI.init).
local function AutoReconnectToggle(state, callbacks)
	local hovered = vide.source(false)
	return vide.create "TextButton" {
		Name = "AutoReconnectToggle",
		Size = UDim2.new(0.38, 0, 1, -6),
		Position = UDim2.new(0.62, 0, 0, 3),
		BackgroundColor3 = function()
			return if hovered() then Theme.Color.IconButtonHover else Theme.Color.IconButton
		end,
		BorderSizePixel = 0,
		AutoButtonColor = false,
		Font = Theme.Font.Body,
		TextSize = 12,
		TextColor3 = Theme.Color.ButtonText,
		Text = function()
			return if state.autoReconnectEnabled() then "Ativado" else "Desativado"
		end,

		vide.create "UICorner" { CornerRadius = Theme.Layout.CornerRadius },

		MouseEnter = function()
			hovered(true)
		end,
		MouseLeave = function()
			hovered(false)
		end,
		Activated = function()
			local newValue = not state.autoReconnectEnabled()
			state.autoReconnectEnabled(newValue)
			callbacks.onAutoReconnectToggle(newValue)
		end,
	}
end

-- Itens "em breve" (spec da tarefa: desabilitados, sem funcionalidade real
-- nesta fatia) — texto estático à direita, sem controle nenhum.
local DISABLED_SETTINGS = {
	"Nome de exibição customizado",
	"Containers observados",
	"Nível de log",
}

local function DisabledSettingRow(labelText)
	return SettingsRow(
		labelText,
		vide.create "TextLabel" {
			Size = UDim2.new(0.38, 0, 1, 0),
			Position = UDim2.new(0.62, 0, 0, 0),
			BackgroundTransparency = 1,
			Font = Theme.Font.Body,
			TextSize = 12,
			TextColor3 = Theme.Color.DisabledText,
			TextXAlignment = Enum.TextXAlignment.Right,
			Text = "em breve",
		},
		true
	)
end

local function SettingsView(state, callbacks)
	local backHovered = vide.source(false)
	local backButton = vide.create "TextButton" {
		Name = "BackButton",
		Size = UDim2.fromOffset(Theme.Layout.IconButtonSize, Theme.Layout.IconButtonSize),
		Position = UDim2.new(0, Theme.Layout.Padding, 0.5, -Theme.Layout.IconButtonSize / 2),
		BackgroundColor3 = function()
			return if backHovered() then Theme.Color.IconButtonHover else Theme.Color.IconButton
		end,
		BorderSizePixel = 0,
		AutoButtonColor = false,
		Font = Theme.Font.Body,
		TextSize = 14,
		TextColor3 = Theme.Color.ButtonText,
		Text = "\u{2190}", -- seta pra esquerda (←) — volta pra tela principal

		vide.create "UICorner" { CornerRadius = Theme.Layout.CornerRadius },

		MouseEnter = function()
			backHovered(true)
		end,
		MouseLeave = function()
			backHovered(false)
		end,
		Activated = function()
			state.view("main")
		end,
	}

	local titleBar = vide.create "Frame" {
		Name = "TitleBar",
		Size = UDim2.new(1, 0, 0, TITLE_HEIGHT),
		BackgroundColor3 = Theme.Color.TitleBar,
		BorderSizePixel = 0,

		vide.create "TextLabel" {
			Size = UDim2.fromScale(1, 1),
			BackgroundTransparency = 1,
			Font = Theme.Font.Title,
			TextSize = 16,
			TextColor3 = Theme.Color.TitleText,
			Text = "CONFIGURAÇÕES",
		},
		backButton,
	}

	return vide.create "Frame" {
		Name = "SettingsView",
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,

		titleBar,
		vide.create "Frame" {
			Name = "SettingsBody",
			Position = UDim2.new(0, Theme.Layout.Padding, 0, TITLE_HEIGHT + ROW_GAP),
			Size = UDim2.new(1, -2 * Theme.Layout.Padding, 1, -(TITLE_HEIGHT + ROW_GAP + Theme.Layout.Padding)),
			BackgroundTransparency = 1,

			vide.create "UIListLayout" {
				SortOrder = Enum.SortOrder.LayoutOrder,
				Padding = UDim.new(0, 4),
			},

			SettingsRow("Mostrar notificações", NotificationsToggle(state, callbacks), false),
			SettingsRow(
				"Reconectar automaticamente ao abrir a place",
				AutoReconnectToggle(state, callbacks),
				false
			),
			DisabledSettingRow(DISABLED_SETTINGS[1]),
			DisabledSettingRow(DISABLED_SETTINGS[2]),
			DisabledSettingRow(DISABLED_SETTINGS[3]),
		},
	}
end

-- ------------------------------------------------------------------- root

-- Constrói a árvore inteira (main view + settings view, trocadas por
-- vide.switch olhando state.view — NUNCA um segundo DockWidgetPluginGui,
-- spec da tarefa) e devolve o rootFrame. Quem chama (PluginUI.luau) parenta
-- rootFrame dentro do DockWidgetPluginGui. O toast de notificação NÃO é mais
-- criado aqui: virou um ScreenGui flutuante independente em CoreGui (ver
-- Toast.luau), montado por PluginUI.init fora deste vide.mount.
function StatusPanel.build(state, callbacks)
	return vide.create "Frame" {
		Name = "SyncTeamRoot",
		Size = UDim2.fromScale(1, 1),
		BackgroundColor3 = Theme.Color.Background,
		BorderSizePixel = 0,
		-- Higiene de painel: nada deve desenhar fora dos limites do widget.
		-- (Antes este clip também servia ao truque de slide-in do toast, que
		-- vivia aqui dentro; o toast agora é um ScreenGui livre em CoreGui e o
		-- clip só permanece por bom senso de layout.)
		ClipsDescendants = true,

		vide.switch(state.view) {
			main = function()
				return MainView(state, callbacks)
			end,
			settings = function()
				return SettingsView(state, callbacks)
			end,
		},
	}
end

return StatusPanel
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="12">
        <Properties>
          <string name="Name">Theme</string>
          <string name="Source"><![CDATA[-- SyncTeam — Constantes visuais do painel de status (M4.5)
--
-- Centraliza cor/espaçamento/fonte usados por StatusPanel.luau/Toast.luau/
-- PluginUI.luau — nenhum valor "mágico" solto nos componentes. Nenhuma das
-- cores abaixo veio de uma referência já validada (o RojoCoop só tinha UI do
-- lado da extensão VS Code, ver .claude/agent-memory/ui-dev.md); são
-- decisões de design desta tarefa, documentadas em detalhe na memória do
-- agente — mudar aqui muda o painel inteiro de uma vez.
--
-- Paleta pensada para conviver com os dois temas do Studio (claro/escuro):
-- como DockWidgetPluginGui não expõe um "tema atual" simples de observar por
-- Vide sem StudioService (fora de escopo desta fatia — decisão registrada em
-- .claude/agent-memory/ui-dev.md), o painel usa uma paleta ESCURA FIXA
-- (segue o mockup do usuário: "título no topo escuro"), igual nos dois temas
-- do Studio. Mesma decisão pragmática já aceita alhures no projeto quando o
-- 100% "correto" (StudioService:GetPropertyChangedSignal("Theme")) fica para
-- uma iteração futura.

local Theme = {}

Theme.Color = {
	-- Fundo geral do painel (main view e settings view).
	Background = Color3.fromRGB(30, 30, 34),
	-- Barra de título "SYNC TEAM" — mais escura que o fundo (mockup do
	-- usuário: "título no topo escuro").
	TitleBar = Color3.fromRGB(18, 18, 21),
	TitleText = Color3.fromRGB(235, 235, 240),

	-- Campo de porta (TextBox) e labels de suporte.
	FieldBackground = Color3.fromRGB(45, 45, 50),
	FieldText = Color3.fromRGB(220, 220, 225),
	FieldPlaceholder = Color3.fromRGB(130, 130, 138),
	LabelMuted = Color3.fromRGB(150, 150, 158),

	-- Botão CONNECT/DISCONNECT muda de cor conforme o estado da conexão (3
	-- estados, ver StatusPanel.ConnectRow / init.server.runConnection):
	-- azul = parado (ação: conectar), laranja = tentando/reconectando,
	-- vermelho = conectado (ação: desconectar).
	ConnectIdle = Color3.fromRGB(46, 111, 219), -- azul: "disconnected" parado, ação = "conectar"
	ConnectIdleHover = Color3.fromRGB(58, 125, 235),
	ConnectConnecting = Color3.fromRGB(224, 132, 32), -- laranja: "connecting"/reconectando em loop
	ConnectConnectingHover = Color3.fromRGB(238, 146, 46),
	ConnectActive = Color3.fromRGB(196, 60, 60), -- vermelho: "connected", ação = "desconectar"
	ConnectActiveHover = Color3.fromRGB(214, 74, 74),
	ButtonText = Color3.fromRGB(245, 245, 248),

	-- Engrenagem de configurações e botão de voltar.
	IconButton = Color3.fromRGB(60, 60, 66),
	IconButtonHover = Color3.fromRGB(75, 75, 82),

	-- Cabeçalho e linhas da tabela USER | INFO.
	TableHeaderText = Color3.fromRGB(140, 140, 148),
	RowBackgroundEven = Color3.fromRGB(36, 36, 41),
	RowBackgroundOdd = Color3.fromRGB(30, 30, 34),
	RowText = Color3.fromRGB(225, 225, 230),
	RowInfoText = Color3.fromRGB(165, 165, 172),
	-- Bolinha de líder — verde, convenção comum de "ativo/principal"; nenhuma
	-- outra cor no painel usa verde, sem ambiguidade.
	LeaderDot = Color3.fromRGB(70, 200, 120),

	-- Opções "em breve" nas configurações.
	DisabledText = Color3.fromRGB(100, 100, 108),

	-- Toast (M4.5, item 3 da tarefa) — fundo neutro escuro com faixa de
	-- destaque à esquerda; texto claro. Sem variação de cor por severidade
	-- nesta fatia (todo gatilho listado na tarefa é "erro/aviso genuíno";
	-- diferenciar info/warning/error fica para uma iteração futura se
	-- surgir um gatilho que precise).
	ToastBackground = Color3.fromRGB(50, 50, 56),
	ToastAccent = Color3.fromRGB(219, 156, 46), -- âmbar: "atenção", nem erro fatal nem sucesso
	ToastText = Color3.fromRGB(240, 240, 244),
	-- Botão de fechar (✕) do toast flutuante — discreto, acende no hover.
	ToastCloseIdle = Color3.fromRGB(150, 150, 158),
	ToastCloseHover = Color3.fromRGB(240, 240, 244),
}

Theme.Font = {
	Title = Enum.Font.GothamBold,
	Body = Enum.Font.Gotham,
	Bold = Enum.Font.GothamBold,
}

-- Espaçamentos/tamanhos usados em mais de um componente (evita repetir o
-- mesmo número mágico em StatusPanel/Toast/PluginUI). Layout exato em pixels
-- é decisão desta tarefa, não especificada pelo mockup — ver memória do
-- agente para o raciocínio completo.
Theme.Layout = {
	Padding = 10,
	TitleBarHeight = 36,
	RowHeight = 30,
	ButtonHeight = 34,
	IconButtonSize = 28,
	CornerRadius = UDim.new(0, 6),
}

return Theme
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="13">
        <Properties>
          <string name="Name">Toast</string>
          <string name="Source"><![CDATA[-- SyncTeam — Notificação flutuante (ScreenGui em CoreGui) do plugin (M4.5+)
--
-- Substitui o toast antigo, que vivia DENTRO do DockWidgetPluginGui do painel
-- sob a premissa (confirmada ERRADA por pesquisa) de que plugin de Studio só
-- tem DockWidgetPluginGui como superfície de UI. A pesquisa
-- (.claude/research/2026-07-15-plugin-floating-overlay-notification.md)
-- confirmou — inclusive no código-fonte público do Rojo — que um plugin PODE
-- criar um `ScreenGui` parentado direto em `game:GetService("CoreGui")`,
-- flutuando LIVREMENTE sobre o Studio (mesma técnica do popup do Rojo). Este
-- módulo cria esse ScreenGui + um Frame de aviso com botão de fechar (✕, canto
-- superior direito) que some sozinho depois de HOLD_SECONDS (5s, item 2 da
-- tarefa; era 4.5s no toast antigo).
--
-- Independente do painel: aparece por conta própria, sem precisar mais forçar o
-- DockWidgetPluginGui a abrir (ver PluginUI.notify). Ressalva registrada na
-- pesquisa (a validar em teste real): o overlay via CoreGui provavelmente só
-- cobre a área do viewport 3D, não os painéis nativos (Explorer/Properties/
-- Output). O log no Output (Logger.notify, incondicional) continua sendo o
-- registro GARANTIDO de todo evento notificável.
--
-- SEM reatividade Vide: `vide.create` é usado só para montar Instances com
-- props ESTÁTICAS (estilo consistente via Theme) — o texto é setado
-- imperativamente em `show()`, o hover do ✕ idem, e a animação é
-- TweenService + task.delay. Assim este módulo NÃO depende de um escopo
-- `vide.root()`/`vide.mount` ativo (é criado direto por PluginUI.init, FORA do
-- vide.mount do painel), evitando o erro "effect() outside stable scope" que
-- confinava a versão anterior à árvore reativa do painel. (Eventos como
-- MouseEnter/Activated são apenas conexões de sinal — não criam effect, não
-- exigem escopo; só props com VALOR-função exigiriam.)
--
-- Só 1 notificação por vez (sem fila): uma nova chamada de `show()` reinicia
-- texto/tween/timer. Token de geração garante que um auto-dismiss antigo não
-- feche por cima de um `show()` mais novo, e que o botão fechar cancele o
-- auto-dismiss pendente.
--
-- Ciclo de vida: CoreGui persiste entre reloads do plugin (NÃO é auto-limpo
-- como o DockWidgetPluginGui) — por isso `mount()` faz self-heal (destrói um
-- ScreenGui vazado de um load anterior) e devolve `destroy()` para
-- PluginUI.stop() chamar em plugin.Unloading (mesma disciplina do vazamento de
-- WebStreamClient documentado em docs/DECISIONS.md).

local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

local vide = require(script.Parent.Parent.Packages.Vide)
local Theme = require(script.Parent.Theme)

local Toast = {}

local WIDTH = 300
local HEIGHT = 64
local MARGIN = 16
local ENTER_SECONDS = 0.28
local EXIT_SECONDS = 0.22
local HOLD_SECONDS = 5 -- item 2 da tarefa: era 4.5 no toast antigo, agora 5

local SCREEN_GUI_NAME = "SyncTeamNotifications"

-- Ancorado no canto inferior-direito da tela (AnchorPoint 1,1). "Escondido" =
-- empurrado além da borda direita pela própria largura + margem; como a
-- posição é relativa à borda (Scale X = 1), o ScreenGui de tela cheia recorta
-- a parte fora e o slide-in funciona sem precisar de ClipsDescendants.
local HIDDEN_POSITION = UDim2.new(1, WIDTH + MARGIN + 40, 1, -MARGIN)
local VISIBLE_POSITION = UDim2.new(1, -MARGIN, 1, -MARGIN)

-- Cria o ScreenGui em CoreGui + o Frame de toast (oculto, fora da borda
-- direita) e devolve { show = function(text: string), destroy = function() }.
-- Chamado 1x por PluginUI.init, fora do vide.mount do painel.
function Toast.mount()
	-- Self-heal: remove um ScreenGui vazado de um load anterior do plugin
	-- (CoreGui não é limpo automaticamente ao recarregar o plugin — ao
	-- contrário do DockWidgetPluginGui, que o Studio gerencia).
	local existing = CoreGui:FindFirstChild(SCREEN_GUI_NAME)
	if existing then
		existing:Destroy()
	end

	-- Forward-declaradas: os handlers (tween/dismiss/hover) capturam estes
	-- upvalues, que já estarão atribuídos quando qualquer evento disparar (só
	-- ocorrem depois que este mount() inteiro já retornou).
	local frame
	local screenGui
	local currentToken = 0

	local function tweenTo(position, seconds, direction)
		TweenService:Create(
			frame,
			TweenInfo.new(seconds, Enum.EasingStyle.Quad, direction),
			{ Position = position }
		):Play()
	end

	-- Fecha imediatamente e invalida qualquer auto-dismiss pendente (bump de
	-- token, mesmo mecanismo do timer de show) — usado pelo botão ✕.
	local function dismiss()
		currentToken += 1
		tweenTo(HIDDEN_POSITION, EXIT_SECONDS, Enum.EasingDirection.In)
	end

	local textLabel = vide.create "TextLabel" {
		Name = "Text",
		Size = UDim2.new(1, -44, 1, -16), -- -44: deixa folga à direita pro botão ✕
		Position = UDim2.new(0, 14, 0, 8),
		BackgroundTransparency = 1,
		Font = Theme.Font.Body,
		TextSize = 14,
		TextColor3 = Theme.Color.ToastText,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextWrapped = true,
		Text = "",
	}

	local closeButton
	closeButton = vide.create "TextButton" {
		Name = "Close",
		Size = UDim2.fromOffset(20, 20),
		Position = UDim2.new(1, -6, 0, 6),
		AnchorPoint = Vector2.new(1, 0),
		BackgroundTransparency = 1,
		AutoButtonColor = false,
		Font = Theme.Font.Bold,
		TextSize = 16,
		TextColor3 = Theme.Color.ToastCloseIdle,
		Text = "\u{2715}", -- ✕ (fechar)

		-- Hover imperativo (sem vide.source, para não exigir escopo reativo).
		MouseEnter = function()
			closeButton.TextColor3 = Theme.Color.ToastCloseHover
		end,
		MouseLeave = function()
			closeButton.TextColor3 = Theme.Color.ToastCloseIdle
		end,
		Activated = function()
			dismiss()
		end,
	}

	frame = vide.create "Frame" {
		Name = "SyncTeamToast",
		Size = UDim2.fromOffset(WIDTH, HEIGHT),
		AnchorPoint = Vector2.new(1, 1),
		Position = HIDDEN_POSITION,
		BackgroundColor3 = Theme.Color.ToastBackground,
		BorderSizePixel = 0,
		ZIndex = 100,

		vide.create "UICorner" { CornerRadius = Theme.Layout.CornerRadius },
		vide.create "Frame" {
			Name = "Accent",
			Size = UDim2.new(0, 4, 1, 0),
			BackgroundColor3 = Theme.Color.ToastAccent,
			BorderSizePixel = 0,
		},
		textLabel,
		closeButton,
	}

	screenGui = vide.create "ScreenGui" {
		Name = SCREEN_GUI_NAME,
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 100, -- por cima de outros ScreenGuis (mesmo valor do Rojo)
		IgnoreGuiInset = true,

		frame,
	}
	screenGui.Parent = CoreGui

	local function show(text)
		currentToken += 1
		local myToken = currentToken
		textLabel.Text = text

		TweenService:Create(
			frame,
			TweenInfo.new(ENTER_SECONDS, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Position = VISIBLE_POSITION }
		):Play()

		task.delay(HOLD_SECONDS, function()
			if currentToken ~= myToken then
				return -- um show()/dismiss() mais novo já assumiu; deixa o dele terminar
			end
			TweenService:Create(
				frame,
				TweenInfo.new(EXIT_SECONDS, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{ Position = HIDDEN_POSITION }
			):Play()
		end)
	end

	-- Chamado por PluginUI.stop() em plugin.Unloading — destrói o ScreenGui de
	-- CoreGui (que não seria limpo sozinho). Bump de token para não deixar um
	-- auto-dismiss pendente tocar tween num Frame já destruído.
	local function destroy()
		currentToken += 1
		pcall(function()
			screenGui:Destroy()
		end)
	end

	return { show = show, destroy = destroy }
end

return Toast
]]></string>
        </Properties>
      </Item>
