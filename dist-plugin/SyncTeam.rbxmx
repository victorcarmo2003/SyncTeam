            <Item class="ModuleScript" referent="36">
              <Properties>
                <string name="Name">read</string>
                <string name="Source"><![CDATA[local function read<T>(value: T | () -> T): T
    return if type(value) == "function" then value() else value
end

return read
]]></string>
